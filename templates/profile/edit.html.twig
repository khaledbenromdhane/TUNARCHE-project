{% extends 'base.html.twig' %}

{% block title %}Modifier mon profil - ArtVista{% endblock %}

{% block body %}
<div class="breadcumb-wrapper" data-bg-src="{{ asset('assets/img/bg/breadcumb-bg.jpg') }}">
    <div class="container"><div class="breadcumb-content">
        <h1 class="breadcumb-title">Modifier mon profil</h1>
        <ul class="breadcumb-menu">
            <li><a href="{{ path('app_home') }}">Accueil</a></li>
            <li><a href="{{ path('app_profile') }}">Profil</a></li>
            <li>Modifier</li>
        </ul>
    </div></div>
</div>

<div class="space overflow-hidden"><div class="container">
    <div class="row justify-content-center"><div class="col-lg-8">
        <div class="contact-form-area">
            <div class="d-flex align-items-center gap-3 mb-4">
                <img src="{{ user.avatarUrl }}" alt="avatar"
                     style="width:60px;height:60px;border-radius:50%;object-fit:cover;border:3px solid #d4a574;">
                <div>
                    <h2 class="sec-title mb-0">Modifier mon profil</h2>
                    <p class="text-muted mb-0">{{ user.email }}</p>
                </div>
            </div>

            {% for message in app.flashes('success') %}
                <div class="alert alert-success alert-dismissible fade show">{{ message }}<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
            {% endfor %}
            {% for message in app.flashes('error') %}
                <div class="alert alert-danger alert-dismissible fade show">{{ message }}<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
            {% endfor %}

            {{ form_start(form, {'attr': {'class': 'contact-form', 'enctype': 'multipart/form-data', 'id': 'profileForm'}}) }}
            <div class="row gx-20">

                {# Avatar #}
                <div class="col-12 mb-4">
                    <div class="text-center">
                        <div class="position-relative d-inline-block mb-2">
                            <img id="avatarPreview"
                                 src="{{ user.avatarUrl }}"
                                 style="width:100px;height:100px;border-radius:50%;object-fit:cover;border:4px solid #d4a574;cursor:pointer;"
                                 onclick="document.getElementById('avatarFile').click()" alt="Avatar"
                                 onerror="this.src='https://ui-avatars.com/api/?name={{ user.prenom|url_encode }}+{{ user.nom|url_encode }}&background=d4a574&color=fff'">
                            <button type="button" onclick="document.getElementById('avatarFile').click()"
                                    class="position-absolute btn"
                                    style="bottom:2px;right:2px;width:28px;height:28px;border-radius:50%;padding:0;background:#d4a574;border:2px solid #fff;">
                                <i class="fas fa-camera" style="font-size:10px;color:white;"></i>
                            </button>
                        </div>
                        <p class="text-muted small">Cliquez pour changer la photo</p>
                        <div style="display:none;">{{ form_widget(form.avatarFile, {'attr': {'id': 'avatarFile', 'accept': 'image/*'}}) }}</div>
                        <div class="text-danger small">{{ form_errors(form.avatarFile) }}</div>
                    </div>
                </div>

                <div class="col-md-6">
                    <div class="form-group">
                        {{ form_label(form.nom) }}
                        {{ form_widget(form.nom, {'attr': {'class': 'form-control'}}) }}
                        <div class="text-danger small">{{ form_errors(form.nom) }}</div>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="form-group">
                        {{ form_label(form.prenom) }}
                        {{ form_widget(form.prenom, {'attr': {'class': 'form-control'}}) }}
                        <div class="text-danger small">{{ form_errors(form.prenom) }}</div>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="form-group">
                        {{ form_label(form.email) }}
                        {{ form_widget(form.email, {'attr': {'class': 'form-control'}}) }}
                        <div class="text-danger small">{{ form_errors(form.email) }}</div>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="form-group">
                        {{ form_label(form.telephone) }}
                        {{ form_widget(form.telephone, {'attr': {'class': 'form-control'}}) }}
                        <div class="text-danger small">{{ form_errors(form.telephone) }}</div>
                    </div>
                </div>

                <div class="col-12">
                    <hr><h5 style="color:#d4a574;"><i class="fas fa-lock me-2"></i>Changer le mot de passe</h5>
                    <p class="text-muted small">Laissez vide pour conserver l'actuel</p>
                </div>
                <div class="col-md-6">
                    <div class="form-group">
                        {{ form_widget(form.newPassword.first, {'attr': {'class': 'form-control', 'id': 'pwdNew', 'placeholder': 'Nouveau mot de passe'}}) }}
                        <div class="text-danger small">{{ form_errors(form.newPassword.first) }}</div>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="form-group">
                        {{ form_widget(form.newPassword.second, {'attr': {'class': 'form-control', 'placeholder': 'Confirmer'}}) }}
                        <div class="text-danger small">{{ form_errors(form.newPassword.second) }}</div>
                    </div>
                </div>

                <div class="col-12 mt-3">
                    <div class="form-btn">
                        <button type="submit" class="btn"><i class="fas fa-save me-2"></i>ENREGISTRER</button>
                        <a href="{{ path('app_profile') }}" class="btn style2 ms-2"><i class="fas fa-times me-2"></i>ANNULER</a>
                    </div>
                </div>
            </div>
            {{ form_end(form) }}
        </div>
    </div></div>
</div></div>
{% endblock %}

{% block javascripts %}
<script>
document.getElementById('avatarFile').addEventListener('change', function() {
    const file = this.files[0];
    if (!file) return;
    const reader = new FileReader();
    reader.onload = e => document.getElementById('avatarPreview').src = e.target.result;
    reader.readAsDataURL(file);
});
</script>
{% endblock %}
