{% extends 'base.html.twig' %}

{% block title %}Home{% endblock %}

{% block body %}
<style>
    .welcome {
        max-width: 800px;
        margin: 100px auto;
        padding: 40px;
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        border-radius: 15px;
        box-shadow: 0 10px 40px rgba(0,0,0,0.2);
        text-align: center;
        color: white;
    }
    
    .welcome h1 {
        font-size: 3em;
        margin-bottom: 20px;
        font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif;
    }
    
    .welcome p {
        font-size: 1.2em;
        margin: 10px 0;
        opacity: 0.9;
    }
    
    .version {
        margin-top: 30px;
        padding: 15px;
        background: rgba(255,255,255,0.1);
        border-radius: 8px;
        font-weight: bold;
    }
</style>

<div class="welcome">
    <h1>🎉 Welcome to Symfony 6!</h1>
    <p>Your Symfony application is now up and running.</p>
    <p>Controller: <strong>{{ controller_name }}</strong></p>
    
    <div class="version">
        <p>✨ Symfony 6.4 Project Successfully Created ✨</p>
    </div>
</div>
{% endblock %}
