{% extends 'base.html.twig' %}

{% block title %}Connexion - ArtVista{% endblock %}

{% block body %}
<div class="breadcumb-wrapper" data-bg-src="{{ asset('assets/img/bg/breadcumb-bg.jpg') }}">
    <div class="container">
        <div class="breadcumb-content">
            <h1 class="breadcumb-title">Connexion</h1>
            <ul class="breadcumb-menu">
                <li><a href="{{ path('app_home') }}">Accueil</a></li>
                <li>Connexion</li>
            </ul>
        </div>
    </div>
</div>

<div class="space overflow-hidden">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-5 col-md-8">
                <div class="contact-form-area">

                    <div class="text-center mb-4">
                        <h2 class="sec-title">Connectez-vous</h2>
                        <p class="sec-text">Accédez à votre espace personnel</p>
                    </div>

                    {# Flash Messages #}
                    {% for message in app.flashes('success') %}
                        <div class="alert alert-success alert-dismissible fade show">
                            {{ message }}
                            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                        </div>
                    {% endfor %}
                    {% for message in app.flashes('info') %}
                        <div class="alert alert-info alert-dismissible fade show">
                            {{ message }}
                            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                        </div>
                    {% endfor %}

                    {% if error %}
                        <div class="alert alert-danger alert-dismissible fade show">
                            <i class="fas fa-exclamation-circle me-2"></i>
                            {{ error.messageKey|trans(error.messageData, 'security') }}
                            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                        </div>
                    {% endif %}

                    {# ── Bouton Google OAuth ── #}
                    <div class="mb-4">
                        <a href="{{ path('connect_google_start') }}"
                           class="btn w-100"
                           style="background:#fff;border:2px solid #ddd;color:#333;display:flex;align-items:center;justify-content:center;gap:10px;padding:12px;">
                            <svg width="20" height="20" viewBox="0 0 48 48">
                                <path fill="#EA4335" d="M24 9.5c3.54 0 6.71 1.22 9.21 3.6l6.85-6.85C35.9 2.38 30.47 0 24 0 14.62 0 6.51 5.38 2.56 13.22l7.98 6.19C12.43 13.72 17.74 9.5 24 9.5z"/>
                                <path fill="#4285F4" d="M46.98 24.55c0-1.57-.15-3.09-.38-4.55H24v9.02h12.94c-.58 2.96-2.26 5.48-4.78 7.18l7.73 6c4.51-4.18 7.09-10.36 7.09-17.65z"/>
                                <path fill="#FBBC05" d="M10.53 28.59c-.48-1.45-.76-2.99-.76-4.59s.27-3.14.76-4.59l-7.98-6.19C.92 16.46 0 20.12 0 24c0 3.88.92 7.54 2.56 10.78l7.97-6.19z"/>
                                <path fill="#34A853" d="M24 48c6.48 0 11.93-2.13 15.89-5.81l-7.73-6c-2.15 1.45-4.92 2.3-8.16 2.3-6.26 0-11.57-4.22-13.47-9.91l-7.98 6.19C6.51 42.62 14.62 48 24 48z"/>
                            </svg>
                            Continuer avec Google
                        </a>
                    </div>

                    <div class="text-center mb-3 position-relative">
                        <hr><span class="position-absolute bg-white px-3"
                                  style="top:-12px;left:50%;transform:translateX(-50%);color:#999;">
                            ou
                        </span>
                    </div>

                    {# ── Formulaire classique ── #}
                    <form method="post" action="{{ path('app_login') }}" class="contact-form" id="loginForm">
                        <div class="row gx-20">
                            <div class="col-12">
                                <div class="form-group">
                                    <label for="inputEmail">
                                        <i class="fas fa-envelope me-2" style="color:#d4a574;"></i>Email
                                    </label>
                                    <input type="email"
                                           class="form-control"
                                           id="inputEmail"
                                           name="_username"
                                           value="{{ last_username }}"
                                           required
                                           autofocus
                                           placeholder="exemple@email.com">
                                </div>
                            </div>

                            <div class="col-12">
                                <div class="form-group">
                                    <label for="inputPassword">
                                        <i class="fas fa-lock me-2" style="color:#d4a574;"></i>Mot de passe
                                    </label>
                                    <div class="position-relative">
                                        <input type="password"
                                               class="form-control"
                                               id="inputPassword"
                                               name="_password"
                                               required
                                               placeholder="Votre mot de passe">
                                        <button type="button"
                                                class="btn position-absolute top-0 end-0 h-100 px-3"
                                                style="background:none;border:none;"
                                                onclick="togglePassword()">
                                            <i class="fas fa-eye" id="toggleIcon" style="color:#d4a574;"></i>
                                        </button>
                                    </div>
                                </div>
                            </div>

                            <div class="col-12 d-flex justify-content-between align-items-center mb-3">
                                <div class="form-check">
                                    <input type="checkbox" class="form-check-input" id="remember_me" name="_remember_me">
                                    <label class="form-check-label" for="remember_me">Se souvenir de moi</label>
                                </div>
                                <a href="{{ path('app_forgot_password') }}" class="text-decoration-underline" style="color:#d4a574;font-size:14px;">
                                    Mot de passe oublié ?
                                </a>
                            </div>

                            <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">
                            {# Token reCAPTCHA v3 — injecté par JS #}
                            <input type="hidden" name="recaptcha_token" id="recaptchaToken">

                            <div class="col-12">
                                <div class="form-btn">
                                    <button type="submit" class="btn w-100" id="loginBtn">
                                        <i class="fas fa-sign-in-alt me-2"></i>SE CONNECTER
                                    </button>
                                </div>
                            </div>

                            <div class="col-12 text-center mt-3">
                                <p class="mb-0">
                                    Vous n'avez pas de compte ?
                                    <a href="{{ path('app_register') }}" class="text-decoration-underline fw-bold" style="color:#d4a574;">
                                        Inscrivez-vous
                                    </a>
                                </p>
                            </div>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}

{% block javascripts %}
<script>
    // ── Login form submit (reCAPTCHA optional) ──
    document.getElementById('loginForm').addEventListener('submit', function(e) {
        e.preventDefault();
        const form = this;

        try {
            if (typeof grecaptcha !== 'undefined') {
                grecaptcha.ready(function() {
                    grecaptcha.execute('{{ recaptcha_site_key|default("") }}', {action: 'login'})
                        .then(function(token) {
                            document.getElementById('recaptchaToken').value = token;
                            form.submit();
                        })
                        .catch(function() { form.submit(); });
                });
            } else {
                form.submit();
            }
        } catch(err) {
            form.submit();
        }
    });

    // ── Toggle password visibility ──
    function togglePassword() {
        const input = document.getElementById('inputPassword');
        const icon  = document.getElementById('toggleIcon');
        if (input.type === 'password') {
            input.type = 'text';
            icon.classList.replace('fa-eye', 'fa-eye-slash');
        } else {
            input.type = 'password';
            icon.classList.replace('fa-eye-slash', 'fa-eye');
        }
    }
</script>
{% endblock %}
