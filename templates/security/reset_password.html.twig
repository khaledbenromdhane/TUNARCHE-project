{% extends 'base.html.twig' %}
{% block title %}Nouveau mot de passe - ArtVista{% endblock %}
{% block body %}
<div class="breadcumb-wrapper" data-bg-src="{{ asset('assets/img/bg/breadcumb-bg.jpg') }}">
    <div class="container"><div class="breadcumb-content">
        <h1 class="breadcumb-title">Nouveau mot de passe</h1>
        <ul class="breadcumb-menu"><li><a href="{{ path('app_home') }}">Accueil</a></li><li>Réinitialisation</li></ul>
    </div></div>
</div>
<div class="space overflow-hidden"><div class="container"><div class="row justify-content-center"><div class="col-lg-5 col-md-8">
    <div class="contact-form-area">
        <div class="text-center mb-4">
            <div style="width:70px;height:70px;border-radius:50%;background:linear-gradient(135deg,#d4a574,#c4924e);display:flex;align-items:center;justify-content:center;margin:0 auto 16px;">
                <i class="fas fa-lock fa-2x text-white"></i>
            </div>
            <h2 class="sec-title">Nouveau mot de passe</h2>
        </div>
        {% for message in app.flashes('error') %}
            <div class="alert alert-danger alert-dismissible fade show">{{ message }}<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
        {% endfor %}
        <form method="post" class="contact-form">
            <div class="row gx-20">
                <div class="col-12">
                    <div class="form-group">
                        <label for="password"><i class="fas fa-lock me-2" style="color:#d4a574;"></i>Nouveau mot de passe</label>
                        <div class="position-relative">
                            <input type="password" class="form-control" id="password" name="password" required minlength="8" placeholder="Min. 8 caractères">
                            <button type="button" onclick="t1()" class="btn position-absolute top-0 end-0 h-100 px-3" style="background:none;border:none;"><i class="fas fa-eye" id="i1" style="color:#d4a574;"></i></button>
                        </div>
                        <div id="str" style="display:none;" class="mt-2">
                            <div class="progress" style="height:4px;"><div id="bar" class="progress-bar" style="width:0%;transition:width .3s;"></div></div>
                            <small id="strtxt" class="text-muted"></small>
                        </div>
                    </div>
                </div>
                <div class="col-12">
                    <div class="form-group">
                        <label for="password_confirm"><i class="fas fa-check-double me-2" style="color:#d4a574;"></i>Confirmer</label>
                        <div class="position-relative">
                            <input type="password" class="form-control" id="password_confirm" name="password_confirm" required placeholder="Répétez le mot de passe">
                            <button type="button" onclick="t2()" class="btn position-absolute top-0 end-0 h-100 px-3" style="background:none;border:none;"><i class="fas fa-eye" id="i2" style="color:#d4a574;"></i></button>
                        </div>
                        <div id="matchMsg" class="small mt-1"></div>
                    </div>
                </div>
                <div class="col-12">
                    <button type="submit" class="btn w-100"><i class="fas fa-save me-2"></i>ENREGISTRER</button>
                </div>
            </div>
        </form>
    </div>
</div></div></div></div>
{% endblock %}
{% block javascripts %}
<script>
function t1(){const i=document.getElementById('password'),ic=document.getElementById('i1');i.type=i.type==='password'?'text':'password';ic.classList.toggle('fa-eye');ic.classList.toggle('fa-eye-slash');}
function t2(){const i=document.getElementById('password_confirm'),ic=document.getElementById('i2');i.type=i.type==='password'?'text':'password';ic.classList.toggle('fa-eye');ic.classList.toggle('fa-eye-slash');}
document.getElementById('password').addEventListener('input',function(){
    const v=this.value;document.getElementById('str').style.display=v?'block':'none';
    let s=[v.length>=8,/[A-Z]/.test(v),/[a-z]/.test(v),/\d/.test(v),/[^A-Za-z0-9]/.test(v)].filter(Boolean).length;
    const l=[['#dc3545','Très faible','20%'],['#fd7e14','Faible','40%'],['#ffc107','Moyen','60%'],['#20c997','Fort','80%'],['#198754','Très fort','100%']][Math.max(0,s-1)];
    document.getElementById('bar').style.cssText=`width:${l[2]};background:${l[0]};`;
    document.getElementById('strtxt').textContent=l[1];document.getElementById('strtxt').style.color=l[0];
});
document.getElementById('password_confirm').addEventListener('input',function(){
    const match=this.value===document.getElementById('password').value;
    const m=document.getElementById('matchMsg');
    m.innerHTML=this.value?(match?'<i class="fas fa-check me-1"></i>Correspondent':'<i class="fas fa-times me-1"></i>Ne correspondent pas'):'';
    m.style.color=match?'#198754':'#dc3545';
});
</script>
{% endblock %}
