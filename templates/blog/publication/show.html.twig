<!doctype html>
<html class="no-js" lang="zxx">

<head>
    <meta charset="utf-8">
    <meta http-equiv="x-ua-compatible" content="ie=edge">
    <title>{{ publication.titre }} - Artvista</title>
    <meta name="description" content="{{ publication.description }}">
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">

    <link rel="icon" type="image/png" sizes="32x32" href="/assets/img/favicons/favicon.png">
    
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Jost:ital,wght@0,100..900;1,100..900&family=Roboto:ital,wght@0,100;0,300;0,400;0,500;0,700;0,900;1,100;1,300;1,400;1,500;1,700;1,900&display=swap" rel="stylesheet">

    <link rel="stylesheet" href="/assets/css/bootstrap.min.css">
    <link rel="stylesheet" href="/assets/css/all.min.css">
    <link rel="stylesheet" href="/assets/css/magnific-popup.min.css">
    <link rel="stylesheet" href="/assets/css/slick.min.css">
    <link rel="stylesheet" href="/assets/css/odometer.css">
    <link rel="stylesheet" href="/assets/css/style.css">

    <style>
        .user-avatar-btn {
            display: flex; align-items: center; gap: 8px;
            background: none; border: none; cursor: pointer;
            color: inherit; text-decoration: none;
        }
        .user-avatar-btn img {
            width: 36px; height: 36px;
            border-radius: 50%; object-fit: cover;
            border: 2px solid #d4a574;
        }
        .user-avatar-btn .user-name { font-size: 14px; font-weight: 500; }
        .profile-dropdown {
            min-width: 220px; border: none;
            box-shadow: 0 8px 30px rgba(0,0,0,0.15);
            border-radius: 12px; overflow: hidden;
        }
        .profile-dropdown .dropdown-header {
            background: linear-gradient(135deg, #d4a574, #c4924e);
            color: white; padding: 16px;
        }
        .profile-dropdown .dropdown-header img {
            width: 55px; height: 55px;
            border-radius: 50%; object-fit: cover;
            border: 3px solid rgba(255,255,255,0.5); margin-bottom: 8px;
        }
        .profile-dropdown .dropdown-item {
            padding: 10px 16px; font-size: 14px;
            display: flex; align-items: center; gap: 10px;
        }
        .profile-dropdown .dropdown-item:hover { background-color: #f8f4ef; color: #d4a574; }
        .profile-dropdown .dropdown-item i { width: 16px; color: #d4a574; }
        .profile-dropdown .dropdown-item.text-danger i { color: #dc3545; }
    </style>
</head>

<body>
    <!-- Cursor -->
    <div class="cursor"></div>
    <div class="cursor-follower"></div>

    <div class="preloader">
        <div class="preloader-inner">
            <img src="/assets/img/logo-white.svg" alt="Artvista">
            <span class="loader"></span>
        </div>
    </div>

    <div class="sidemenu-wrapper">
        <div class="sidemenu-content">
            <button class="closeButton sideMenuCls"><i class="fas fa-times"></i></button>
            <div class="widget footer-widget mb-4">
                <h4 class="widget_title text-white mb-3">Mon Compte</h4>
                {% if app.user %}
                    <div class="d-flex align-items-center gap-2 mb-3">
                        <img src="{{ app.user.avatarUrl }}" alt="Avatar"
                             style="width:45px;height:45px;border-radius:50%;object-fit:cover;border:2px solid #d4a574;">
                        <div>
                            <div class="text-white fw-bold">{{ app.user.prenom }} {{ app.user.nom }}</div>
                            <small class="text-muted">{{ app.user.email }}</small>
                        </div>
                    </div>
                    <a href="{{ path('app_profile') }}" class="btn w-100 mb-2">
                        <i class="fas fa-user me-2"></i>Mon Profil
                    </a>
                    <a href="{{ path('app_logout') }}" class="btn style2 w-100">
                        <i class="fas fa-sign-out-alt me-2"></i>Déconnexion
                    </a>
                {% else %}
                    <a href="{{ path('app_login') }}" class="btn w-100 mb-2">
                        <i class="fas fa-sign-in-alt me-2"></i>Connexion
                    </a>
                    <a href="{{ path('app_register') }}" class="btn style2 w-100">
                        <i class="fas fa-user-plus me-2"></i>Inscription
                    </a>
                {% endif %}
            </div>
            <div class="widget footer-widget">
                <div class="widget widget-about footer-widget">
                    <div class="footer-logo">
                        <a href="{{ path('app_front_index') }}"><img src="/assets/img/logo-white.svg" alt="logo"></a>
                    </div>
                    <p class="about-text mb-4 text-white">Découvrez l'art sous toutes ses formes avec Artvista.</p>
                    <div class="social-btn style2 mt-30">
                        <a href="https://facebook.com/"><i class="fab fa-facebook-f"></i></a>
                        <a href="https://www.twitter.com/"><i class="fab fa-twitter"></i></a>
                        <a href="https://linkedin.com/"><i class="fab fa-linkedin-in"></i></a>
                        <a href="https://instagram.com/"><i class="fab fa-instagram"></i></a>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="popup-search-box">
        <button class="searchClose"><i class="fas fa-times"></i></button>
        <form action="#">
            <input type="text" placeholder="Search Here..">
            <button type="submit"><i class="fas fa-search"></i></button>
        </form>
    </div>

    <div class="mobile-menu-wrapper">
        <div class="mobile-menu-area text-center">
            <button class="menu-toggle"><i class="fas fa-times"></i></button>
            <div class="mobile-logo">
                <a href="{{ path('app_front_index') }}"><img src="/assets/img/logo-white.svg" alt="Artvista"></a>
            </div>
            <div class="mobile-menu">
                <ul>
                    {% if app.user %}
                        <li><a href="{{ path('app_profile') }}"><i class="fas fa-user-circle me-2"></i>Mon Profil</a></li>
                        {% if is_granted('ROLE_ADMIN') %}
                            <li><a href="{{ path('app_admin_dashboard') }}"><i class="fas fa-tachometer-alt me-2"></i>Administration</a></li>
                        {% endif %}
                        <li><a href="{{ path('app_logout') }}"><i class="fas fa-sign-out-alt me-2"></i>Déconnexion</a></li>
                    {% else %}
                        <li><a href="{{ path('app_login') }}"><i class="fas fa-sign-in-alt me-2"></i>Connexion</a></li>
                        <li><a href="{{ path('app_register') }}"><i class="fas fa-user-plus me-2"></i>Inscription</a></li>
                    {% endif %}
                    <li><a href="{{ path('app_front_index') }}">Accueil</a></li>
                    <li><a href="{{ path('app_front_oeuvre') }}">Œuvres</a></li>
                    <li><a href="{{ path('app_evenement_index') }}">Événements</a></li>
                    <li><a href="{{ path('blog_publication_index') }}">Blog</a></li>
                    <li><a href="{{ path('app_formation_front') }}">Formation</a></li>
                </ul>
            </div>
        </div>
    </div>

    <!--==============================
	Header Area
    ==============================-->
    <header class="nav-header header-layout1">
        <div class="header-top d-md-block d-none">
            <div class="container">
                <div class="row justify-content-center justify-content-lg-between align-items-center gy-2">
                    <div class="col-auto">
                        <div class="header-links">
                            <ul>
                                <li><i class="far fa-envelope"></i><a href="mailto:info@artvista.com">Mail Us: info@artvista.com</a></li>
                                <li><i class="far fa-clock"></i>Mon - Fri: 8:00AM - 6:00PM</li>
                            </ul>
                        </div>
                    </div>
                    <div class="col-auto d-none d-lg-block">
                        <div class="header-links header-links-right">
                            <ul>
                                <li>
                                    {% if app.user %}
                                        <div class="dropdown">
                                            <a class="user-avatar-btn dropdown-toggle" href="#" role="button"
                                               data-bs-toggle="dropdown" aria-expanded="false">
                                                <img src="{{ app.user.avatarUrl }}" alt="{{ app.user.prenom }}"
                                                     onerror="this.src='https://ui-avatars.com/api/?name={{ app.user.prenom|url_encode }}+{{ app.user.nom|url_encode }}&background=d4a574&color=fff'">
                                                <span class="user-name">{{ app.user.prenom }}</span>
                                                <i class="fas fa-chevron-down ms-1" style="font-size:10px;"></i>
                                            </a>
                                            <ul class="dropdown-menu dropdown-menu-end profile-dropdown">
                                                <li>
                                                    <div class="dropdown-header text-center">
                                                        <img src="{{ app.user.avatarUrl }}" alt="{{ app.user.prenom }}"
                                                             onerror="this.src='https://ui-avatars.com/api/?name={{ app.user.prenom|url_encode }}+{{ app.user.nom|url_encode }}&background=d4a574&color=fff'">
                                                        <div class="fw-bold">{{ app.user.prenom }} {{ app.user.nom }}</div>
                                                        <small style="opacity:.8;">{{ app.user.email }}</small>
                                                        <div class="mt-1">
                                                            {% for role in app.user.roles %}
                                                                {% if role != 'ROLE_USER' %}
                                                                    <span class="badge" style="background:rgba(255,255,255,0.3);font-size:10px;">
                                                                        {{ role|replace({'ROLE_': ''}) }}
                                                                    </span>
                                                                {% endif %}
                                                            {% endfor %}
                                                        </div>
                                                    </div>
                                                </li>
                                                <li><hr class="dropdown-divider m-0"></li>
                                                <li><a class="dropdown-item" href="{{ path('app_profile') }}"><i class="fas fa-user"></i> Mon Profil</a></li>
                                                <li><a class="dropdown-item" href="{{ path('app_profile_edit') }}"><i class="fas fa-edit"></i> Modifier le profil</a></li>
                                                {% if is_granted('ROLE_ADMIN') %}
                                                    <li><hr class="dropdown-divider"></li>
                                                    <li><a class="dropdown-item" href="{{ path('app_admin_dashboard') }}"><i class="fas fa-tachometer-alt"></i> Administration</a></li>
                                                    <li><a class="dropdown-item" href="{{ path('app_admin_users_index') }}"><i class="fas fa-users-cog"></i> Gestion utilisateurs</a></li>
                                                {% endif %}
                                                <li><hr class="dropdown-divider"></li>
                                                <li><a class="dropdown-item text-danger" href="{{ path('app_logout') }}"><i class="fas fa-sign-out-alt"></i> Déconnexion</a></li>
                                            </ul>
                                        </div>
                                    {% else %}
                                        <i class="fas fa-user"></i>
                                        <a href="{{ path('app_login') }}">Connexion</a>
                                        <span style="margin:0 5px;">|</span>
                                        <a href="{{ path('app_register') }}">Inscription</a>
                                    {% endif %}
                                </li>
                                <li>
                                    <button type="button" class="sidebar-btn sideMenuToggler">
                                        <span class="line"></span>
                                    </button>
                                </li>
                            </ul>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="sticky-wrapper">
            <!-- Main Menu Area -->
            <div class="menu-area">
                <div class="container">
                    <div class="row align-items-center justify-content-between">
                        <div class="col-auto">
                            <div class="header-logo">
                                <a href="{{ path('app_front_index') }}"><img src="/assets/img/logo.svg" alt="logo"></a>
                            </div>
                        </div>
                        <div class="col-auto">
                            <nav class="main-menu d-none d-lg-inline-block">
                                <ul>
                                    <li><a href="{{ path('app_front_index') }}">Accueil</a></li>
                                    <li><a href="{{ path('app_front_oeuvre') }}">Œuvres</a></li>
                                    <li><a href="{{ path('app_evenement_index') }}">Événements</a></li>
                                    <li><a href="{{ path('blog_publication_index') }}">Blog</a></li>
                                    <li><a href="{{ path('app_formation_front') }}">Formation</a></li>
                                </ul>
                            </nav>
                            <div class="navbar-right d-inline-flex d-lg-none">
                                <button type="button" class="menu-toggle icon-btn"><i class="fas fa-bars"></i></button>
                            </div>
                        </div>
                        <div class="col-auto d-none d-xl-block">
                            <div class="header-button">
                                <a href="{{ path('app_evenement_index') }}" class="btn d-none d-xl-block">
                                    ÉVÉNEMENTS &amp; TICKETS
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </header>

    <!--==============================
    Breadcumb
    ============================== -->
    <div class="breadcumb-wrapper" data-bg-src="https://images.unsplash.com/photo-1513364776144-60967b0f800f?w=1920&q=80">
        <div class="container">
            <div class="breadcumb-content">
                <h1 class="breadcumb-title">{{ publication.titre }}</h1>
                <ul class="breadcumb-menu">
                    <li><a href="{{ path('app_home') }}">Home</a></li>
                    <li><a href="{{ path('blog_publication_index') }}">Blog</a></li>
                    <li>{{ publication.titre }}</li>
                </ul>
            </div>
        </div>
    </div>

    <!--==============================
    Blog Details Area
    ==============================-->
    <section class="space-top space-extra-bottom">
        <div class="container">
            {% for message in app.flashes('success') %}
                <div class="alert alert-success alert-dismissible fade show" role="alert" style="background: #28a745; color: white; border-radius: 8px; margin-bottom: 20px;">
                    <i class="fas fa-check-circle me-2"></i>{{ message }}
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            {% endfor %}
            {% for message in app.flashes('error') %}
                <div class="alert alert-danger alert-dismissible fade show" role="alert" style="background: #dc3545; color: white; border-radius: 8px; margin-bottom: 20px;">
                    <i class="fas fa-exclamation-circle me-2"></i>{{ message }}
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            {% endfor %}
            <div class="row">
                <div class="col-xxl-8 col-lg-7">
                    <div class="blog-single">
                        <div class="blog-img">
                            <img src="/uploads/{{ publication.image }}" alt="{{ publication.titre }}" onerror="this.src='/assets/img/blog/blog_s1_1.png'">
                        </div>
                        <div class="blog-content">
                            <div class="blog-meta">
                                <a href="#"><i class="far fa-calendar"></i>{{ publication.dateAct ? publication.dateAct|date('F d, Y') : 'N/A' }}</a>
                                <a href="#"><i class="far fa-user"></i>By {% if user %}{{ user.fullName }}{% else %}Unknown User{% endif %}</a>
                            </div>
                            <h2 class="blog-title">{{ publication.titre }}</h2>
                            <div class="blog-text">
                                {{ publication.description|nl2br }}
                            </div>

                            <div class="share-links clearfix">
                                <div class="row justify-content-between align-items-center">
                                    <div class="col-md-auto d-flex align-items-center gap-2">
                                        <button type="button" class="btn btn-sm btn-light react-btn" data-type="publication" data-id="{{ publication.idPublication }}" data-like="true">
                                            <i class="fas fa-thumbs-up text-success"></i> <span class="like-count fw-bold">{{ publication.nbLikes ?? 0 }}</span>
                                        </button>
                                        <button type="button" class="btn btn-sm btn-light react-btn" data-type="publication" data-id="{{ publication.idPublication }}" data-like="false">
                                            <i class="fas fa-thumbs-down text-danger"></i> <span class="dislike-count fw-bold">{{ publication.nbDislikes ?? 0 }}</span>
                                        </button>
                                    </div>
                                    <div class="col-md-auto">
                                        <a href="{{ path('blog_publication_edit', {'id': publication.idPublication}) }}" class="btn">
                                            <i class="fas fa-edit me-2"></i>Edit Publication
                                        </a>
                                    </div>
                                    <div class="col-md-auto">
                                        <button type="button" class="btn" style="background: #dc3545; border-color: #dc3545;" onclick="showDeleteModal('publication', {{ publication.idPublication }}, '{{ publication.titre }}')">
                                            <i class="fas fa-trash me-2"></i>Delete
                                        </button>
                                        <form id="delete-publication-form-{{ publication.idPublication }}" method="post" action="{{ path('blog_publication_delete', {'id': publication.idPublication}) }}" style="display: none;">
                                            <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ publication.idPublication) }}">
                                        </form>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    {% if recommendations is defined and recommendations is not empty %}
                    <div class="row mt-5 mb-5">
                        <div class="col-12">
                            <h3 class="blog-inner-title mb-4"><i class="fas fa-layer-group me-2" style="color: #ffc832;"></i>Similar Artworks</h3>
                        </div>
                        {% for rec in recommendations %}
                        <div class="col-md-4">
                            <div class="blog-card" style="margin-bottom: 20px; box-shadow: 0 5px 15px rgba(0,0,0,0.05); transition: transform 0.3s ease;">
                                <div class="blog-img" style="height: 150px; overflow: hidden; border-radius: 8px 8px 0 0;">
                                    <a href="{{ path('blog_publication_show', {'slug': rec.slug}) }}">
                                        <img src="/uploads/{{ rec.image }}" alt="{{ rec.titre }}" style="height: 100%; width: 100%; object-fit: cover;" onerror="this.src='/assets/img/blog/blog_s1_1.png'">
                                    </a>
                                </div>
                                <div class="blog-content" style="padding: 15px; background: white; border-radius: 0 0 8px 8px; border: 1px solid #eee; border-top: none;">
                                    <h5 class="blog-title" style="font-size: 16px; margin-bottom: 5px;">
                                        <a href="{{ path('blog_publication_show', {'slug': rec.slug}) }}" style="color: #333; text-decoration: none;">{{ rec.titre }}</a>
                                    </h5>
                                    {% if rec.user %}
                                    <div style="font-size: 12px; color: #888;">
                                        <i class="far fa-user me-1"></i>{{ rec.user.fullName }}
                                    </div>
                                    {% endif %}
                                </div>
                            </div>
                        </div>
                        {% endfor %}
                    </div>
                    {% endif %}

                    <div class="blog-comment-area">
                        <div class="d-flex justify-content-between align-items-center mb-4">
                            <h3 class="blog-inner-title mb-0">Comments ({{ comments|length }})</h3>
                            <a href="{{ path('blog_commentaire_new', {'publicationId': publication.idPublication}) }}" class="btn">
                                <i class="fas fa-plus me-2"></i>Add Comment
                            </a>
                        </div>
                        {% if comments is not empty %}
                            {% for comment in comments %}
                                <div class="blog-comment-item" style="border: 1px solid #e5e5e5; padding: 20px; border-radius: 8px; margin-bottom: 20px; background: #f9f9f9;">
                                    <div class="blog-comment-author">
                                        <div class="media-body">
                                            <h4 class="name">
                                                <i class="fas fa-user-circle me-2"></i>
                                                {% if comment.user %}{{ comment.user.fullName }}{% else %}Unknown User{% endif %}
                                            </h4>
                                            <span class="commented-on">
                                                <i class="far fa-calendar me-1"></i>{{ comment.dateCreation ? comment.dateCreation|date('F d, Y H:i') : 'N/A' }}
                                            </span>
                                            <span class="ms-3 d-inline-flex align-items-center gap-2">
                                                <button type="button" class="btn btn-sm btn-light react-btn p-1" data-type="comment" data-id="{{ comment.idCommentaire }}" data-like="true">
                                                    <i class="fas fa-thumbs-up text-success"></i> <span class="like-count fw-bold">{{ comment.nbLikes ?? 0 }}</span>
                                                </button>
                                                <button type="button" class="btn btn-sm btn-light react-btn p-1" data-type="comment" data-id="{{ comment.idCommentaire }}" data-like="false">
                                                    <i class="fas fa-thumbs-down text-danger"></i> <span class="dislike-count fw-bold">{{ comment.nbDislikes ?? 0 }}</span>
                                                </button>
                                            </span>
                                            <span class="ms-3 badge" style="background: {% if comment.status == 'approved' %}#28a745{% elseif comment.status == 'pending' %}#ffc107{% else %}#dc3545{% endif %};">
                                                {{ comment.status|upper }}
                                            </span>
                                        </div>
                                    </div>
                                    <p class="text mt-3">{{ comment.content|nl2br }}</p>
                                    <div class="comment-actions mt-3">
                                        <a href="{{ path('blog_commentaire_edit', {'id': comment.idCommentaire}) }}" class="btn btn-sm" style="background: #ffc107; border-color: #ffc107; padding: 5px 15px; font-size: 14px;">
                                            <i class="fas fa-edit"></i> Edit
                                        </a>
                                        <button type="button" class="btn btn-sm" style="background: #dc3545; border-color: #dc3545; padding: 5px 15px; font-size: 14px;" onclick="showDeleteModal('comment', {{ comment.idCommentaire }}, 'this comment')">
                                            <i class="fas fa-trash"></i> Delete
                                        </button>
                                        <form id="delete-comment-form-{{ comment.idCommentaire }}" method="post" action="{{ path('blog_commentaire_delete', {'id': comment.idCommentaire}) }}" style="display: none;">
                                            <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ comment.idCommentaire) }}">
                                        </form>
                                    </div>
                                </div>
                            {% endfor %}
                        {% else %}
                            <div style="text-align: center; padding: 40px; background: #f9f9f9; border-radius: 8px;">
                                <i class="far fa-comment" style="font-size: 48px; color: #ccc; margin-bottom: 15px;"></i>
                                <p class="text-muted mb-3">No comments yet. Be the first to comment!</p>
                                <a href="{{ path('blog_commentaire_new', {'publicationId': publication.idPublication}) }}" class="btn">
                                    <i class="fas fa-plus me-2"></i>Add First Comment
                                </a>
                            </div>
                        {% endif %}
                    </div>
                </div>

                <div class="col-xxl-4 col-lg-5">
                    <aside class="sidebar-area">
                        <div class="widget">
                            <h3 class="widget_title">Publication Details</h3>
                            <div class="recent-post-wrap">
                                <div class="widget-contact">
                                    <ul class="contact-info-list">
                                        <li><strong>ID:</strong> {{ publication.idPublication }}</li>
                                        <li><strong>Date:</strong> {{ publication.dateAct ? publication.dateAct|date('F d, Y') : 'N/A' }}</li>
                                        <li><strong>Author:</strong> {% if user %}{{ user.fullName }}{% else %}Unknown User{% endif %}</li>
                                        <li><strong>Comments:</strong> {{ comments|length }}</li>
                                    </ul>
                                </div>
                            </div>
                        </div>

                        {% if publication.imageAnalysis %}
                        {% set analysis = publication.imageAnalysis|json_decode %}
                        <div class="widget" style="margin-top: 30px;">
                            <h3 class="widget_title"><i class="fas fa-palette me-2"></i>Image Analysis</h3>
                            <div style="padding: 4px 0;">

                                {% if analysis.dominant_colors is defined and analysis.dominant_colors|length > 0 %}
                                <div style="margin-bottom: 16px;">
                                    <span style="font-size: 11px; text-transform: uppercase; letter-spacing: 1px; color: #888; display: block; margin-bottom: 8px;">Dominant Colors</span>
                                    <div style="display: flex; gap: 8px; flex-wrap: wrap;">
                                        {% for color in analysis.dominant_colors %}
                                        <div title="{{ color }}" style="width: 32px; height: 32px; background: {{ color }}; border-radius: 6px; box-shadow: 0 2px 6px rgba(0,0,0,0.3); border: 2px solid rgba(255,255,255,0.2);"></div>
                                        {% endfor %}
                                    </div>
                                </div>
                                {% endif %}

                                <div style="display: flex; gap: 8px; flex-wrap: wrap; margin-bottom: 16px;">
                                    {% if analysis.brightness is defined %}
                                    <div style="background: rgba(255,200,50,0.1); border: 1px solid rgba(255,200,50,0.3); border-radius: 8px; padding: 8px 12px; text-align: center; flex: 1; min-width: 75px;">
                                        <div style="font-size: 10px; color: #888; text-transform: uppercase; letter-spacing: 1px;">Brightness</div>
                                        <div style="font-weight: 700; color: #ffc832; font-size: 14px; margin-top: 2px;">{{ analysis.brightness }}</div>
                                    </div>
                                    {% endif %}
                                    {% if analysis.saturation is defined %}
                                    <div style="background: rgba(255,200,50,0.1); border: 1px solid rgba(255,200,50,0.3); border-radius: 8px; padding: 8px 12px; text-align: center; flex: 1; min-width: 75px;">
                                        <div style="font-size: 10px; color: #888; text-transform: uppercase; letter-spacing: 1px;">Saturation</div>
                                        <div style="font-weight: 700; color: #ffc832; font-size: 14px; margin-top: 2px;">{{ analysis.saturation }}</div>
                                    </div>
                                    {% endif %}
                                </div>

                                {% if analysis.composition is defined %}
                                <div style="margin-bottom: 16px;">
                                    <span style="font-size: 11px; text-transform: uppercase; letter-spacing: 1px; color: #888; display: block; margin-bottom: 8px;">Composition</span>
                                    <div style="display: flex; flex-direction: column; gap: 6px;">
                                        <div style="display: flex; justify-content: space-between; align-items: center; font-size: 13px;">
                                            <span style="color: #888;"><i class="fas fa-balance-scale me-1"></i>Balance</span>
                                            <span style="color: #e0e0e0; font-weight: 600;">{{ analysis.composition.visual_weight }}</span>
                                        </div>
                                        <div style="display: flex; justify-content: space-between; align-items: center; font-size: 13px;">
                                            <span style="color: #888;"><i class="fas fa-crosshairs me-1"></i>Subject</span>
                                            <span style="color: #e0e0e0; font-weight: 600;">{{ analysis.composition.subject_position }}</span>
                                        </div>
                                        <div style="display: flex; justify-content: space-between; align-items: center; font-size: 13px;">
                                            <span style="color: #888;"><i class="fas fa-border-all me-1"></i>Complexity</span>
                                            <span style="color: #e0e0e0; font-weight: 600;">{{ analysis.composition.edge_complexity }}</span>
                                        </div>
                                    </div>
                                </div>
                                {% endif %}

                                {% if analysis.visual_elements is defined and analysis.visual_elements|length > 0 %}
                                <div style="margin-bottom: 16px;">
                                    <span style="font-size: 11px; text-transform: uppercase; letter-spacing: 1px; color: #888; display: block; margin-bottom: 8px;">Visual Elements</span>
                                    <div style="display: flex; gap: 6px; flex-wrap: wrap;">
                                        {% for elem in analysis.visual_elements %}
                                        <span style="background: rgba(255,255,255,0.08); border: 1px solid rgba(255,255,255,0.15); color: #ddd; padding: 3px 10px; border-radius: 20px; font-size: 12px;">{{ elem }}</span>
                                        {% endfor %}
                                    </div>
                                </div>
                                {% endif %}

                                {% if analysis.style_tags is defined and analysis.style_tags|length > 0 %}
                                <div>
                                    <span style="font-size: 11px; text-transform: uppercase; letter-spacing: 1px; color: #888; display: block; margin-bottom: 8px;">Artistic Style</span>
                                    <div style="display: flex; gap: 6px; flex-wrap: wrap;">
                                        {% for tag in analysis.style_tags %}
                                        <span style="background: #ffc832; color: #1a1a2e; padding: 4px 14px; border-radius: 20px; font-size: 13px; font-weight: 700;">{{ tag }}</span>
                                        {% endfor %}
                                    </div>
                                </div>
                                {% endif %}

                            </div>
                        </div>

                        {% if analysis.generated_description is defined and analysis.generated_description %}
                        <div class="widget" style="margin-top: 20px; background: rgba(255, 200, 50, 0.03); border: 1px solid rgba(255, 200, 50, 0.15);">
                            <h3 class="widget_title" style="font-size: 16px; margin-bottom: 12px; border-bottom: none;"><i class="fas fa-magic me-2" style="color: #ffc832;"></i>Artistic Concept</h3>
                            <p style="font-size: 14px; color: #555; font-style: italic; line-height: 1.6; margin: 0;">{{ analysis.generated_description }}</p>
                        </div>
                        {% endif %}

                        {% endif %}

