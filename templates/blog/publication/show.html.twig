    <!-- Delete Confirmation Modal -->
    <div id="deleteModal" style="display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.7); z-index: 9999; align-items: center; justify-content: center;">
        <div style="background: white; padding: 40px; border-radius: 12px; max-width: 500px; width: 90%; box-shadow: 0 10px 40px rgba(0,0,0,0.3); text-align: center;">
            <div style="color: #dc3545; font-size: 60px; margin-bottom: 20px;">
                <i class="fas fa-exclamation-triangle"></i>
            </div>
            <h3 style="margin-bottom: 15px; color: #333; font-size: 24px;">Confirm Delete</h3>
            <p id="deleteMessage" style="color: #666; margin-bottom: 30px; font-size: 16px;"></p>
            <div style="display: flex; gap: 15px; justify-content: center;">
                <button onclick="closeDeleteModal()" class="btn" style="background: #6c757d; border-color: #6c757d; padding: 12px 30px;">
                    <i class="fas fa-times me-2"></i>Cancel
                </button>
                <button id="confirmDeleteBtn" class="btn" style="background: #dc3545; border-color: #dc3545; padding: 12px 30px;">
                    <i class="fas fa-trash me-2"></i>Delete
                </button>
            </div>
        </div>
    </div>

    <script>
        let deleteFormId = null;

        function showDeleteModal(type, id, name) {
            const modal = document.getElementById('deleteModal');
            const message = document.getElementById('deleteMessage');
            const confirmBtn = document.getElementById('confirmDeleteBtn');
            
            deleteFormId = `delete-${type}-form-${id}`;
            
            if (type === 'publication') {
                message.innerHTML = `Are you sure you want to delete the publication <strong>"${name}"</strong>?<br><small style="color: #dc3545; margin-top: 10px; display: block;">This action cannot be undone and will also delete all comments.</small>`;
            } else {
                message.innerHTML = `Are you sure you want to delete ${name}?<br><small style="color: #dc3545; margin-top: 10px; display: block;">This action cannot be undone.</small>`;
            }
            
            modal.style.display = 'flex';
            
            // Set up confirm button
            confirmBtn.onclick = function() {
                document.getElementById(deleteFormId).submit();
            };
        }

        function closeDeleteModal() {
            document.getElementById('deleteModal').style.display = 'none';
            deleteFormId = null;
        }

        // Close modal on escape key
        document.addEventListener('keydown', function(e) {
            if (e.key === 'Escape') {
                closeDeleteModal();
            }
        });

        // Close modal when clicking outside
        document.getElementById('deleteModal').addEventListener('click', function(e) {
            if (e.target === this) {
                closeDeleteModal();
            }
        });

        // React AJAX handler
        document.querySelectorAll('.react-btn').forEach(button => {
            button.addEventListener('click', function() {
                const type = this.dataset.type;
                const id = this.dataset.id;
                const isLike = this.dataset.like;
                const container = type === 'publication' ? document : this.closest('.blog-comment-item');
                
                let url = type === 'publication' ? `/blog/publication/${id}/react` : `/blog/commentaire/${id}/react`;

                fetch(url, {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/x-www-form-urlencoded',
                        'X-Requested-With': 'XMLHttpRequest'
                    },
                    body: `is_like=${isLike}&id_user=1` // Using dummy user 1 for now
                })
                .then(response => response.json())
                .then(data => {
                    if (data.success) {
                        if (type === 'publication') {
                            document.querySelector('.react-btn[data-type="publication"][data-like="true"] .like-count').textContent = data.nbLikes;
                            document.querySelector('.react-btn[data-type="publication"][data-like="false"] .dislike-count').textContent = data.nbDislikes;
                        } else {
                            container.querySelector('.react-btn[data-like="true"] .like-count').textContent = data.nbLikes;
                            container.querySelector('.react-btn[data-like="false"] .dislike-count').textContent = data.nbDislikes;
                        }
                    } else {
                        alert("Error toggling reaction.");
                    }
                })
                .catch(error => console.error('Error:', error));
            });
        });
    </script>
