    <script>
        function previewImage(event) {
            const file = event.target.files[0];
            if (!file) return;
            const reader = new FileReader();
            reader.onload = function(e) {
                document.getElementById('preview').src = e.target.result;
                document.getElementById('imagePreview').style.display = 'block';

                // Run live analysis once image loads
                const img = new Image();
                img.onload = () => analyzeImageLive(img);
                img.src = e.target.result;
            };
            reader.readAsDataURL(file);
        }

        function analyzeImageLive(img) {
            const SAMPLE = 30;
            const canvas = document.getElementById('analysisCanvas');
            canvas.width  = SAMPLE;
            canvas.height = SAMPLE;
            const ctx = canvas.getContext('2d');
            ctx.drawImage(img, 0, 0, SAMPLE, SAMPLE);
            const data = ctx.getImageData(0, 0, SAMPLE, SAMPLE).data;

            // Build pixel array
            const pixels = [];
            for (let i = 0; i < data.length; i += 4) {
                const r = data[i], g = data[i+1], b = data[i+2];
                const idx = i / 4;
                const col = idx % SAMPLE;
                const row = Math.floor(idx / SAMPLE);
                const luma = 0.299*r + 0.587*g + 0.114*b;
                const [h, s, v] = rgbToHsv(r, g, b);
                pixels.push({r, g, b, h, s, v, luma, col, row});
            }

            // Dominant colors (bucket quantisation)
            const buckets = {};
            pixels.forEach(p => {
                const key = ((p.r>>5)<<4)|((p.g>>5)<<2)|(p.b>>5);
                if (!buckets[key]) buckets[key] = {count:0,r:0,g:0,b:0};
                buckets[key].count++;
                buckets[key].r += p.r;
                buckets[key].g += p.g;
                buckets[key].b += p.b;
            });
            const sorted = Object.values(buckets).sort((a,b)=>b.count-a.count).slice(0,5);
            const colors = sorted.map(b => {
                const r = Math.round(b.r/b.count).toString(16).padStart(2,'0');
                const g = Math.round(b.g/b.count).toString(16).padStart(2,'0');
                const bh = Math.round(b.b/b.count).toString(16).padStart(2,'0');
                return `#${r}${g}${bh}`;
            });

            // Global averages
            const avgLuma = pixels.reduce((s,p)=>s+p.luma,0)/pixels.length;
            const avgSat  = pixels.reduce((s,p)=>s+p.s,0)/pixels.length;
            const avgR    = pixels.reduce((s,p)=>s+p.r,0)/pixels.length;
            const avgB    = pixels.reduce((s,p)=>s+p.b,0)/pixels.length;
            const warmth  = avgR - avgB;

            const brightness  = avgLuma < 80 ? 'Dark' : avgLuma < 170 ? 'Medium' : 'Bright';
            const saturation  = avgSat  < 0.25 ? 'Muted' : avgSat < 0.55 ? 'Moderate' : 'Vivid';
            const tone        = warmth > 15 ? 'Warm' : warmth < -15 ? 'Cool' : 'Neutral';

            // Contrast
            const lumas   = pixels.map(p=>p.luma);
            const contrast = (Math.max(...lumas)-Math.min(...lumas))/255;

            // Style tags
            const tags = [];
            if (brightness==='Bright' && saturation==='Muted')  tags.push('Minimalist');
            if (saturation==='Muted')                            tags.push('Monochromatic');
            if (brightness==='Dark' && contrast>0.45)            tags.push('Dramatic');
            if (saturation==='Vivid' && warmth>20)               tags.push('Impressionist');
            if (saturation==='Vivid')                            tags.push('Vibrant');
            if (brightness==='Dark' && saturation==='Vivid')     tags.push('Surrealist');
            if (saturation==='Moderate' && contrast<0.4)         tags.push('Realist');
            if (tags.length===0)                                 tags.push('Contemporary');

            // Composition — 3×3 grid
            const bs = SAMPLE/3;
            const lumaGrid = Array.from({length:3},(_,br)=>
                Array.from({length:3},(_,bc)=>{
                    let sum=0, cnt=0;
                    for(let r=Math.floor(br*bs);r<Math.min(Math.floor((br+1)*bs),SAMPLE);r++){
                        for(let c=Math.floor(bc*bs);c<Math.min(Math.floor((bc+1)*bs),SAMPLE);c++){
                            sum += pixels[r*SAMPLE+c].luma; cnt++;
                        }
                    }
                    return cnt>0?sum/cnt:0;
                })
            );
            const leftL   = (lumaGrid[0][0]+lumaGrid[1][0]+lumaGrid[2][0])/3;
            const centL   = (lumaGrid[0][1]+lumaGrid[1][1]+lumaGrid[2][1])/3;
            const rightL  = (lumaGrid[0][2]+lumaGrid[1][2]+lumaGrid[2][2])/3;
            const maxSide = Math.max(leftL,rightL);
            const minSide = Math.min(leftL,rightL);
            const bal     = maxSide>0?(maxSide-minSide)/maxSide:0;
            let weight = bal<0.12 ? 'Balanced' : leftL>rightL ? 'Left-heavy' : 'Right-heavy';
            if(centL > leftL*1.2 && centL > rightL*1.2) weight = 'Centered';

            const surround = (lumaGrid[0][0]+lumaGrid[0][1]+lumaGrid[0][2]+lumaGrid[1][0]+lumaGrid[1][2]+lumaGrid[2][0]+lumaGrid[2][1]+lumaGrid[2][2])/8;
            const thirds   = (lumaGrid[0][1]+lumaGrid[0][2]+lumaGrid[2][0]+lumaGrid[2][1])/4;
            let position = lumaGrid[1][1] > surround*1.25 ? 'Central' : thirds > lumaGrid[1][1]*1.1 ? 'Rule of Thirds' : 'Distributed';

            // Render UI
            document.getElementById('liveAnalysis').style.display = 'block';

            const swatches = document.getElementById('colorSwatches');
            swatches.innerHTML = colors.map(c=>
                `<div title="${c}" style="width:36px;height:36px;background:${c};border-radius:6px;box-shadow:0 2px 6px rgba(0,0,0,0.4);cursor:default;border:2px solid rgba(255,255,255,0.15);"></div>`
            ).join('');

            document.getElementById('brightnessVal').textContent  = brightness;
            document.getElementById('saturationVal').textContent  = saturation;
            document.getElementById('toneVal').textContent        = tone;

            const compDiv = document.getElementById('compositionVal');
            compDiv.innerHTML = [
                `<span style="background:rgba(255,200,50,0.15);border:1px solid rgba(255,200,50,0.3);color:#ffc832;padding:4px 12px;border-radius:20px;font-size:13px;">⚖ ${weight}</span>`,
                `<span style="background:rgba(255,200,50,0.15);border:1px solid rgba(255,200,50,0.3);color:#ffc832;padding:4px 12px;border-radius:20px;font-size:13px;">🎯 ${position}</span>`
            ].join('');

            const tagsDiv = document.getElementById('styleTags');
            tagsDiv.innerHTML = tags.map(t=>
                `<span style="background:#ffc832;color:#1a1a2e;padding:4px 14px;border-radius:20px;font-size:13px;font-weight:700;">${t}</span>`
            ).join('');

            // Generate and show description
            const desc = generateDescriptionResult(brightness, saturation, warmth, contrast, tags, weight, position);
            document.getElementById('suggestedDescText').innerText = desc;
        }

        function useSuggestedDescription() {
            const desc = document.getElementById('suggestedDescText').innerText;
            const textarea = document.getElementById('description');
            if (textarea) {
                if (textarea.value.trim() !== '' && !confirm('This will overwrite your current description. Continue?')) {
                    return;
                }
                textarea.value = desc;
                // clear error if exists
                document.getElementById('error-description').style.display = 'none';
                textarea.style.borderColor = '';
            }
        }

        function generateDescriptionResult(brightness, saturation, warmth, contrast, tags, weight, position) {
            let openingList = [
                'A nuanced and carefully balanced work,',
                'Thoughtful in tone and execution,',
                'Poised between light and shadow,'
            ];
            if (brightness === 'Dark' && contrast > 0.45) openingList = ['A striking work of dramatic intensity,', 'A bold and moody composition,', 'This arresting piece commands attention,'];
            else if (brightness === 'Dark') openingList = ['Shrouded in deep, atmospheric shadows,', 'A quietly powerful work imbued with darkness,', 'Rich with depth and mystery,'];
            else if (brightness === 'Bright' && saturation === 'Muted') openingList = ['Serene and restrained in its luminosity,', 'A clean, light-filled composition,', 'Minimal yet radiant in its simplicity,'];
            else if (brightness === 'Bright') openingList = ['Radiating light and energy,', 'Vibrant and sun-drenched,', 'Filled with luminous brilliance,'];
            const opening = openingList[Math.floor(Math.random() * openingList.length)];

            const tone = warmth > 15 ? 'warm' : (warmth < -15 ? 'cool' : 'balanced');
            const satLabel = saturation.toLowerCase();
            let palette = `The palette is balanced and harmonious, weaving together ${satLabel} tones without a single dominant temperature.`;
            if (tone === 'warm') palette = `The palette leans into ${satLabel} warm tones — golds, ambers, and earthy reds that invite the eye inward.`;
            if (tone === 'cool') palette = `Cool hues dominate the palette — blues, teals, and silvers lending a calm, introspective atmosphere.`;

            const compSentences = {
                'Central': 'The subject anchors the composition at its heart, drawing the viewer into a single focal point.',
                'Rule of Thirds': 'The artist leverages the classic rule of thirds, placing key elements at the natural tension points of the frame.',
                'Distributed': 'Visual interest is distributed across the frame, encouraging the eye to explore freely.'
            };
            const weightSentences = {
                'Left-heavy': ' Visual weight pulls gently to the left, creating a sense of flow and directional momentum.',
                'Right-heavy': ' The composition anchors to the right, with a sense of deliberate tension and counterbalance.',
                'Centered': ' A strong central axis grounds the work with symmetry and stability.',
                'Balanced': ' The composition achieves a graceful equilibrium across the frame.'
            };
            const compositionSentence = (compSentences[position] || '') + (weightSentences[weight] || '');

            const primaryTag = tags.length > 0 ? tags[0] : 'Contemporary';
            const styleDescriptions = {
                'Minimalist': 'In the tradition of minimalist art, the work distils its subject to essentials, finding power in what is left unsaid.',
                'Monochromatic': 'The monochromatic treatment strips away colour distraction, turning subtle tonal gradations into the language of the piece.',
                'Dramatic': 'Executed with dramatic flair, this piece evokes the chiaroscuro mastery of the Old Masters — light and shadow locked in expressive dialogue.',
                'Impressionist': 'Inspired by the Impressionist tradition, the work captures a fleeting moment, colour and light dissolving into pure sensation.',
                'Vibrant': 'Colour is the true subject here — vivid, uncompromising, and emotionally direct.',
                'Surrealist': 'The image inhabits a liminal space between the real and the imagined, its dark palette amplifying an air of dreamlike tension.',
                'Abstract': 'Moving beyond representation, this abstract work trusts shape, colour, and rhythm to carry the full weight of meaning.',
                'Realist': 'Grounded in careful observation, this realist composition renders its subject with quiet fidelity to the visible world.',
                'Contemporary': 'A contemporary work that speaks in the visual language of its time — self-aware, considered, and open to interpretation.'
            };
            const styleSentence = styleDescriptions[primaryTag] || styleDescriptions['Contemporary'];

            return [opening, palette, compositionSentence, styleSentence].join(' ');
        }

        function rgbToHsv(r,g,b){
            r/=255;g/=255;b/=255;
            const max=Math.max(r,g,b),min=Math.min(r,g,b),d=max-min;
            let h=0,s=max>0?d/max:0,v=max;
            if(d!==0){
                if(max===r)      h=60*(((g-b)/d)%6);
                else if(max===g) h=60*((b-r)/d+2);
                else             h=60*((r-g)/d+4);
            }
            return [h<0?h+360:h,s,v];
        }

        // Custom form validation
        document.getElementById('publicationForm').addEventListener('submit', function(e) {
            let isValid = true;
            
            // Clear all previous errors
            document.querySelectorAll('.error-message').forEach(el => {
                el.style.display = 'none';
                el.textContent = '';
            });
            document.querySelectorAll('.style-border').forEach(el => {
                el.style.borderColor = '';
            });

            // Validate Author
            const idUser = document.getElementById('id_user');
            if (!idUser.value || idUser.value === '') {
                showError('id_user', 'Please select an author');
                isValid = false;
            }

            // Validate Title
            const titre = document.getElementById('titre');
            const titreValue = titre.value.trim();
            if (titreValue === '') {
                showError('titre', 'Title is required');
                isValid = false;
            } else if (titreValue.length < 3) {
                showError('titre', 'Title must be at least 3 characters long');
                isValid = false;
            } else if (titreValue.length > 255) {
                showError('titre', 'Title cannot exceed 255 characters');
                isValid = false;
            }

            // Validate Description
            const description = document.getElementById('description');
            const descValue = description.value.trim();
            if (descValue === '') {
                showError('description', 'Description is required');
                isValid = false;
            } else if (descValue.length < 10) {
                showError('description', 'Description must be at least 10 characters long');
                isValid = false;
            } else if (descValue.length > 5000) {
                showError('description', 'Description cannot exceed 5000 characters');
                isValid = false;
            }

            // Validate Image (optional but check size if provided)
            const imageInput = document.getElementById('image');
            if (imageInput.files.length > 0) {
                const file = imageInput.files[0];
                const maxSize = 5 * 1024 * 1024; // 5MB
                if (file.size > maxSize) {
                    alert('Image file is too large. Maximum size is 5MB.');
                    isValid = false;
                }
                
                const validTypes = ['image/jpeg', 'image/png', 'image/gif', 'image/webp'];
                if (!validTypes.includes(file.type)) {
                    alert('Invalid file type. Only JPG, PNG, GIF, and WEBP images are allowed.');
                    isValid = false;
                }
            }

            if (!isValid) {
                e.preventDefault();
            }
        });

        function showError(fieldId, message) {
            const errorDiv = document.getElementById('error-' + fieldId);
            const field = document.getElementById(fieldId);
            
            errorDiv.textContent = '⚠ ' + message;
            errorDiv.style.display = 'block';
            field.style.borderColor = '#dc3545';
            
            // Scroll to first error
            if (!window.scrolledToError) {
                field.scrollIntoView({ behavior: 'smooth', block: 'center' });
                window.scrolledToError = true;
                setTimeout(() => { window.scrolledToError = false; }, 1000);
            }
        }
    </script>

</body>

