<!DOCTYPE html>
<html lang="fr" data-bs-theme="dark">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}Admin Panel{% endblock %} | Gestion Formation</title>

    {# ── CSS Frameworks ── #}
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">

    {# ── Custom Styles ── #}
    <link href="{{ asset('assets/css/admin.css') }}" rel="stylesheet">

    {% block stylesheets %}{% endblock %}
</head>

<body>
    {# ── TOP NAVBAR ── #}
    <nav class="navbar navbar-expand-lg fixed-top admin-navbar" id="topNavbar">
        <div class="container-fluid px-4">
            <button class="btn btn-link admin-sidebar-toggle me-3 d-lg-none" id="sidebarToggle">
                <i class="fas fa-bars"></i>
            </button>

            <a class="navbar-brand admin-brand d-flex align-items-center" href="{{ path('app_admin_dashboard') }}">
                <span class="brand-icon me-2"><i class="fas fa-graduation-cap"></i></span>
                <span class="brand-text">
                    <span class="brand-primary">Edu</span><span class="brand-accent">Admin</span>
                </span>
            </a>

            <button class="btn btn-link admin-sidebar-toggle me-3 d-none d-lg-inline-flex" id="sidebarCollapseBtn">
                <i class="fas fa-bars"></i>
            </button>

            <div class="d-flex align-items-center ms-auto admin-nav-actions">
                <a class="nav-link btn btn-outline-accent btn-sm px-3 d-none d-sm-inline-flex me-3" href="{{ path('app_formation_index') }}">
                    <i class="fas fa-external-link-alt me-1"></i> Voir le Site
                </a>

                <div class="dropdown">
                    <button class="btn admin-profile-btn dropdown-toggle" data-bs-toggle="dropdown">
                        <div class="admin-avatar">
                            <img src="https://ui-avatars.com/api/?name=Admin&background=c9a84c&color=0a0a12&bold=true&size=40" alt="Avatar">
                        </div>
                        <div class="admin-info d-none d-md-block">
                            <span class="admin-name">Administrateur</span>
                            <span class="admin-role">Super Admin</span>
                        </div>
                    </button>
                    <ul class="dropdown-menu dropdown-menu-end admin-dropdown">
                        <li><a class="dropdown-item" href="#"><i class="fas fa-user me-2 text-accent"></i> Profil</a></li>
                        <li><hr class="dropdown-divider"></li>
                        <li><a class="dropdown-item text-danger" href="#"><i class="fas fa-sign-out-alt me-2"></i> Déconnexion</a></li>
                    </ul>
                </div>
            </div>
        </div>
    </nav>

    {# ── SIDEBAR ── #}
    <aside class="admin-sidebar" id="adminSidebar">
        <div class="sidebar-content">
            <div class="sidebar-section">
                <span class="sidebar-section-title">Menu Principal</span>
                <ul class="sidebar-nav">
                    <li class="sidebar-item {% if app.request.get('_route') == 'app_admin_dashboard' %}active{% endif %}">
                        <a href="{{ path('app_admin_dashboard') }}" class="sidebar-link">
                            <i class="fas fa-th-large"></i>
                            <span class="sidebar-text">Dashboard</span>
                        </a>
                    </li>

                    <li class="sidebar-header text-uppercase small px-3 mt-3 mb-1 text-muted">Formation & Quiz</li>

                    <li class="sidebar-item {% if 'formation' in app.request.get('_route') %}active{% endif %}">
                        <a href="{{ path('app_formation_index') }}" class="sidebar-link">
                            <i class="fas fa-book"></i>
                            <span class="sidebar-text">Formations</span>
                        </a>
                    </li>

                    <li class="sidebar-item {% if 'quiz' in app.request.get('_route') %}active{% endif %}">
                        <a href="{{ path('app_admin_quiz_index') }}" class="sidebar-link">
                            <i class="fas fa-question-circle"></i>
                            <span class="sidebar-text">Gestion Quiz</span>
                        </a>
                    </li>

                    <li class="sidebar-item {% if 'question' in app.request.get('_route') %}active{% endif %}">
                        <a href="{{ path('app_question_index') }}" class="sidebar-link">
                            <i class="fas fa-list-ol"></i>
                            <span class="sidebar-text">Questions</span>
                        </a>
                    </li>

                    <li class="sidebar-item {% if 'evaluation' in app.request.get('_route') %}active{% endif %}">
                        <a href="{{ path('app_evaluation_index') }}" class="sidebar-link">
                            <i class="fas fa-star"></i>
                            <span class="sidebar-text">Évaluations</span>
                        </a>
                    </li>
                </ul>
            </div>
        </div>
    </aside>

    <div class="sidebar-overlay" id="sidebarOverlay"></div>

    {# ── MAIN CONTENT ── #}
    <main class="admin-main" id="adminMain">
        <div class="admin-content">
            <div class="page-header">
                <div class="d-flex flex-column flex-md-row justify-content-between align-items-start align-items-md-center">
                    <div>
                        <h1 class="page-title">{% block page_title %}Tableau de Bord{% endblock %}</h1>
                        <nav aria-label="breadcrumb">
                            <ol class="breadcrumb admin-breadcrumb">
                                <li class="breadcrumb-item"><a href="{{ path('app_admin_dashboard') }}"><i class="fas fa-home"></i></a></li>
                                {% block breadcrumb %}
                                    <li class="breadcrumb-item active">Dashboard</li>
                                {% endblock %}
                            </ol>
                        </nav>
                    </div>
                    <div class="page-actions mt-3 mt-md-0">
                        {% block page_actions %}{% endblock %}
                    </div>
                </div>
            </div>

            {# Flash Messages #}
            {% for label, messages in app.flashes %}
                {% for message in messages %}
                    <div class="alert alert-{{ label == 'danger' ? 'danger' : (label == 'success' ? 'success' : 'info') }} alert-dismissible fade show shadow-sm" role="alert">
                        {{ message }}
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                    </div>
                {% endfor %}
            {% endfor %}

            {% block body %}{% endblock %}
        </div>

        <footer class="admin-footer text-center text-md-start">
            <p class="mb-0">&copy; {{ "now"|date("Y") }} <strong class="text-accent">EduFormation</strong>. Tous droits réservés.</p>
        </footer>
    </main>

    {# ── Scripts ── #}
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script src="{{ asset('assets/js/admin.js') }}"></script>
    {% block javascripts %}{% endblock %}
</body>
</html>