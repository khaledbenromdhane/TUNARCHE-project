{% extends 'base.html.twig' %}

{% block title %}Mot de passe oublié - ArtVista{% endblock %}

{% block body %}
<div class="breadcumb-wrapper" data-bg-src="{{ asset('assets/img/bg/breadcumb-bg.jpg') }}">
    <div class="container">
        <div class="breadcumb-content">
            <h1 class="breadcumb-title">Mot de passe oublié</h1>
            <ul class="breadcumb-menu">
                <li><a href="{{ path('app_home') }}">Accueil</a></li>
                <li>Récupération</li>
            </ul>
        </div>
    </div>
</div>

<div class="space overflow-hidden">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-5 col-md-8">
                <div class="contact-form-area">
                    <div class="text-center mb-4">
                        <div style="width:70px;height:70px;border-radius:50%;background:linear-gradient(135deg,#d4a574,#c4924e);display:flex;align-items:center;justify-content:center;margin:0 auto 16px;">
                            <i class="fas fa-key fa-2x text-white"></i>
                        </div>
                        <h2 class="sec-title">Réinitialiser le mot de passe</h2>
                        <p class="sec-text">Entrez votre email pour recevoir un lien de réinitialisation</p>
                    </div>

                    {% for message in app.flashes('success') %}
                        <div class="alert alert-success alert-dismissible fade show">
                            <i class="fas fa-check-circle me-2"></i>{{ message }}
                            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                        </div>
                    {% endfor %}
                    {% for message in app.flashes('info') %}
                        <div class="alert alert-info alert-dismissible fade show">
                            <i class="fas fa-info-circle me-2"></i>
                            <strong>Dev :</strong> {{ message }}
                            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                        </div>
                    {% endfor %}

                    <form method="post" class="contact-form">
                        <div class="row gx-20">
                            <div class="col-12">
                                <div class="form-group">
                                    <label for="email"><i class="fas fa-envelope me-2" style="color:#d4a574;"></i>Email</label>
                                    <input type="email" class="form-control" id="email" name="email" required autofocus placeholder="votre@email.com">
                                </div>
                            </div>
                            <div class="col-12">
                                <button type="submit" class="btn w-100">
                                    <i class="fas fa-paper-plane me-2"></i>ENVOYER LE LIEN
                                </button>
                            </div>
                            <div class="col-12 text-center mt-3">
                                <a href="{{ path('app_login') }}" style="color:#d4a574;text-decoration:underline;">
                                    <i class="fas fa-arrow-left me-1"></i>Retour à la connexion
                                </a>
                            </div>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
