{% extends 'base.html.twig' %}

{% block title %}Détails Utilisateur{% endblock %}

{% block body %}
<!--==============================
    Breadcrumb Area
==============================-->
<div class="breadcumb-wrapper" data-bg-src="{{ asset('assets/img/bg/breadcumb-bg.jpg') }}">
    <div class="container">
        <div class="breadcumb-content">
            <h1 class="breadcumb-title">Détails Utilisateur</h1>
            <ul class="breadcumb-menu">
                <li><a href="{{ path('app_home') }}">Accueil</a></li>
                <li><a href="{{ path('app_user_index') }}">Utilisateurs</a></li>
                <li>Détails</li>
            </ul>
        </div>
    </div>
</div>

<!--==============================
    User Details Area
==============================-->
<div class="space overflow-hidden">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-8">
                <div class="contact-form-area">
                    <div class="d-flex justify-content-between align-items-center mb-4">
                        <h2 class="sec-title mb-0">{{ user.prenom }} {{ user.nom }}</h2>
                        <div>
                            <a href="{{ path('app_user_edit', {'id': user.id}) }}" class="btn btn-sm">
                                <i class="far fa-edit me-2"></i>MODIFIER
                            </a>
                        </div>
                    </div>

                    <table class="table table-bordered">
                        <tbody>
                            <tr>
                                <th width="30%">ID</th>
                                <td>{{ user.id }}</td>
                            </tr>
                            <tr>
                                <th>Nom</th>
                                <td>{{ user.nom }}</td>
                            </tr>
                            <tr>
                                <th>Prénom</th>
                                <td>{{ user.prenom }}</td>
                            </tr>
                            <tr>
                                <th>Email</th>
                                <td>
                                    <a href="mailto:{{ user.email }}">{{ user.email }}</a>
                                </td>
                            </tr>
                            <tr>
                                <th>Téléphone</th>
                                <td>
                                    <a href="tel:{{ user.telephone }}">{{ user.telephone }}</a>
                                </td>
                            </tr>
                            <tr>
                                <th>Rôle(s)</th>
                                <td>
                                    {% for role in user.role %}
                                        <span class="badge bg-primary">{{ role }}</span>
                                    {% endfor %}
                                </td>
                            </tr>
                        </tbody>
                    </table>

                    <div class="mt-4">
                        <a href="{{ path('app_user_index') }}" class="btn style2">
                            <i class="fas fa-arrow-left me-2"></i>RETOUR À LA LISTE
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}