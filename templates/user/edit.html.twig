{% extends 'base.html.twig' %}

{% block title %}Modifier Utilisateur{% endblock %}

{% block body %}
<!--==============================
    Breadcrumb Area
==============================-->
<div class="breadcumb-wrapper" data-bg-src="{{ asset('assets/img/bg/breadcumb-bg.jpg') }}">
    <div class="container">
        <div class="breadcumb-content">
            <h1 class="breadcumb-title">Modifier Utilisateur</h1>
            <ul class="breadcumb-menu">
                <li><a href="{{ path('app_home') }}">Accueil</a></li>
                <li><a href="{{ path('app_user_index') }}">Utilisateurs</a></li>
                <li>Modifier</li>
            </ul>
        </div>
    </div>
</div>

<!--==============================
    Form Area
==============================-->
<div class="space overflow-hidden">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-8">
                <div class="contact-form-area">
                    <h2 class="sec-title mb-4">Modifier {{ user.prenom }} {{ user.nom }}</h2>
                    
                    {{ form_start(form, {'attr': {'class': 'contact-form', 'novalidate': 'novalidate'}}) }}
                        <div class="row gx-20">
                            <div class="col-md-6">
                                <div class="form-group">
                                    {{ form_label(form.nom) }}
                                    {{ form_widget(form.nom, {'attr': {'class': 'form-control'}}) }}
                                    {{ form_errors(form.nom) }}
                                </div>
                            </div>
                            
                            <div class="col-md-6">
                                <div class="form-group">
                                    {{ form_label(form.prenom) }}
                                    {{ form_widget(form.prenom, {'attr': {'class': 'form-control'}}) }}
                                    {{ form_errors(form.prenom) }}
                                </div>
                            </div>

                            <div class="col-md-6">
                                <div class="form-group">
                                    {{ form_label(form.email) }}
                                    {{ form_widget(form.email, {'attr': {'class': 'form-control'}}) }}
                                    {{ form_errors(form.email) }}
                                </div>
                            </div>

                            <div class="col-md-6">
                                <div class="form-group">
                                    {{ form_label(form.telephone) }}
                                    {{ form_widget(form.telephone, {'attr': {'class': 'form-control'}}) }}
                                    {{ form_errors(form.telephone) }}
                                </div>
                            </div>

                            <div class="col-12">
                                <div class="form-group">
                                    {{ form_label(form.password, 'Nouveau mot de passe (laisser vide pour ne pas modifier)') }}
                                    {{ form_widget(form.password, {'attr': {'class': 'form-control', 'required': false}}) }}
                                    {{ form_errors(form.password) }}
                                </div>
                            </div>

                            <div class="col-12">
                                <div class="form-group">
                                    {{ form_label(form.role) }}
                                    {{ form_widget(form.role) }}
                                    {{ form_errors(form.role) }}
                                </div>
                            </div>

                            <div class="col-12">
                                <div class="form-btn mt-3">
                                    <button type="submit" class="btn">
                                        <i class="fas fa-save me-2"></i>ENREGISTRER
                                    </button>
                                    <a href="{{ path('app_user_index') }}" class="btn style2 ms-2">
                                        <i class="fas fa-times me-2"></i>ANNULER
                                    </a>
                                </div>
                            </div>
                        </div>
                    {{ form_end(form) }}

                    <!-- Delete Form -->
                    <div class="mt-4 pt-4 border-top">
                        <form method="post" action="{{ path('app_user_delete', {'id': user.id}) }}" onsubmit="return confirm('Êtes-vous sûr de vouloir supprimer cet utilisateur ?');">
                            <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ user.id) }}">
                            <button type="submit" class="btn btn-danger">
                                <i class="far fa-trash-alt me-2"></i>SUPPRIMER CET UTILISATEUR
                            </button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}