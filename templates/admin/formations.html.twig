{% extends 'admin/base.html.twig' %}

{% block title %}Formations Management{% endblock %}

{% block page_title %}Formations{% endblock %}

{% block breadcrumb %}
    <li class="breadcrumb-item"><a href="{{ path('app_admin_dashboard') }}">Dashboard</a></li>
    <li class="breadcrumb-item active" aria-current="page">Formations</li>
{% endblock %}

{% block page_actions %}
    <div class="d-flex gap-2 flex-wrap">
        <button class="btn btn-admin-outline btn-sm" id="exportFormationsBtn">
            <i class="fas fa-file-export me-1"></i> Export
        </button>
        <button class="btn btn-admin-primary" data-bs-toggle="modal" data-bs-target="#formationModal" id="addFormationBtn">
            <i class="fas fa-graduation-cap me-1"></i> Add Formation
        </button>
    </div>
{% endblock %}

{% block stylesheets %}
    <link href="{{ asset('assets/css/admin-formations.css') }}" rel="stylesheet">
{% endblock %}

{% block body %}

    {# ═══════════════════════════════════════════════════════════
       FORMATION STAT SUMMARY CARDS
    ═══════════════════════════════════════════════════════════ #}
    <div class="row g-3 mb-4">
        <div class="col-xl-3 col-lg-6 col-md-6 col-sm-6">
            <div class="form-stat-card animate-in">
                <div class="form-stat-icon gold">
                    <i class="fas fa-graduation-cap"></i>
                </div>
                <div class="form-stat-info">
                    <span class="form-stat-value" data-counter="42">0</span>
                    <span class="form-stat-label">Total Formations</span>
                </div>
                <div class="form-stat-trend up"><i class="fas fa-arrow-up"></i> 18%</div>
            </div>
        </div>
        <div class="col-xl-3 col-lg-6 col-md-6 col-sm-6">
            <div class="form-stat-card animate-in">
                <div class="form-stat-icon teal">
                    <i class="fas fa-chalkboard-user"></i>
                </div>
                <div class="form-stat-info">
                    <span class="form-stat-value" data-counter="28">0</span>
                    <span class="form-stat-label">Active Formations</span>
                </div>
                <div class="form-stat-trend up"><i class="fas fa-arrow-up"></i> 25%</div>
            </div>
        </div>
        <div class="col-xl-3 col-lg-6 col-md-6 col-sm-6">
            <div class="form-stat-card animate-in">
                <div class="form-stat-icon purple">
                    <i class="fas fa-check-circle"></i>
                </div>
                <div class="form-stat-info">
                    <span class="form-stat-value" data-counter="14">0</span>
                    <span class="form-stat-label">Completed</span>
                </div>
                <div class="form-stat-trend down"><i class="fas fa-arrow-down"></i> 5%</div>
            </div>
        </div>
        <div class="col-xl-3 col-lg-6 col-md-6 col-sm-6">
            <div class="form-stat-card animate-in">
                <div class="form-stat-icon pink">
                    <i class="fas fa-users"></i>
                </div>
                <div class="form-stat-info">
                    <span class="form-stat-value" data-counter="389">0</span>
                    <span class="form-stat-label">Participants</span>
                </div>
                <div class="form-stat-trend up"><i class="fas fa-arrow-up"></i> 32%</div>
            </div>
        </div>
    </div>

    {# ═══════════════════════════════════════════════════════════
       FORMATION TABLE CARD
    ═══════════════════════════════════════════════════════════ #}
    <div class="admin-table-card animate-in">
        {# ── Table Header ── #}
        <div class="admin-table-header">
            <div class="d-flex align-items-center gap-2">
                <h5 class="mb-0">All Formations</h5>
                <span class="form-count-badge" id="formationCount">42</span>
            </div>
            <div class="admin-table-controls">
                <div class="form-search-wrap">
                    <i class="fas fa-search"></i>
                    <input type="text" id="formationSearchInput" class="form-control" placeholder="Search formations...">
                </div>
                <select id="formationTypeFilter" class="form-select">
                    <option value="">All Types</option>
                    <option value="beginner">Beginner</option>
                    <option value="intermediate">Intermediate</option>
                    <option value="advanced">Advanced</option>
                    <option value="workshop">Workshop</option>
                    <option value="masterclass">Masterclass</option>
                </select>
            </div>
        </div>

