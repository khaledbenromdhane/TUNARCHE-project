                        <th class="sortable" data-sort="id">ID <i class="fas fa-sort ms-1"></i></th>
                        <th class="sortable" data-sort="nom">Formation Name <i class="fas fa-sort ms-1"></i></th>
                        <th class="sortable" data-sort="date">Date <i class="fas fa-sort ms-1"></i></th>
                        <th class="sortable" data-sort="type">Type <i class="fas fa-sort ms-1"></i></th>
                        <th class="sortable" data-sort="description">Description <i class="fas fa-sort ms-1"></i></th>
                        <th style="width: 150px;">Actions</th>
                    </tr>
                </thead>
                <tbody id="formationTableBody">
                    {# Sample Row 1 #}
                    <tr data-formation-id="1" data-type="beginner">
                        <td><input type="checkbox" class="form-check-input formation-check"></td>
                        <td class="form-id">1</td>
                        <td>
                            <div class="form-nom-cell">
                                <div class="form-icon-avatar beginner">
                                    <i class="fas fa-graduation-cap"></i>
                                </div>
                                <span class="form-nom">Introduction to Art History</span>
                            </div>
                        </td>
                        <td><span class="form-date"><i class="fas fa-calendar me-1"></i>2026-03-15</span></td>
                        <td><span class="type-badge type-beginner">Beginner</span></td>
                        <td><span class="form-description">Comprehensive introduction to art history from ancient to modern times.</span></td>
                        <td>
                            <div class="table-actions">
                                <button class="table-action-btn view-formation-btn" title="View" data-bs-toggle="tooltip" data-formation-id="1"><i class="fas fa-eye"></i></button>
                                <button class="table-action-btn edit-formation-btn" title="Edit" data-bs-toggle="tooltip" data-formation-id="1"><i class="fas fa-pen-to-square"></i></button>
                                <button class="table-action-btn delete delete-formation-btn" title="Delete" data-bs-toggle="tooltip" data-formation-id="1" data-formation-nom="Introduction to Art History"><i class="fas fa-trash-can"></i></button>
                            </div>
                        </td>
                    </tr>

                    {# Sample Row 2 #}
                    <tr data-formation-id="2" data-type="intermediate">
                        <td><input type="checkbox" class="form-check-input formation-check"></td>
                        <td class="form-id">2</td>
                        <td>
                            <div class="form-nom-cell">
                                <div class="form-icon-avatar intermediate">
                                    <i class="fas fa-palette"></i>
                                </div>
                                <span class="form-nom">Oil Painting Techniques</span>
                            </div>
                        </td>
                        <td><span class="form-date"><i class="fas fa-calendar me-1"></i>2026-04-10</span></td>
                        <td><span class="type-badge type-intermediate">Intermediate</span></td>
                        <td><span class="form-description">Master oil painting techniques from Renaissance to contemporary styles.</span></td>
                        <td>
                            <div class="table-actions">
                                <button class="table-action-btn view-formation-btn" title="View" data-bs-toggle="tooltip" data-formation-id="2"><i class="fas fa-eye"></i></button>
                                <button class="table-action-btn edit-formation-btn" title="Edit" data-bs-toggle="tooltip" data-formation-id="2"><i class="fas fa-pen-to-square"></i></button>
                                <button class="table-action-btn delete delete-formation-btn" title="Delete" data-bs-toggle="tooltip" data-formation-id="2" data-formation-nom="Oil Painting Techniques"><i class="fas fa-trash-can"></i></button>
                            </div>
                        </td>
                    </tr>

                    {# Sample Row 3 #}
