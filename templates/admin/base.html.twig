<!DOCTYPE html>
<html lang="en" data-bs-theme="dark">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}Admin Panel{% endblock %} | BackOffice</title>

    {# ── Bootstrap 5.3 CSS ── #}
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">

    {# ── Font Awesome 6 Icons ── #}
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" rel="stylesheet">

    {# ── Google Fonts – Poppins (all weights) ── #}
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">

    {# ── Admin Panel Custom Styles ── #}
    <link href="{{ asset('assets/css/admin.css') }}" rel="stylesheet">

    {% block stylesheets %}{% endblock %}
</head>

<body>
    {# ═══════════════════════════════════════════════════════════════
       TOP NAVBAR
       – Logo / brand on the left
       – Search bar center (optional)
       – Notifications + Admin profile dropdown on the right
    ═══════════════════════════════════════════════════════════════ #}
    <nav class="navbar navbar-expand-lg fixed-top admin-navbar" id="topNavbar">
        <div class="container-fluid px-4">

            {# ── Sidebar Toggle Button ── #}
            <button class="btn btn-link admin-sidebar-toggle me-3 d-lg-none" id="sidebarToggle" aria-label="Toggle sidebar">
                <i class="fas fa-bars"></i>
            </button>

            {# ── Brand / Logo ── #}
            <a class="navbar-brand admin-brand d-flex align-items-center" href="{{ path('app_admin_dashboard') }}">
                <span class="brand-icon me-2">
                    <i class="fas fa-gem"></i>
                </span>
                <span class="brand-text">
                    <span class="brand-primary">Artis</span><span class="brand-accent">Event</span>
                </span>
            </a>

            {# ── Desktop Sidebar Toggle ── #}
            <button class="btn btn-link admin-sidebar-toggle me-3 d-none d-lg-inline-flex" id="sidebarCollapseBtn" aria-label="Collapse sidebar">
                <i class="fas fa-bars"></i>
            </button>

            {# ── Right Side: Notifications & Profile ── #}
            <div class="d-flex align-items-center ms-auto admin-nav-actions">

                {# ── Search (desktop only) ── #}
                <div class="admin-search d-none d-lg-flex me-2 me-lg-3">
                    <div class="input-group">
                        <span class="input-group-text"><i class="fas fa-search"></i></span>
                        <input type="text" class="form-control" placeholder="Search…" aria-label="Search">
                    </div>
                </div>

                {# ── Mobile Search Toggle ── #}
                <button class="btn btn-link admin-nav-icon me-2 d-lg-none" id="mobileSearchToggle" aria-label="Search">
                    <i class="fas fa-search"></i>
                </button>

                {# ── Notifications Dropdown ── #}
                <div class="dropdown me-2 me-md-3">
                    <button class="btn btn-link admin-nav-icon position-relative" data-bs-toggle="dropdown" aria-expanded="false" aria-label="Notifications">
                        <i class="fas fa-bell"></i>
                        <span class="badge-dot"></span>
                    </button>
                    <ul class="dropdown-menu dropdown-menu-end admin-dropdown notifications-dropdown">
                        <li class="dropdown-header">
                            <strong>Notifications</strong>
                            <a href="#" class="float-end small text-accent">Tout lire</a>
                        </li>
                        <li><hr class="dropdown-divider"></li>
                        <li>
                            <a class="dropdown-item notification-item unread" href="#">
                                <div class="notification-icon bg-gold"><i class="fas fa-calendar-check"></i></div>
                                <div class="notification-content">
                                    <p>Nouvel événement créé</p>
                                    <small>Il y a 2 minutes</small>
                                </div>
                            </a>
                        </li>
                        <li>
                            <a class="dropdown-item notification-item unread" href="{{ path('app_admin_users_index') }}">
                                <div class="notification-icon bg-purple"><i class="fas fa-user-plus"></i></div>
                                <div class="notification-content">
                                    <p>Gestion des utilisateurs</p>
                                    <small>Administration</small>
                                </div>
                            </a>
                        </li>
                        <li>
                            <a class="dropdown-item notification-item" href="#">
                                <div class="notification-icon bg-teal"><i class="fas fa-blog"></i></div>
                                <div class="notification-content">
                                    <p>Publication en attente</p>
                                    <small>Il y a 3 heures</small>
                                </div>
                            </a>
                        </li>
                        <li><hr class="dropdown-divider"></li>
                        <li><a class="dropdown-item text-center small text-accent" href="#">Voir toutes les notifications</a></li>
                    </ul>
                </div>

                {# ── Messages Icon ── #}
                <button class="btn btn-link admin-nav-icon me-2 me-md-3 position-relative d-none d-sm-inline-flex" aria-label="Messages">
                    <i class="fas fa-envelope"></i>
                    <span class="badge-count">3</span>
                </button>

                {# ══════════════════════════════════════════════════
                   PROFIL ADMIN – DONNÉES RÉELLES DE L'UTILISATEUR
                ══════════════════════════════════════════════════ #}
                {% if app.user %}
                <div class="dropdown">
                    <button class="btn admin-profile-btn dropdown-toggle" data-bs-toggle="dropdown" aria-expanded="false">
                        <div class="admin-avatar">
                            {% if app.user.avatarFilename is defined and app.user.avatarFilename %}
                                <img src="{{ asset('uploads/avatars/' ~ app.user.avatarFilename) }}"
                                     alt="Avatar"
                                     style="width:40px;height:40px;object-fit:cover;border-radius:50%;">
                            {% else %}
                                <img src="https://ui-avatars.com/api/?name={{ app.user.prenom|default('A') }}+{{ app.user.nom|default('U') }}&background=c9a84c&color=0a0a12&bold=true&size=40"
                                     alt="Avatar">
                            {% endif %}
                        </div>
                        <div class="admin-info d-none d-md-block">
                            <span class="admin-name">{{ app.user.prenom }} {{ app.user.nom }}</span>
                            <span class="admin-role">
                                {% if 'ROLE_ADMIN' in app.user.roles %}Administrateur
                                {% elseif 'ROLE_ARTIST' in app.user.roles %}Artiste
                                {% else %}Utilisateur{% endif %}
                            </span>
                        </div>
                    </button>

                    <ul class="dropdown-menu dropdown-menu-end admin-dropdown profile-dropdown">
                        <li class="dropdown-header">
                            <div class="d-flex align-items-center">
                                {% if app.user.avatarFilename is defined and app.user.avatarFilename %}
                                    <img src="{{ asset('uploads/avatars/' ~ app.user.avatarFilename) }}"
                                         class="rounded-circle me-3"
                                         width="48" height="48"
                                         style="object-fit:cover;border:2px solid #c9a84c;"
                                         alt="Avatar">
                                {% else %}
                                    <img src="https://ui-avatars.com/api/?name={{ app.user.prenom|default('A') }}+{{ app.user.nom|default('U') }}&background=c9a84c&color=0a0a12&bold=true&size=60"
                                         class="rounded-circle me-3"
                                         width="48" height="48"
                                         alt="Avatar">
                                {% endif %}
                                <div>
                                    <strong>{{ app.user.prenom }} {{ app.user.nom }}</strong>
                                    <p class="mb-1 small text-muted">{{ app.user.email }}</p>
                                    {% for role in app.user.roles %}
                                        {% if role == 'ROLE_ADMIN' %}
                                            <span class="badge bg-danger" style="font-size:0.65rem;">
                                                <i class="fas fa-shield-alt me-1"></i>Admin
                                            </span>
                                        {% elseif role == 'ROLE_ARTIST' %}
                                            <span class="badge bg-warning text-dark" style="font-size:0.65rem;">
                                                <i class="fas fa-palette me-1"></i>Artiste
                                            </span>
                                        {% endif %}
                                    {% endfor %}
                                </div>
                            </div>
                        </li>
                        <li><hr class="dropdown-divider"></li>
                        <li>
                            <a class="dropdown-item" href="{{ path('app_profile') }}">
                                <i class="fas fa-user me-2 text-accent"></i>Mon Profil
                            </a>
                        </li>
                        <li>
                            <a class="dropdown-item" href="{{ path('app_profile_edit') }}">
                                <i class="fas fa-edit me-2 text-accent"></i>Modifier le Profil
                            </a>
                        </li>
                        <li>
                            <a class="dropdown-item" href="{{ path('app_admin_users_index') }}">
                                <i class="fas fa-users-cog me-2 text-accent"></i>Gestion Utilisateurs
                            </a>
                        </li>
                        <li><hr class="dropdown-divider"></li>
                        <li>
                            <a class="dropdown-item text-danger" href="{{ path('app_logout') }}">
                                <i class="fas fa-sign-out-alt me-2"></i>Déconnexion
                            </a>
                        </li>
                    </ul>
                </div>
                {% endif %}
            </div>
        </div>
    </nav>

    {# ── Mobile Search Bar (toggleable) ── #}
    <div class="mobile-search-bar" id="mobileSearchBar">
        <div class="container-fluid px-4">
            <div class="input-group">
                <span class="input-group-text"><i class="fas fa-search"></i></span>
                <input type="text" class="form-control" placeholder="Search anything…" aria-label="Mobile Search">
                <button class="btn btn-link" id="closeMobileSearch" aria-label="Close search">
                    <i class="fas fa-times"></i>
                </button>
            </div>
        </div>
    </div>

    {# ═══════════════════════════════════════════════════════════════
       SIDEBAR NAVIGATION
       – Collapsible left sidebar with menu items
       – Font Awesome icons for each item
       – Active state highlighting
    ═══════════════════════════════════════════════════════════════ #}
    <aside class="admin-sidebar" id="adminSidebar">
        <div class="sidebar-content">

            {# ── Main Navigation ── #}
            <div class="sidebar-section">
                <span class="sidebar-section-title">Main Menu</span>
                <ul class="sidebar-nav">
                    <li class="sidebar-item {% if app.request.get('_route') == 'app_admin_dashboard' %}active{% endif %}">
                        <a href="{{ path('app_admin_dashboard') }}" class="sidebar-link">
                            <i class="fas fa-th-large"></i>
                            <span class="sidebar-text">Dashboard</span>
                        </a>
                    </li>
                    <li class="sidebar-item {% if 'app_admin_users' in (app.request.get('_route')|default('')) %}active{% endif %}">
                        <a href="{{ path('app_admin_users_index') }}" class="sidebar-link">
                            <i class="fas fa-users"></i>
                            <span class="sidebar-text">Utilisateurs</span>
                        </a>
                    </li>
                    <li class="sidebar-item {% if 'evenement' in app.request.get('_route')|default('') %}active{% endif %}">
                        <a href="#" class="sidebar-link sidebar-dropdown-toggle" data-dropdown="evenement-submenu">
                            <i class="fas fa-calendar-alt"></i>
                            <span class="sidebar-text">Événements</span>
                            <i class="fas fa-chevron-down sidebar-dropdown-icon"></i>
                        </a>
                        <ul class="sidebar-submenu" id="evenement-submenu">
                            <li class="sidebar-submenu-item">
                                <a href="{{ path('app_admin_evenements') }}" class="sidebar-submenu-link">
                                    <i class="fas fa-calendar-days"></i>
                                    <span>Événement</span>
                                </a>
                            </li>
                            <li class="sidebar-submenu-item">
                                <a href="{{ path('app_admin_participations') }}" class="sidebar-submenu-link">
                                    <i class="fas fa-users-between-lines"></i>
                                    <span>Participation</span>
                                </a>
                            </li>
                            <li class="sidebar-submenu-item">
                                <a href="{{ path('app_admin_scan') }}" class="sidebar-submenu-link">
                                    <i class="fas fa-qrcode"></i>
                                    <span>Scanner QR</span>
                                </a>
                            </li>
                        </ul>
                    </li>
                    <li class="sidebar-item {% if 'blog' in app.request.get('_route')|default('') %}active{% endif %}">
                        <a href="#" class="sidebar-link sidebar-dropdown-toggle" data-dropdown="blog-submenu">
                            <i class="fas fa-feather-alt"></i>
                            <span class="sidebar-text">Blogs</span>
                            <i class="fas fa-chevron-down sidebar-dropdown-icon"></i>
                        </a>
                        <ul class="sidebar-submenu" id="blog-submenu">
                            <li class="sidebar-submenu-item">
                                <a href="{{ path('app_admin_commentaires') }}" class="sidebar-submenu-link">
                                    <i class="fas fa-comments"></i>
                                    <span>Commentaires</span>
                                </a>
                            </li>
                            <li class="sidebar-submenu-item">
                                <a href="{{ path('app_admin_publications') }}" class="sidebar-submenu-link">
                                    <i class="fas fa-file-alt"></i>
                                    <span>Publications</span>
                                </a>
                            </li>
                        </ul>
                    </li>
                    <li class="sidebar-item {% if 'galerie' in app.request.get('_route')|default('') %}active{% endif %}">
                        <a href="#" class="sidebar-link sidebar-dropdown-toggle" data-dropdown="galerie-submenu">
                            <i class="fas fa-images"></i>
                            <span class="sidebar-text">Galerie</span>
                            <i class="fas fa-chevron-down sidebar-dropdown-icon"></i>
                        </a>
                        <ul class="sidebar-submenu" id="galerie-submenu">
                            <li class="sidebar-submenu-item">
                                <a href="{{ path('app_admin_galeries') }}" class="sidebar-submenu-link">
                                    <i class="fas fa-images"></i>
                                    <span>Galerie</span>
                                </a>
                            </li>
                            <li class="sidebar-submenu-item">
                                <a href="{{ path('app_admin_oeuvres') }}" class="sidebar-submenu-link">
                                    <i class="fas fa-palette"></i>
                                    <span>Œuvre</span>
                                </a>
                            </li>
                            <li class="sidebar-submenu-item {% if 'app_admin_stats' in (app.request.get('_route')|default('')) %}active{% endif %}">
                                <a href="{{ path('app_admin_stats_ventes') }}" class="sidebar-submenu-link">
                                    <i class="fas fa-chart-bar"></i>
                                    <span>Stats Ventes</span>
                                </a>
                            </li>
                        </ul>
                    </li>
                    <li class="sidebar-item {% if 'formation' in app.request.get('_route')|default('') or 'quiz' in app.request.get('_route')|default('') or 'question' in app.request.get('_route')|default('') or 'evaluation' in app.request.get('_route')|default('') %}active{% endif %}">
                        <a href="#" class="sidebar-link sidebar-dropdown-toggle" data-dropdown="formation-submenu">
                            <i class="fas fa-graduation-cap"></i>
                            <span class="sidebar-text">Formation</span>
                            <i class="fas fa-chevron-down sidebar-dropdown-icon"></i>
                        </a>
                        <ul class="sidebar-submenu" id="formation-submenu">
                            <li class="sidebar-submenu-item">
                                <a href="{{ path('app_formation_index') }}" class="sidebar-submenu-link">
                                    <i class="fas fa-graduation-cap"></i>
                                    <span>Formation</span>
                                </a>
                            </li>
                            <li class="sidebar-submenu-item">
                                <a href="{{ path('app_admin_quiz_index') }}" class="sidebar-submenu-link">
                                    <i class="fas fa-question-circle"></i>
                                    <span>Quiz</span>
                                </a>
                            </li>
                            <li class="sidebar-submenu-item">
                                <a href="{{ path('app_question_index') }}" class="sidebar-submenu-link">
                                    <i class="fas fa-list-ol"></i>
                                    <span>Questions</span>
                                </a>
                            </li>
                            <li class="sidebar-submenu-item">
                                <a href="{{ path('app_evaluation_index') }}" class="sidebar-submenu-link">
                                    <i class="fas fa-clipboard-check"></i>
                                    <span>Évaluation</span>
                                </a>
                            </li>
                        </ul>
                    </li>
                </ul>
            </div>

            {# ── Secondary Navigation ── #}
            <div class="sidebar-section">
                <span class="sidebar-section-title">Compte</span>
                <ul class="sidebar-nav">
                    <li class="sidebar-item">
                        <a href="{{ path('app_profile') }}" class="sidebar-link">
                            <i class="fas fa-user-circle"></i>
                            <span class="sidebar-text">Mon Profil</span>
                        </a>
                    </li>
                    <li class="sidebar-item">
                        <a href="{{ path('app_profile_edit') }}" class="sidebar-link">
                            <i class="fas fa-edit"></i>
                            <span class="sidebar-text">Modifier le Profil</span>
                        </a>
                    </li>
                    <li class="sidebar-item">
                        <a href="{{ path('app_logout') }}" class="sidebar-link" style="color:#dc3545;">
                            <i class="fas fa-sign-out-alt" style="color:#dc3545;"></i>
                            <span class="sidebar-text">Déconnexion</span>
                        </a>
                    </li>
                </ul>
            </div>

            {# ── Settings ── #}
            <div class="sidebar-section">
                <span class="sidebar-section-title">Settings</span>
                <ul class="sidebar-nav">
                    <li class="sidebar-item">
                        <a href="#" class="sidebar-link">
                            <i class="fas fa-chart-line"></i>
                            <span class="sidebar-text">Analytics</span>
                        </a>
                    </li>
                    <li class="sidebar-item">
                        <a href="#" class="sidebar-link">
                            <i class="fas fa-sliders-h"></i>
                            <span class="sidebar-text">Settings</span>
                        </a>
                    </li>
                </ul>
            </div>

        </div>
    </aside>

    {# ── Sidebar Overlay (mobile) ── #}
    <div class="sidebar-overlay" id="sidebarOverlay"></div>

    {# ═══════════════════════════════════════════════════════════════
       MAIN CONTENT AREA
       – Page header with breadcrumb
       – Dynamic content block
       – Footer
    ═══════════════════════════════════════════════════════════════ #}
    <main class="admin-main" id="adminMain">
        <div class="admin-content">

            {# ── Page Header / Breadcrumb ── #}
            <div class="page-header">
                <div class="d-flex flex-column flex-md-row justify-content-between align-items-start align-items-md-center">
                    <div>
                        <h1 class="page-title">{% block page_title %}Dashboard{% endblock %}</h1>
                        <nav aria-label="breadcrumb">
                            <ol class="breadcrumb admin-breadcrumb">
                                <li class="breadcrumb-item"><a href="{{ path('app_admin_dashboard') }}"><i class="fas fa-home"></i></a></li>
                                {% block breadcrumb %}
                                    <li class="breadcrumb-item active" aria-current="page">Dashboard</li>
                                {% endblock %}
                            </ol>
                        </nav>
                    </div>
                    <div class="page-actions mt-3 mt-md-0">
                        {% block page_actions %}{% endblock %}
                    </div>
                </div>
            </div>

            {# ── Flash Messages Globaux ── #}
            {% for label, messages in app.flashes %}
                {% for message in messages %}
                    <div class="alert alert-{{ label == 'success' ? 'success' : (label == 'error' ? 'danger' : label) }} alert-dismissible fade show mb-3">
                        <i class="fas fa-{{ label == 'success' ? 'check-circle' : 'exclamation-circle' }} me-2"></i>
                        {{ message }}
                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                    </div>
                {% endfor %}
            {% endfor %}

            {# ── Main Body Content ── #}
            {% block body %}{% endblock %}

        </div>

        {# ── Footer ── #}
        <footer class="admin-footer">
            <div class="d-flex flex-column flex-md-row justify-content-between align-items-center">
                <p class="mb-0">© {{ "now"|date("Y") }} <strong class="text-accent">Tun'Arche</strong>. All rights reserved.</p>
                <p class="mb-0 small">Crafted with <i class="fas fa-heart text-danger"></i> for Arts &amp; Events</p>
            </div>
        </footer>
    </main>

    {# ── Bootstrap 5.3 JS Bundle ── #}
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

    {# ── Admin Panel Custom JS ── #}
    <script src="{{ asset('assets/js/admin.js') }}"></script>

    {% block javascripts %}{% endblock %}
</body>
</html>
