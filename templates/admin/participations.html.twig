    {# ═══════════════════════════════════════════════════════════
       ADD / EDIT PARTICIPATION MODAL
       – Blurred backdrop (backdrop-filter: blur)
       – All required input fields
       – Conditional mode_paiement field (only for paid events)
    ═══════════════════════════════════════════════════════════ #}
    <div class="modal fade" id="participationModal" tabindex="-1" aria-labelledby="participationModalLabel" aria-hidden="true" data-bs-backdrop="static">
        <div class="modal-dialog modal-dialog-centered modal-lg">
            <div class="modal-content part-modal-content">

                {# ── Modal Header ── #}
                <div class="modal-header part-modal-header">
                    <div class="modal-header-icon part-header-icon">
                        <i class="fas fa-user-plus" id="partModalIcon"></i>
                    </div>
                    <div>
                        <h5 class="modal-title" id="participationModalLabel">Add Participation</h5>
                        <p class="modal-subtitle mb-0" id="partModalSubtitle">Fill in the details to register a new participation</p>
                    </div>
                    <button type="button" class="btn-close-modal" data-bs-dismiss="modal" aria-label="Close">
                        <i class="fas fa-times"></i>
                    </button>
                </div>

                {# ── Modal Body ── #}
                <div class="modal-body part-modal-body">
                    <form id="participationForm" novalidate>
                        <input type="hidden" id="formParticipationId" value="">

                        <div class="row g-3">
                            {# ── ID Participation ── #}
                            <div class="col-md-6">
                                <div class="form-floating-custom">
                                    <label for="inputPartId"><i class="fas fa-hashtag me-1 text-accent"></i> ID Participation</label>
                                    <input type="text" class="form-control modal-input" id="inputPartId" placeholder="Auto-generated" readonly>
                                    <small class="form-hint">Auto-generated by system</small>
                                </div>
                            </div>

                            {# ── Date Participation ── #}
                            <div class="col-md-6">
                                <div class="form-floating-custom">
                                    <label for="inputPartDate"><i class="fas fa-calendar-day me-1 text-accent"></i> Date Participation <span class="required">*</span></label>
                                    <input type="date" class="form-control modal-input" id="inputPartDate" required>
                                    <div class="invalid-feedback">Please select a date.</div>
                                </div>
                            </div>

                            {# ── ID User (Select) ── #}
                            <div class="col-md-12">
                                <div class="form-floating-custom">
                                    <label for="inputPartUser"><i class="fas fa-user me-1 text-accent"></i> User <span class="required">*</span></label>
                                    <select class="form-select modal-input" id="inputPartUser" required>
                                        <option value="" disabled selected>Select user…</option>
                                        <option value="1">Sophie Martin (sophie@tunarche.com)</option>
                                        <option value="2">Ahmed Ben Ali (ahmed@tunarche.com)</option>
                                        <option value="3">Clara Dubois (clara@tunarche.com)</option>
                                        <option value="4">Marc Lefevre (marc@tunarche.com)</option>
                                        <option value="5">Lina Haddad (lina@tunarche.com)</option>
                                        <option value="6">Thomas Blanc (thomas@tunarche.com)</option>
                                    </select>
                                    <div class="invalid-feedback">Please select a user.</div>
                                </div>
                            </div>

                            {# ── ID Événement (Select) ── #}
                            <div class="col-md-12">
                                <div class="form-floating-custom">
                                    <label for="inputPartEvent"><i class="fas fa-calendar-star me-1 text-accent"></i> Événement <span class="required">*</span></label>
                                    <select class="form-select modal-input" id="inputPartEvent" required>
                                        <option value="" disabled selected>Select event…</option>
                                        <option value="1" data-paid="true">Gala Night 2026 (Paid)</option>
                                        <option value="2" data-paid="false">Art Moderne Exhibition (Free)</option>
                                        <option value="3" data-paid="true">Jazz & Wine Evening (Paid)</option>
                                        <option value="4" data-paid="true">Photography Workshop (Paid)</option>
                                        <option value="5" data-paid="false">Digital Art Conference (Free)</option>
                                        <option value="6" data-paid="true">Festival des Arts Vivants (Paid)</option>
                                    </select>
                                    <div class="invalid-feedback">Please select an event.</div>
                                </div>
                            </div>

                            {# ── Status ── #}
                            <div class="col-md-6">
                                <div class="form-floating-custom">
                                    <label for="inputPartStatus"><i class="fas fa-check-circle me-1 text-accent"></i> Status <span class="required">*</span></label>
                                    <select class="form-select modal-input" id="inputPartStatus" required>
                                        <option value="" disabled selected>Select status…</option>
                                        <option value="pending">Pending</option>
                                        <option value="accepted">Accepted</option>
                                        <option value="refused">Refused</option>
                                    </select>
                                    <div class="invalid-feedback">Please select a status.</div>
                                </div>
                            </div>

                            {# ── Nbr Participation ── #}
                            <div class="col-md-6">
                                <div class="form-floating-custom">
                                    <label for="inputPartNbr"><i class="fas fa-users me-1 text-accent"></i> Nbr Participants <span class="required">*</span></label>
                                    <input type="number" class="form-control modal-input" id="inputPartNbr" placeholder="0" min="1" required>
                                    <div class="invalid-feedback">Enter number of participants.</div>
                                </div>
                            </div>

                            {# ── Mode Paiement (Conditional) ── #}
                            <div class="col-md-12" id="paiementModeField" style="display: none;">
                                <div class="form-floating-custom">
                                    <label for="inputPartPaiement"><i class="fas fa-credit-card me-1 text-accent"></i> Mode Paiement <span class="required">*</span></label>
                                    <select class="form-select modal-input" id="inputPartPaiement">
                                        <option value="" disabled selected>Select payment method…</option>
                                        <option value="cash"><i class="fas fa-money-bill-wave"></i> Cash</option>
                                        <option value="card"><i class="fas fa-credit-card"></i> Card</option>
                                        <option value="online"><i class="fas fa-globe"></i> Online</option>
                                    </select>
                                    <div class="invalid-feedback">Please select a payment method.</div>
                                    <small class="form-hint text-warning"><i class="fas fa-info-circle me-1"></i>Payment required for paid events</small>
                                </div>
                            </div>
                        </div>

                    </form>
                </div>

                {# ── Modal Footer ── #}
                <div class="modal-footer part-modal-footer">
                    <button type="button" class="btn btn-modal-cancel" data-bs-dismiss="modal">
                        <i class="fas fa-times me-1"></i> Cancel
                    </button>
                    <button type="button" class="btn btn-modal-save" id="saveParticipationBtn">
                        <i class="fas fa-check me-1"></i> <span id="saveParticipationBtnText">Save Participation</span>
                    </button>
                </div>

            </div>
        </div>
    </div>


    {# ═══════════════════════════════════════════════════════════
       CUSTOM DELETE CONFIRMATION ALERT
    ═══════════════════════════════════════════════════════════ #}
    <div class="custom-alert-overlay" id="deletePartAlertOverlay">
        <div class="custom-alert-box" id="deletePartAlertBox">
            <div class="alert-icon-wrap danger-part">
                <i class="fas fa-user-xmark"></i>
            </div>
            <h4 class="alert-title">Delete Participation?</h4>
            <p class="alert-message">Are you sure you want to delete the participation for <strong id="deletePartUser"></strong>? This action cannot be undone.</p>
            <div class="alert-actions">
                <button class="btn btn-alert-cancel" id="cancelPartDeleteBtn">
                    <i class="fas fa-times me-1"></i> Cancel
                </button>
                <button class="btn btn-alert-confirm" id="confirmPartDeleteBtn">
                    <i class="fas fa-trash-can me-1"></i> Delete
                </button>
            </div>
        </div>
    </div>


    {# ═══════════════════════════════════════════════════════════
       TOAST NOTIFICATIONS
    ═══════════════════════════════════════════════════════════ #}
    <div class="toast-container position-fixed top-0 end-0 p-3" id="partToastContainer" style="z-index: 1090;">

        <div class="toast admin-toast toast-success" id="partToastSuccess" role="alert" aria-live="assertive" aria-atomic="true" data-bs-autohide="true" data-bs-delay="4000">
            <div class="toast-body-custom">
                <div class="toast-icon"><i class="fas fa-check-circle"></i></div>
                <div class="toast-content">
                    <strong class="toast-title">Success</strong>
                    <p class="toast-message mb-0" id="partToastSuccessMsg">Operation completed successfully.</p>
                </div>
                <button type="button" class="btn-close-toast" data-bs-dismiss="toast" aria-label="Close"><i class="fas fa-times"></i></button>
            </div>
            <div class="toast-progress"><div class="toast-progress-bar success"></div></div>
        </div>

        <div class="toast admin-toast toast-error" id="partToastError" role="alert" aria-live="assertive" aria-atomic="true" data-bs-autohide="true" data-bs-delay="5000">
            <div class="toast-body-custom">
                <div class="toast-icon"><i class="fas fa-times-circle"></i></div>
                <div class="toast-content">
                    <strong class="toast-title">Error</strong>
                    <p class="toast-message mb-0" id="partToastErrorMsg">Something went wrong.</p>
                </div>
                <button type="button" class="btn-close-toast" data-bs-dismiss="toast" aria-label="Close"><i class="fas fa-times"></i></button>
            </div>
            <div class="toast-progress"><div class="toast-progress-bar error"></div></div>
        </div>

        <div class="toast admin-toast toast-warning" id="partToastWarning" role="alert" aria-live="assertive" aria-atomic="true" data-bs-autohide="true" data-bs-delay="4000">
            <div class="toast-body-custom">
                <div class="toast-icon"><i class="fas fa-exclamation-circle"></i></div>
                <div class="toast-content">
                    <strong class="toast-title">Warning</strong>
                    <p class="toast-message mb-0" id="partToastWarningMsg">Please check your input.</p>
                </div>
                <button type="button" class="btn-close-toast" data-bs-dismiss="toast" aria-label="Close"><i class="fas fa-times"></i></button>
            </div>
            <div class="toast-progress"><div class="toast-progress-bar warning"></div></div>
        </div>

    </div>

{% endblock %}

{% block javascripts %}
    <script src="{{ asset('assets/js/admin-participations.js') }}"></script>
{% endblock %}
