{# ═══════════════════════════════════════════════════════════════
   Admin Participations Management Page
   Route: /admin/participation
   Features:
     – Dynamic data from DB (no hardcoded rows)
     – Form-based CRUD (no AJAX/JSON)
     – Add/Edit participation modal with blurred backdrop
     – Conditional mode_paiement field (only for paid events)
     – Custom animated alert for delete confirmation
     – Fully responsive, luxury dark + gold/purple theme
═══════════════════════════════════════════════════════════════ #}
{% extends 'admin/base.html.twig' %}

{% block title %}Participations Management{% endblock %}

{% block page_title %}Participations{% endblock %}

{% block breadcrumb %}
    <li class="breadcrumb-item"><a href="{{ path('app_admin_dashboard') }}">Dashboard</a></li>
    <li class="breadcrumb-item active" aria-current="page">Participations</li>
{% endblock %}

{% block page_actions %}
    <div class="d-flex gap-2 flex-wrap">
        <button class="btn btn-admin-outline btn-sm" id="exportParticipationsBtn">
            <i class="fas fa-file-export me-1"></i> Export
        </button>
        <button class="btn btn-admin-primary" data-bs-toggle="modal" data-bs-target="#participationModal" id="addParticipationBtn">
            <i class="fas fa-user-plus me-1"></i> Add Participation
        </button>
    </div>
{% endblock %}

{% block stylesheets %}
    <link href="{{ asset('assets/css/admin-participations.css') }}" rel="stylesheet">
{% endblock %}

{% block body %}

    {# ═══════════════════════════════════════════════════════════
       FLASH MESSAGES
    ═══════════════════════════════════════════════════════════ #}
    {% for label, messages in app.flashes %}
        {% for message in messages %}
            <div class="alert alert-{{ label == 'success' ? 'success' : 'danger' }} alert-dismissible fade show mb-3" role="alert" style="background: {{ label == 'success' ? 'rgba(40,167,69,0.15)' : 'rgba(220,53,69,0.15)' }}; border: 1px solid {{ label == 'success' ? 'rgba(40,167,69,0.3)' : 'rgba(220,53,69,0.3)' }}; color: #fff;">
                <i class="fas {{ label == 'success' ? 'fa-check-circle' : 'fa-exclamation-circle' }} me-2"></i>
                {{ message }}
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        {% endfor %}
    {% endfor %}

    {# ═══════════════════════════════════════════════════════════
       PARTICIPATION STAT SUMMARY CARDS
    ═══════════════════════════════════════════════════════════ #}
    <div class="row g-3 mb-4">
        <div class="col-xl-3 col-lg-6 col-md-6 col-sm-6">
            <div class="part-stat-card animate-in">
                <div class="part-stat-icon gold">
                    <i class="fas fa-ticket-alt"></i>
                </div>
                <div class="part-stat-info">
                    <span class="part-stat-value" data-counter="{{ totalCount }}">0</span>
                    <span class="part-stat-label">Total Participations</span>
                </div>
                <div class="part-stat-trend up"><i class="fas fa-arrow-up"></i> 18%</div>
            </div>
        </div>
        <div class="col-xl-3 col-lg-6 col-md-6 col-sm-6">
            <div class="part-stat-card animate-in">
                <div class="part-stat-icon teal">
                    <i class="fas fa-check-circle"></i>
                </div>
                <div class="part-stat-info">
                    <span class="part-stat-value" data-counter="{{ confirmedCount }}">0</span>
                    <span class="part-stat-label">Confirmées</span>
                </div>
                <div class="part-stat-trend up"><i class="fas fa-arrow-up"></i> 12%</div>
            </div>
        </div>
        <div class="col-xl-3 col-lg-6 col-md-6 col-sm-6">
            <div class="part-stat-card animate-in">
                <div class="part-stat-icon purple">
                    <i class="fas fa-clock"></i>
                </div>
                <div class="part-stat-info">
                    <span class="part-stat-value" data-counter="{{ pendingCount }}">0</span>
                    <span class="part-stat-label">En attente</span>
                </div>
                <div class="part-stat-trend down"><i class="fas fa-arrow-down"></i> 5%</div>
            </div>
        </div>
        <div class="col-xl-3 col-lg-6 col-md-6 col-sm-6">
            <div class="part-stat-card animate-in">
                <div class="part-stat-icon gold">
                    <i class="fas fa-users"></i>
                </div>
                <div class="part-stat-info">
                    <span class="part-stat-value" data-counter="{{ totalPlaces }}">0</span>
                    <span class="part-stat-label">Total Places</span>
                </div>
                <div class="part-stat-trend up"><i class="fas fa-arrow-up"></i> 3%</div>
            </div>
        </div>
    </div>


    {# ═══════════════════════════════════════════════════════════
       PARTICIPATIONS TABLE CARD
    ═══════════════════════════════════════════════════════════ #}
    <div class="admin-table-card part-table-card animate-in">

        {# ── Table Header with Filters (PHP server-side) ── #}
        <div class="admin-table-header">
            <div class="d-flex align-items-center gap-2">
                <h3 class="admin-table-title mb-0">
                    <i class="fas fa-clipboard-list me-2 text-accent"></i>All Participations
                </h3>
                <span class="part-count-badge">{{ participations|length }}</span>
            </div>
            <form method="get" action="{{ path('app_admin_participations') }}" class="part-table-filters d-flex flex-wrap gap-2 align-items-center mt-3 mt-md-0">
                <div class="part-search-wrap">
                    <i class="fas fa-search"></i>
                    <input type="text" class="form-control admin-form-control" name="q" value="{{ q }}" placeholder="Search participations…">
                </div>
                <select class="form-select admin-select" name="statut" onchange="this.form.submit()">
                    <option value="" {{ statut == '' ? 'selected' : '' }}>All Status</option>
                    <option value="En attente" {{ statut == 'En attente' ? 'selected' : '' }}>En attente</option>
                    <option value="Confirmée" {{ statut == 'Confirmée' ? 'selected' : '' }}>Confirmée</option>
                    <option value="Annulée" {{ statut == 'Annulée' ? 'selected' : '' }}>Annulée</option>
                </select>
                <select class="form-select admin-select" name="paiement" onchange="this.form.submit()">
                    <option value="" {{ paiement == '' ? 'selected' : '' }}>All Payment</option>
                    <option value="Carte" {{ paiement == 'Carte' ? 'selected' : '' }}>Carte</option>
                    <option value="Cash" {{ paiement == 'Cash' ? 'selected' : '' }}>Cash</option>
                    <option value="free" {{ paiement == 'free' ? 'selected' : '' }}>Gratuit</option>
                </select>
                <input type="hidden" name="sort" value="{{ sort }}">
                <input type="hidden" name="order" value="{{ order }}">
                <button type="submit" class="btn btn-sm" style="background:rgba(212,175,55,0.15);border:1px solid rgba(212,175,55,0.3);color:#d4af37;border-radius:6px;padding:0.4rem 0.8rem;"><i class="fas fa-search"></i></button>
                {% if q is not empty or statut is not empty or paiement is not empty %}
                    <a href="{{ path('app_admin_participations') }}" class="btn btn-sm" style="background:rgba(255,255,255,0.06);border:1px solid rgba(255,255,255,0.1);color:rgba(255,255,255,0.6);border-radius:6px;padding:0.4rem 0.8rem;" title="Reset"><i class="fas fa-times"></i></a>
                {% endif %}
            </form>
        </div>

        {% set nextOrder = order == 'ASC' ? 'DESC' : 'ASC' %}

        {# ── Responsive Table ── #}
        <div class="table-responsive">
            <table class="admin-table part-table" id="participationsTable">
                <thead>
                    <tr>
                        <th class="th-check"><input type="checkbox" class="form-check-input" id="selectAllParticipations"></th>
                        <th>ID</th>
                        <th><a href="{{ path('app_admin_participations', {q: q, statut: statut, paiement: paiement, sort: 'evenement', order: sort == 'evenement' ? nextOrder : 'ASC'}) }}" style="color:inherit;text-decoration:none;">Événement <i class="fas fa-sort{{ sort == 'evenement' ? (order == 'ASC' ? '-up' : '-down') : '' }}" style="font-size:0.7rem;{{ sort == 'evenement' ? 'color:#a855f7;' : 'opacity:0.4;' }}"></i></a></th>
                        <th><a href="{{ path('app_admin_participations', {q: q, statut: statut, paiement: paiement, sort: 'dateParticipation', order: sort == 'dateParticipation' ? nextOrder : 'DESC'}) }}" style="color:inherit;text-decoration:none;">Date <i class="fas fa-sort{{ sort == 'dateParticipation' ? (order == 'ASC' ? '-up' : '-down') : '' }}" style="font-size:0.7rem;{{ sort == 'dateParticipation' ? 'color:#a855f7;' : 'opacity:0.4;' }}"></i></a></th>
                        <th><a href="{{ path('app_admin_participations', {q: q, statut: statut, paiement: paiement, sort: 'statut', order: sort == 'statut' ? nextOrder : 'ASC'}) }}" style="color:inherit;text-decoration:none;">Statut <i class="fas fa-sort{{ sort == 'statut' ? (order == 'ASC' ? '-up' : '-down') : '' }}" style="font-size:0.7rem;{{ sort == 'statut' ? 'color:#a855f7;' : 'opacity:0.4;' }}"></i></a></th>
                        <th><a href="{{ path('app_admin_participations', {q: q, statut: statut, paiement: paiement, sort: 'nbrParticipation', order: sort == 'nbrParticipation' ? nextOrder : 'DESC'}) }}" style="color:inherit;text-decoration:none;">Places <i class="fas fa-sort{{ sort == 'nbrParticipation' ? (order == 'ASC' ? '-up' : '-down') : '' }}" style="font-size:0.7rem;{{ sort == 'nbrParticipation' ? 'color:#a855f7;' : 'opacity:0.4;' }}"></i></a></th>
                        <th>Paiement</th>
                        <th class="th-actions">Actions</th>
                    </tr>
                </thead>
                <tbody id="participationsTableBody">

                    {% if participations is empty %}
                        <tr>
                            <td colspan="8" class="text-center py-5">
                                <i class="fas fa-ticket-alt d-block mb-2" style="font-size: 2rem; color: rgba(212,175,55,0.3);"></i>
                                <span style="color: rgba(255,255,255,0.4);">Aucune participation trouvée. <a href="#" onclick="document.getElementById('addParticipationBtn').click(); return false;" style="color: #d4af37;">Créer la première</a></span>
                            </td>
                        </tr>
                    {% else %}
                        {% for p in participations %}
                        <tr data-participation-id="{{ p.id }}"
                            data-status="{{ p.statut }}"
                            data-paiement="{{ p.modePaiement ?? 'free' }}"
                            data-id-evenement="{{ p.evenement ? p.evenement.id : '' }}"
                            data-date="{{ p.dateParticipation|date('Y-m-d') }}"
                            data-nbr="{{ p.nbrParticipation }}"
                            data-mode-paiement="{{ p.modePaiement ?? '' }}"
                            data-event-name="{{ p.evenement ? p.evenement.nom : 'N/A' }}"
                            data-event-paid="{{ p.evenement and p.evenement.paiement ? '1' : '0' }}">
                            <td><input type="checkbox" class="form-check-input part-check"></td>
                            <td class="part-id">#PART-{{ '%03d'|format(p.id) }}</td>
                            <td><span class="part-event-name"><i class="fas fa-calendar-alt me-1 text-muted"></i>{{ p.evenement ? p.evenement.nom : 'N/A' }}</span></td>
                            <td><span class="part-date"><i class="fas fa-calendar-day me-1 text-muted"></i>{{ p.dateParticipation|date('d/m/Y') }}</span></td>
                            <td>
                                {% if p.statut == 'Confirmée' %}
                                    <span class="status-badge status-accepted"><i class="fas fa-check-circle me-1"></i>Confirmée</span>
                                {% elseif p.statut == 'En attente' %}
                                    <span class="status-badge status-pending"><i class="fas fa-clock me-1"></i>En attente</span>
                                {% else %}
                                    <span class="status-badge status-refused"><i class="fas fa-times-circle me-1"></i>Annulée</span>
                                {% endif %}
                            </td>
                            <td><span class="part-number">{{ p.nbrParticipation }}</span></td>
                            <td>
                                {% if p.modePaiement == 'Carte' %}
                                    <span class="paiement-mode-badge pm-card"><i class="fas fa-credit-card me-1"></i>Carte</span>
                                {% elseif p.modePaiement == 'Cash' %}
                                    <span class="paiement-mode-badge pm-cash"><i class="fas fa-money-bill-wave me-1"></i>Cash</span>
                                {% else %}
                                    <span class="paiement-mode-badge pm-free"><i class="fas fa-gift me-1"></i>Gratuit</span>
                                {% endif %}
                            </td>
                            <td>
                                <div class="table-actions">
                                    <button type="button" class="table-action-btn view-part-btn" title="View" data-bs-toggle="tooltip" data-participation-id="{{ p.id }}"><i class="fas fa-eye"></i></button>
                                    <button type="button" class="table-action-btn edit-part-btn" title="Edit" data-bs-toggle="tooltip" data-participation-id="{{ p.id }}"><i class="fas fa-pen-to-square"></i></button>
                                    <button type="button" class="table-action-btn delete delete-part-btn" title="Delete" data-bs-toggle="tooltip" data-participation-id="{{ p.id }}" data-participation-name="#PART-{{ '%03d'|format(p.id) }}" data-delete-url="{{ path('app_admin_participation_delete', {id: p.id}) }}"><i class="fas fa-trash-can"></i></button>
                                </div>
                            </td>
                        </tr>
                        {% endfor %}
                    {% endif %}

                </tbody>
            </table>
        </div>

        {# ── Table Footer ── #}
        <div class="admin-table-footer">
            <div class="table-footer-info">
                Showing <strong>{{ participations|length }}</strong> of <strong>{{ totalCount }}</strong> participations
            </div>
        </div>
    </div>


    {# ═══════════════════════════════════════════════════════════
       ADD / EDIT PARTICIPATION MODAL
       – Form-based POST (no AJAX)
       – Conditional mode_paiement field (only for paid events)
    ═══════════════════════════════════════════════════════════ #}
    <div class="modal fade" id="participationModal" tabindex="-1" aria-labelledby="participationModalLabel" aria-hidden="true" data-bs-backdrop="static">
        <div class="modal-dialog modal-dialog-centered modal-lg">
            <div class="modal-content part-modal-content">

                {# ── Modal Header ── #}
                <div class="modal-header part-modal-header">
                    <div class="modal-header-icon part-header-icon">
                        <i class="fas fa-user-plus" id="partModalIcon"></i>
                    </div>
                    <div>
                        <h5 class="modal-title" id="participationModalLabel">Add Participation</h5>
                        <p class="modal-subtitle mb-0" id="partModalSubtitle">Fill in the details to register a new participation</p>
                    </div>
                    <button type="button" class="btn-close-modal" data-bs-dismiss="modal" aria-label="Close">
                        <i class="fas fa-times"></i>
                    </button>
                </div>

                {# ── Modal Body ── #}
                <div class="modal-body part-modal-body">
                    <form id="participationForm" method="POST" action="{{ path('app_admin_participation_store') }}" novalidate>

                        <div class="row g-3">
                            {# ── ID Participation ── #}
                            <div class="col-md-6">
                                <div class="form-floating-custom">
                                    <label for="inputPartId"><i class="fas fa-hashtag me-1 text-accent"></i> ID Participation</label>
                                    <input type="text" class="form-control modal-input" id="inputPartId" placeholder="Auto-generated" readonly>
                                    <small class="form-hint">Auto-generated by system</small>
                                </div>
                            </div>

                            {# ── Date Participation ── #}
                            <div class="col-md-6">
                                <div class="form-floating-custom">
                                    <label for="inputPartDate"><i class="fas fa-calendar-day me-1 text-accent"></i> Date Participation <span class="required">*</span></label>
                                    <input type="date" class="form-control modal-input" id="inputPartDate" name="date_participation" required>
                                    <div class="invalid-feedback">Veuillez sélectionner une date.</div>
                                </div>
                            </div>

                            {# ── Événement (Select) ── #}
                            <div class="col-md-12">
                                <div class="form-floating-custom">
                                    <label for="inputPartEvent"><i class="fas fa-calendar-alt me-1 text-accent"></i> Événement <span class="required">*</span></label>
                                    <select class="form-select modal-input" id="inputPartEvent" name="id_evenement" required>
                                        <option value="" disabled selected>Sélectionner un événement…</option>
                                        {% for evt in evenements %}
                                            <option value="{{ evt.id }}" data-paid="{{ evt.paiement ? '1' : '0' }}" data-date="{{ evt.date|date('Y-m-d') }}">
                                                {{ evt.nom }} ({{ evt.date|date('d/m/Y') }}) — {{ evt.nbrParticipant }} places
                                            </option>
                                        {% endfor %}
                                    </select>
                                    <div class="invalid-feedback">Veuillez sélectionner un événement.</div>
                                </div>
                            </div>

                            {# ── Statut ── #}
                            <div class="col-md-6">
                                <div class="form-floating-custom">
                                    <label for="inputPartStatus"><i class="fas fa-check-circle me-1 text-accent"></i> Statut <span class="required">*</span></label>
                                    <select class="form-select modal-input" id="inputPartStatus" name="statut" required>
                                        <option value="" disabled selected>Sélectionner un statut…</option>
                                        <option value="En attente">En attente</option>
                                        <option value="Confirmée">Confirmée</option>
                                        <option value="Annulée">Annulée</option>
                                    </select>
                                    <div class="invalid-feedback">Veuillez sélectionner un statut.</div>
                                </div>
                            </div>

                            {# ── Nbr Participation ── #}
                            <div class="col-md-6">
                                <div class="form-floating-custom">
                                    <label for="inputPartNbr"><i class="fas fa-users me-1 text-accent"></i> Nombre de places <span class="required">*</span></label>
                                    <input type="number" class="form-control modal-input" id="inputPartNbr" name="nbr_participation" placeholder="0" min="1" required>
                                    <div class="invalid-feedback">Entrez le nombre de places.</div>
                                </div>
                            </div>

                            {# ── Mode Paiement (Conditional) ── #}
                            <div class="col-md-12" id="paiementModeField" style="display: none;">
                                <div class="form-floating-custom">
                                    <label for="inputPartPaiement"><i class="fas fa-credit-card me-1 text-accent"></i> Mode Paiement <span class="required">*</span></label>
                                    <select class="form-select modal-input" id="inputPartPaiement" name="mode_paiement">
                                        <option value="" disabled selected>Sélectionner un mode de paiement…</option>
                                        <option value="Carte">💳 Carte bancaire</option>
                                        <option value="Cash">💵 Cash</option>
                                    </select>
                                    <div class="invalid-feedback">Veuillez sélectionner un mode de paiement.</div>
                                    <small class="form-hint text-warning"><i class="fas fa-info-circle me-1"></i>Paiement requis pour les événements payants</small>
                                </div>
                            </div>
                        </div>

                    </form>
                </div>

                {# ── Modal Footer ── #}
                <div class="modal-footer part-modal-footer">
                    <button type="button" class="btn btn-modal-cancel" data-bs-dismiss="modal">
                        <i class="fas fa-times me-1"></i> Cancel
                    </button>
                    <button type="submit" class="btn btn-modal-save" id="saveParticipationBtn" form="participationForm">
                        <i class="fas fa-check me-1"></i> <span id="saveParticipationBtnText">Save Participation</span>
                    </button>
                </div>

            </div>
        </div>
    </div>


    {# ═══════════════════════════════════════════════════════════
       CUSTOM DELETE CONFIRMATION ALERT (form-based POST)
    ═══════════════════════════════════════════════════════════ #}
    <div class="custom-alert-overlay" id="deletePartAlertOverlay">
        <div class="custom-alert-box" id="deletePartAlertBox">
            <div class="alert-icon-wrap danger-part">
                <i class="fas fa-user-xmark"></i>
            </div>
            <h4 class="alert-title">Delete Participation?</h4>
            <p class="alert-message">Are you sure you want to delete <strong id="deletePartName"></strong>? This action cannot be undone.</p>
            <form id="deletePartForm" method="POST" action="">
                <div class="alert-actions">
                    <button type="button" class="btn btn-alert-cancel" id="cancelPartDeleteBtn">
                        <i class="fas fa-times me-1"></i> Cancel
                    </button>
                    <button type="submit" class="btn btn-alert-confirm" id="confirmPartDeleteBtn">
                        <i class="fas fa-trash-can me-1"></i> Delete
                    </button>
                </div>
            </form>
        </div>
    </div>

{% endblock %}

{% block javascripts %}
    <script src="{{ asset('assets/js/admin-participations.js') }}"></script>
{% endblock %}
