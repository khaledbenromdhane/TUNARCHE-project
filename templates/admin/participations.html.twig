{# ═══════════════════════════════════════════════════════════════
   Admin Participations Management Page
   Route: /admin/participation
   Features:
     – Styled participation listing table
     – Add/Edit participation modal with blurred backdrop
     – Conditional mode_paiement field (only for paid events)
     – Bootstrap Toasts for success/error notifications
     – Custom animated alert for delete confirmation
     – Fully responsive, luxury dark + gold/purple theme
═══════════════════════════════════════════════════════════════ #}
{% extends 'admin/base.html.twig' %}

{% block title %}Participations Management{% endblock %}

{% block page_title %}Participations{% endblock %}

{% block breadcrumb %}
    <li class="breadcrumb-item"><a href="{{ path('app_admin_dashboard') }}">Dashboard</a></li>
    <li class="breadcrumb-item active" aria-current="page">Participations</li>
{% endblock %}

{% block page_actions %}
    <div class="d-flex gap-2 flex-wrap">
        <button class="btn btn-admin-outline btn-sm" id="exportParticipationsBtn">
            <i class="fas fa-file-export me-1"></i> Export
        </button>
        <button class="btn btn-admin-primary" data-bs-toggle="modal" data-bs-target="#participationModal" id="addParticipationBtn">
            <i class="fas fa-user-plus me-1"></i> Add Participation
        </button>
    </div>
{% endblock %}

{% block stylesheets %}
    <link href="{{ asset('assets/css/admin-participations.css') }}" rel="stylesheet">
{% endblock %}

{% block body %}

