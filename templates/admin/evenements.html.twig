{# ═══════════════════════════════════════════════════════════════
   Admin Événements Management Page
   Route: /admin/evenement
   Features:
     – Styled event listing table with all required columns
     – Add/Edit event modal with blurred backdrop
     – Payment toggle switch (true/false)
     – Bootstrap Toasts for success/error notifications
     – Custom animated alert for delete confirmation
     – Fully responsive, luxury dark + gold/purple theme
═══════════════════════════════════════════════════════════════ #}
{% extends 'admin/base.html.twig' %}

{% block title %}Événements Management{% endblock %}

{% block page_title %}Événements{% endblock %}

{% block breadcrumb %}
    <li class="breadcrumb-item"><a href="{{ path('app_admin_dashboard') }}">Dashboard</a></li>
    <li class="breadcrumb-item active" aria-current="page">Événements</li>
{% endblock %}

{% block page_actions %}
    <div class="d-flex gap-2 flex-wrap">
        <button class="btn btn-admin-outline btn-sm" id="exportEventsBtn">
            <i class="fas fa-file-export me-1"></i> Export
        </button>
        <button type="button" class="btn btn-admin-primary" id="addEventBtn" data-bs-toggle="modal" data-bs-target="#eventModal">
            <i class="fas fa-calendar-plus me-1"></i> Add Événement
        </button>
    </div>
{% endblock %}

{% block stylesheets %}
    <link href="{{ asset('assets/css/admin-events.css') }}" rel="stylesheet">
{% endblock %}

{% block body %}

    {# ═══════════════════════════════════════════════════════════
       FLASH MESSAGES
    ═══════════════════════════════════════════════════════════ #}
    {% for label, messages in app.flashes %}
        {% for message in messages %}
            <div class="alert alert-{{ label == 'success' ? 'success' : 'danger' }} alert-dismissible fade show mb-3" role="alert" style="background: {{ label == 'success' ? 'rgba(40,167,69,0.15)' : 'rgba(220,53,69,0.15)' }}; border: 1px solid {{ label == 'success' ? 'rgba(40,167,69,0.3)' : 'rgba(220,53,69,0.3)' }}; color: #fff;">
                <i class="fas {{ label == 'success' ? 'fa-check-circle' : 'fa-exclamation-circle' }} me-2"></i>
                {{ message }}
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        {% endfor %}
    {% endfor %}

    {# ═══════════════════════════════════════════════════════════
       EVENT STAT SUMMARY CARDS
    ═══════════════════════════════════════════════════════════ #}
    <div class="row g-3 mb-4">
        <div class="col-xl-3 col-lg-6 col-md-6 col-sm-6">
            <div class="evt-stat-card animate-in">
                <div class="evt-stat-icon gold">
                    <i class="fas fa-calendar-check"></i>
                </div>
                <div class="evt-stat-info">
                    <span class="evt-stat-value" data-counter="{{ totalCount }}">0</span>
                    <span class="evt-stat-label">Total Events</span>
                </div>
                <div class="evt-stat-trend up"><i class="fas fa-arrow-up"></i> 12%</div>
            </div>
        </div>
        <div class="col-xl-3 col-lg-6 col-md-6 col-sm-6">
            <div class="evt-stat-card animate-in">
                <div class="evt-stat-icon purple">
                    <i class="fas fa-clock"></i>
                </div>
                <div class="evt-stat-info">
                    <span class="evt-stat-value" data-counter="{{ upcomingCount }}">0</span>
                    <span class="evt-stat-label">Upcoming</span>
                </div>
                <div class="evt-stat-trend up"><i class="fas fa-arrow-up"></i> 8%</div>
            </div>
        </div>
        <div class="col-xl-3 col-lg-6 col-md-6 col-sm-6">
            <div class="evt-stat-card animate-in">
                <div class="evt-stat-icon teal">
                    <i class="fas fa-users-between-lines"></i>
                </div>
                <div class="evt-stat-info">
                    <span class="evt-stat-value" data-counter="{{ totalAttendees }}">0</span>
                    <span class="evt-stat-label">Total Attendees</span>
                </div>
                <div class="evt-stat-trend up"><i class="fas fa-arrow-up"></i> 24%</div>
            </div>
        </div>
        <div class="col-xl-3 col-lg-6 col-md-6 col-sm-6">
            <div class="evt-stat-card animate-in">
                <div class="evt-stat-icon gold">
                    <i class="fas fa-coins"></i>
                </div>
                <div class="evt-stat-info">
                    <span class="evt-stat-value" data-counter="{{ paidCount }}">0</span>
                    <span class="evt-stat-label">Paid Events</span>
                </div>
                <div class="evt-stat-trend down"><i class="fas fa-arrow-down"></i> 3%</div>
            </div>
        </div>
    </div>


    {# ═══════════════════════════════════════════════════════════
       EVENTS TABLE CARD
    ═══════════════════════════════════════════════════════════ #}
    <div class="admin-table-card evt-table-card animate-in">

        {# ── Table Header with Filters (AJAX dynamic search) ── #}
        <div class="admin-table-header">
            <div class="d-flex align-items-center gap-2">
                <h3 class="admin-table-title mb-0">
                    <i class="fas fa-calendar-alt me-2 text-accent"></i>All Événements
                </h3>
                <span class="evt-count-badge" id="evtCountBadge">{{ evenements|length }}</span>
            </div>
            <div class="evt-table-filters d-flex flex-wrap gap-2 align-items-center mt-3 mt-md-0">
                <div class="evt-search-wrap">
                    <i class="fas fa-search"></i>
                    <input type="text" class="form-control admin-form-control" id="adminEvtSearchInput" value="{{ q }}" placeholder="Search events…">
                </div>
                <select class="form-select admin-select" id="adminEvtTypeFilter">
                    <option value="" {{ type == '' ? 'selected' : '' }}>All Types</option>
                    <option value="Concerts" {{ type == 'Concerts' ? 'selected' : '' }}>Concerts</option>
                    <option value="Expositions d'art" {{ type == "Expositions d'art" ? 'selected' : '' }}>Expositions d'art</option>
                    <option value="Festivals" {{ type == 'Festivals' ? 'selected' : '' }}>Festivals</option>
                    <option value="Spectacles de danse" {{ type == 'Spectacles de danse' ? 'selected' : '' }}>Spectacles de danse</option>
                    <option value="Théâtre" {{ type == 'Théâtre' ? 'selected' : '' }}>Théâtre</option>
                    <option value="Tournois" {{ type == 'Tournois' ? 'selected' : '' }}>Tournois</option>
                    <option value="Formations" {{ type == 'Formations' ? 'selected' : '' }}>Formations</option>
                </select>
                <select class="form-select admin-select" id="adminEvtPaiementFilter">
                    <option value="" {{ paiement == '' ? 'selected' : '' }}>All Payment</option>
                    <option value="1" {{ paiement == '1' ? 'selected' : '' }}>Paid</option>
                    <option value="0" {{ paiement == '0' ? 'selected' : '' }}>Free</option>
                </select>
                <input type="hidden" id="adminEvtSort" value="{{ sort }}">
                <input type="hidden" id="adminEvtOrder" value="{{ order }}">
                <button type="button" class="btn btn-sm" id="adminEvtSearchBtn" style="background:rgba(212,175,55,0.15);border:1px solid rgba(212,175,55,0.3);color:#d4af37;border-radius:6px;padding:0.4rem 0.8rem;"><i class="fas fa-search"></i></button>
                <button type="button" class="btn btn-sm" id="adminEvtResetBtn" style="background:rgba(255,255,255,0.06);border:1px solid rgba(255,255,255,0.1);color:rgba(255,255,255,0.6);border-radius:6px;padding:0.4rem 0.8rem;display:{{ (q is not empty or type is not empty or paiement is not empty) ? 'inline-block' : 'none' }};" title="Reset"><i class="fas fa-times"></i></button>
            </div>
        </div>

        {# ── Responsive Table ── #}
        <div class="table-responsive">
            <table class="admin-table evt-table" id="eventsTable">
                <thead>
                    <tr>
                        <th class="th-check"><input type="checkbox" class="form-check-input" id="selectAllEvents"></th>
                        <th>ID</th>
                        <th data-sort-key="nom" style="cursor:pointer;">Nom <i class="fas fa-sort{{ sort == 'nom' ? (order == 'ASC' ? '-up' : '-down') : '' }} sort-icon" style="font-size:0.7rem;{{ sort == 'nom' ? 'color:#a855f7;' : 'opacity:0.4;' }}"></i></th>
                        <th data-sort-key="typeEvenement" style="cursor:pointer;">Type <i class="fas fa-sort{{ sort == 'typeEvenement' ? (order == 'ASC' ? '-up' : '-down') : '' }} sort-icon" style="font-size:0.7rem;{{ sort == 'typeEvenement' ? 'color:#a855f7;' : 'opacity:0.4;' }}"></i></th>
                        <th data-sort-key="nbrParticipant" style="cursor:pointer;">Participants <i class="fas fa-sort{{ sort == 'nbrParticipant' ? (order == 'ASC' ? '-up' : '-down') : '' }} sort-icon" style="font-size:0.7rem;{{ sort == 'nbrParticipant' ? 'color:#a855f7;' : 'opacity:0.4;' }}"></i></th>
                        <th data-sort-key="date" style="cursor:pointer;">Date <i class="fas fa-sort{{ sort == 'date' ? (order == 'ASC' ? '-up' : '-down') : '' }} sort-icon" style="font-size:0.7rem;{{ sort == 'date' ? 'color:#a855f7;' : 'opacity:0.4;' }}"></i></th>
                        <th data-sort-key="heure" style="cursor:pointer;">Heure <i class="fas fa-sort{{ sort == 'heure' ? (order == 'ASC' ? '-up' : '-down') : '' }} sort-icon" style="font-size:0.7rem;{{ sort == 'heure' ? 'color:#a855f7;' : 'opacity:0.4;' }}"></i></th>
                        <th data-sort-key="lieu" style="cursor:pointer;">Lieu <i class="fas fa-sort{{ sort == 'lieu' ? (order == 'ASC' ? '-up' : '-down') : '' }} sort-icon" style="font-size:0.7rem;{{ sort == 'lieu' ? 'color:#a855f7;' : 'opacity:0.4;' }}"></i></th>
                        <th data-sort-key="paiement" style="cursor:pointer;">Paiement <i class="fas fa-sort{{ sort == 'paiement' ? (order == 'ASC' ? '-up' : '-down') : '' }} sort-icon" style="font-size:0.7rem;{{ sort == 'paiement' ? 'color:#a855f7;' : 'opacity:0.4;' }}"></i></th>
                        <th class="th-actions">Actions</th>
                    </tr>
                </thead>
                <tbody id="eventsTableBody">

                    {% if evenements is empty %}
                        <tr>
                            <td colspan="10" class="text-center py-5">
                                <i class="fas fa-calendar-xmark d-block mb-2" style="font-size: 2rem; color: rgba(212,175,55,0.3);"></i>
                                <span style="color: rgba(255,255,255,0.4);">Aucun événement trouvé. <a href="#" onclick="document.getElementById('addEventBtn').click(); return false;" style="color: #d4af37;">Créer le premier</a></span>
                            </td>
                        </tr>
                    {% else %}
                        {% for evt in evenements %}
                        <tr data-event-id="{{ evt.id }}"
                            data-type="{{ evt.typeEvenement }}"
                            data-paiement="{{ evt.paiement ? 'true' : 'false' }}"
                            data-nom="{{ evt.nom }}"
                            data-date="{{ evt.date|date('Y-m-d') }}"
                            data-heure="{{ evt.heure|date('H:i') }}"
                            data-lieu="{{ evt.lieu }}"
                            data-description="{{ evt.description }}"
                            data-nbr-participant="{{ evt.nbrParticipant }}"
                            data-image="{{ evt.image ?? '' }}"
                            data-prix="{{ evt.prix ?? '' }}">
                            <td><input type="checkbox" class="form-check-input evt-check"></td>
                            <td class="evt-id">#EVT-{{ '%03d'|format(evt.id) }}</td>
                            <td>
                                <div class="evt-name-cell">
                                    {% if evt.image %}
                                        <img src="{{ asset('uploads/evenements/' ~ evt.image) }}" alt="{{ evt.nom }}" style="width: 36px; height: 36px; border-radius: 8px; object-fit: cover; border: 1px solid rgba(255,255,255,0.1);">
                                    {% else %}
                                        <div class="evt-icon-mini gold"><i class="fas fa-calendar-star"></i></div>
                                    {% endif %}
                                    <div>
                                        <span class="evt-name">{{ evt.nom }}</span>
                                        <span class="evt-desc-hint">{{ evt.description|length > 40 ? evt.description|slice(0, 40) ~ '…' : evt.description }}</span>
                                    </div>
                                </div>
                            </td>
                            <td><span class="type-badge type-{{ evt.typeEvenement|lower|replace({' ': '-', "'": ''}) }}">{{ evt.typeEvenement }}</span></td>
                            <td><span class="participant-count"><i class="fas fa-users me-1"></i>{{ evt.nbrParticipant }}</span></td>
                            <td><span class="evt-date"><i class="fas fa-calendar-day me-1 text-muted"></i>{{ evt.date|date('M d, Y') }}</span></td>
                            <td><span class="evt-time"><i class="fas fa-clock me-1 text-muted"></i>{{ evt.heure|date('H:i') }}</span></td>
                            <td><span class="evt-lieu"><i class="fas fa-map-marker-alt me-1 text-muted"></i>{{ evt.lieu }}</span></td>
                            <td>
                                {% if evt.paiement %}
                                    <span class="paiement-badge paid"><i class="fas fa-check-circle me-1"></i>{{ evt.prix ? evt.prix|number_format(2, ',', ' ') ~ ' €' : 'Paid' }}</span>
                                {% else %}
                                    <span class="paiement-badge free"><i class="fas fa-gift me-1"></i>Free</span>
                                {% endif %}
                            </td>
                            <td>
                                <div class="table-actions">
                                    <button type="button" class="table-action-btn view-evt-btn" title="View" data-event-id="{{ evt.id }}"><i class="fas fa-eye"></i></button>
                                    <button type="button" class="table-action-btn edit-evt-btn" title="Edit" data-event-id="{{ evt.id }}"><i class="fas fa-pen-to-square"></i></button>
                                    <button type="button" class="table-action-btn delete delete-evt-btn" title="Delete" data-event-id="{{ evt.id }}" data-event-name="{{ evt.nom }}" data-delete-url="{{ path('app_admin_evenement_delete', {id: evt.id}) }}"><i class="fas fa-trash-can"></i></button>
                                </div>
                            </td>
                        </tr>
                        {% endfor %}
                    {% endif %}

                </tbody>
            </table>
        </div>

        {# ── Table Footer / Pagination ── #}
        <div class="admin-table-footer">
            <div class="table-footer-info">
                Showing <strong>{{ evenements|length }}</strong> of <strong>{{ totalCount }}</strong> events
            </div>
            <nav aria-label="Events pagination">
                <ul class="pagination admin-pagination mb-0">
                    <li class="page-item disabled">
                        <a class="page-link" href="#" aria-label="Previous"><i class="fas fa-chevron-left"></i></a>
                    </li>
                    <li class="page-item active"><a class="page-link" href="#">1</a></li>
                    <li class="page-item"><a class="page-link" href="#">2</a></li>
                    <li class="page-item"><a class="page-link" href="#">3</a></li>
                    <li class="page-item"><a class="page-link" href="#">…</a></li>
                    <li class="page-item"><a class="page-link" href="#">27</a></li>
                    <li class="page-item">
                        <a class="page-link" href="#" aria-label="Next"><i class="fas fa-chevron-right"></i></a>
                    </li>
                </ul>
            </nav>
        </div>
    </div>


    {# ═══════════════════════════════════════════════════════════
       ADD / EDIT EVENT MODAL
       – Blurred backdrop (backdrop-filter: blur)
       – All required input fields
       – Paiement as toggle switch
    ═══════════════════════════════════════════════════════════ #}
    <div class="modal fade" id="eventModal" tabindex="-1" aria-labelledby="eventModalLabel" aria-hidden="true" data-bs-backdrop="static">
        <div class="modal-dialog modal-dialog-centered modal-lg">
            <div class="modal-content evt-modal-content">

                {# ── Modal Header ── #}
                <div class="modal-header evt-modal-header">
                    <div class="modal-header-icon evt-header-icon">
                        <i class="fas fa-calendar-plus" id="evtModalIcon"></i>
                    </div>
                    <div>
                        <h5 class="modal-title" id="eventModalLabel">Add Événement</h5>
                        <p class="modal-subtitle mb-0" id="evtModalSubtitle">Fill in the details to create a new event</p>
                    </div>
                    <button type="button" class="btn-close-modal" data-bs-dismiss="modal" aria-label="Close">
                        <i class="fas fa-times"></i>
                    </button>
                </div>

                {# ── Modal Body ── #}
                <div class="modal-body evt-modal-body">
                    <form id="eventForm" method="POST" action="{{ path('app_admin_evenement_store') }}" enctype="multipart/form-data" novalidate>
                        <input type="hidden" id="formEventId" name="event_id" value="">

                        <div class="row g-3">
                            {# ── ID Événement ── #}
                            <div class="col-md-4">
                                <div class="form-floating-custom">
                                    <label for="inputEvtId"><i class="fas fa-hashtag me-1 text-accent"></i> ID Événement</label>
                                    <input type="text" class="form-control modal-input" id="inputEvtId" placeholder="Auto-generated" readonly>
                                    <small class="form-hint">Auto-generated by system</small>
                                </div>
                            </div>

                            {# ── Nom ── #}
                            <div class="col-md-8">
                                <div class="form-floating-custom">
                                    <label for="inputEvtNom"><i class="fas fa-bookmark me-1 text-accent"></i> Nom <span class="required">*</span></label>
                                    <input type="text" class="form-control modal-input" id="inputEvtNom" name="nom" placeholder="Event name" required>
                                    <div class="invalid-feedback">Please enter the event name.</div>
                                </div>
                            </div>

                            {# ── Type Événement ── #}
                            <div class="col-md-6">
                                <div class="form-floating-custom">
                                    <label for="inputEvtType"><i class="fas fa-tags me-1 text-accent"></i> Type Événement <span class="required">*</span></label>
                                    <select class="form-select modal-input" id="inputEvtType" name="type_evenement" required>
                                        <option value="" disabled selected>Select event type…</option>
                                        {% for type in ['Concerts', 'Expositions d\'art', 'Festivals', 'Spectacles de danse', 'Théâtre', 'Tournois', 'Formations'] %}
                                            <option value="{{ type }}">{{ type }}</option>
                                        {% endfor %}
                                    </select>
                                    <div class="invalid-feedback">Please select an event type.</div>
                                </div>
                            </div>

                            {# ── Nbr Participants ── #}
                            <div class="col-md-6">
                                <div class="form-floating-custom">
                                    <label for="inputEvtParticipants"><i class="fas fa-users me-1 text-accent"></i> Nbr Participants <span class="required">*</span></label>
                                    <input type="number" class="form-control modal-input" id="inputEvtParticipants" name="nbr_participant" placeholder="0" min="1" required>
                                    <div class="invalid-feedback">Enter number of participants.</div>
                                </div>
                            </div>

                            {# ── Date ── #}
                            <div class="col-md-6">
                                <div class="form-floating-custom">
                                    <label for="inputEvtDate"><i class="fas fa-calendar-day me-1 text-accent"></i> Date <span class="required">*</span></label>
                                    <input type="date" class="form-control modal-input" id="inputEvtDate" name="date" required>
                                    <div class="invalid-feedback">Please select a date.</div>
                                </div>
                            </div>

                            {# ── Heure ── #}
                            <div class="col-md-6">
                                <div class="form-floating-custom">
                                    <label for="inputEvtHeure"><i class="fas fa-clock me-1 text-accent"></i> Heure <span class="required">*</span></label>
                                    <input type="time" class="form-control modal-input" id="inputEvtHeure" name="heure" required>
                                    <div class="invalid-feedback">Please select a time.</div>
                                </div>
                            </div>

                            {# ── Lieu ── #}
                            <div class="col-md-12">
                                <div class="form-floating-custom">
                                    <label for="inputEvtLieu"><i class="fas fa-map-marker-alt me-1 text-accent"></i> Lieu <span class="required">*</span></label>
                                    <input type="text" class="form-control modal-input" id="inputEvtLieu" name="lieu" placeholder="Event venue" required>
                                    <div class="invalid-feedback">Please enter the location.</div>
                                </div>
                            </div>

                            {# ── Description ── #}
                            <div class="col-md-12">
                                <div class="form-floating-custom">
                                    <label for="inputEvtDesc"><i class="fas fa-align-left me-1 text-accent"></i> Description</label>
                                    <button type="button" id="btnGenerateDesc" style="
                                        background: linear-gradient(135deg, #b8860b, #d4a017);
                                        border: none;
                                        color: #1a1a2e;
                                        font-weight: 700;
                                        padding: 6px 14px;
                                        border-radius: 8px;
                                        margin-bottom: 8px;
                                        cursor: pointer;
                                        font-size: 0.8rem;
                                        display: inline-block;
                                        margin-left: 10px;
                                        transition: all 0.3s;
                                    " onmouseover="this.style.opacity='0.85'" onmouseout="this.style.opacity='1'">
                                        <i class="fas fa-robot me-1"></i>Générer avec IA
                                    </button>
                                    <textarea class="form-control modal-input evt-textarea" id="inputEvtDesc" name="description" rows="3" placeholder="Write a short description of the event…"></textarea>
                                </div>
                            </div>

                            {# ── Paiement Toggle ── #}
                            <div class="col-md-12">
                                <div class="paiement-toggle-wrap">
                                    <div class="paiement-toggle-label">
                                        <i class="fas fa-credit-card me-2 text-accent"></i>
                                        <div>
                                            <span class="ptl-title">Paiement Required</span>
                                            <span class="ptl-desc">Toggle on if this is a paid event</span>
                                        </div>
                                    </div>
                                    <label class="toggle-switch">
                                        <input type="checkbox" id="inputEvtPaiement" name="paiement">
                                        <span class="toggle-slider"></span>
                                        <span class="toggle-label-text" id="paiementStatusText">Free</span>
                                    </label>
                                </div>
                            </div>

                            {# ── Prix (only when paid) ── #}
                            <div class="col-md-6" id="prixFieldGroup" style="display:none;">
                                <div class="form-floating-custom">
                                    <label for="inputEvtPrix"><i class="fas fa-euro-sign me-1 text-accent"></i> Prix par place (€) <span class="required">*</span></label>
                                    <input type="number" class="form-control modal-input" id="inputEvtPrix" name="prix" placeholder="0.00" min="0.01" step="0.01">
                                    <small class="form-hint">Prix unitaire par place en euros</small>
                                    <div class="invalid-feedback">Please enter the price per place.</div>
                                </div>
                            </div>

                            {# ── Image Upload ── #}
                            <div class="col-md-12">
                                <div class="form-floating-custom">
                                    <label for="inputEvtImage"><i class="fas fa-image me-1 text-accent"></i> Image</label>
                                    <input type="file" class="form-control modal-input" id="inputEvtImage" name="image" accept="image/*">
                                    <small class="form-hint">JPG, PNG, GIF, WEBP. Max 5 Mo.</small>
                                    <div id="currentImagePreview" style="margin-top: 0.5rem; display: none;">
                                        <img id="currentImageImg" src="" alt="Current" style="max-width: 120px; max-height: 80px; border-radius: 6px; border: 1px solid rgba(255,255,255,0.1);">
                                        <small class="d-block" style="color: rgba(255,255,255,0.4); font-size: 0.75rem; margin-top: 0.25rem;">Image actuelle</small>
                                    </div>
                                </div>
                            </div>
                        </div>

                    </form>
                </div>

                {# ── Modal Footer ── #}
                <div class="modal-footer evt-modal-footer">
