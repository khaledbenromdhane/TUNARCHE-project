        </div>

        <div class="toast admin-toast toast-error" id="evtToastError" role="alert" aria-live="assertive" aria-atomic="true" data-bs-autohide="true" data-bs-delay="5000">
            <div class="toast-body-custom">
                <div class="toast-icon"><i class="fas fa-times-circle"></i></div>
                <div class="toast-content">
                    <strong class="toast-title">Error</strong>
                    <p class="toast-message mb-0" id="evtToastErrorMsg">Something went wrong.</p>
                </div>
                <button type="button" class="btn-close-toast" data-bs-dismiss="toast" aria-label="Close"><i class="fas fa-times"></i></button>
            </div>
            <div class="toast-progress"><div class="toast-progress-bar error"></div></div>
        </div>

        <div class="toast admin-toast toast-warning" id="evtToastWarning" role="alert" aria-live="assertive" aria-atomic="true" data-bs-autohide="true" data-bs-delay="4000">
