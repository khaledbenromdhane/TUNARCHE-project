{# ═══════════════════════════════════════════════════════════════
   Admin Événements Management Page
   Route: /admin/evenement
   Features:
     – Styled event listing table with all required columns
     – Add/Edit event modal with blurred backdrop
     – Payment toggle switch (true/false)
     – Bootstrap Toasts for success/error notifications
     – Custom animated alert for delete confirmation
     – Fully responsive, luxury dark + gold/purple theme
═══════════════════════════════════════════════════════════════ #}
{% extends 'admin/base.html.twig' %}

{% block title %}Événements Management{% endblock %}

{% block page_title %}Événements{% endblock %}

{% block breadcrumb %}
    <li class="breadcrumb-item"><a href="{{ path('app_admin_dashboard') }}">Dashboard</a></li>
    <li class="breadcrumb-item active" aria-current="page">Événements</li>
{% endblock %}

{% block page_actions %}
    <div class="d-flex gap-2 flex-wrap">
        <button class="btn btn-admin-outline btn-sm" id="exportEventsBtn">
            <i class="fas fa-file-export me-1"></i> Export
        </button>
        <button class="btn btn-admin-primary" data-bs-toggle="modal" data-bs-target="#eventModal" id="addEventBtn">
            <i class="fas fa-calendar-plus me-1"></i> Add Événement
        </button>
    </div>
{% endblock %}

{% block stylesheets %}
    <link href="{{ asset('assets/css/admin-events.css') }}" rel="stylesheet">
{% endblock %}

{% block body %}

