                <div class="toast-icon"><i class="fas fa-exclamation-circle"></i></div>
                <div class="toast-content">
                    <strong class="toast-title">Warning</strong>
                    <p class="toast-message mb-0" id="evtToastWarningMsg">Please check your input.</p>
                </div>
                <button type="button" class="btn-close-toast" data-bs-dismiss="toast" aria-label="Close"><i class="fas fa-times"></i></button>
            </div>
            <div class="toast-progress"><div class="toast-progress-bar warning"></div></div>
        </div>

    </div>

{% endblock %}

{% block javascripts %}
    <script src="{{ asset('assets/js/admin-events.js') }}"></script>
    <script>
    document.getElementById('btnGenerateDesc').addEventListener('click', function() {
        var nom  = document.getElementById('inputEvtNom').value;
        var type = document.getElementById('inputEvtType').value;

        if (!nom) { alert('Entrez le nom de l\'événement d\'abord !'); return; }

        var btn = this;
        btn.innerHTML = '<i class="fas fa-spinner fa-spin me-1"></i>Génération...';
        btn.disabled = true;
        btn.style.opacity = '0.7';

        var formData = new FormData();
        formData.append('nom', nom);
        formData.append('type', type);

        fetch('{{ path("app_admin_generate_description") }}', {
            method: 'POST',
            body: formData
        })
        .then(function(r) { return r.json(); })
        .then(function(data) {
            if (data.success) {
                document.getElementById('inputEvtDesc').value = data.description;
                btn.innerHTML = '<i class="fas fa-check me-1"></i>Généré !';
                btn.style.background = 'linear-gradient(135deg, #28a745, #20c997)';
                btn.style.opacity = '1';
                setTimeout(function() {
                    btn.innerHTML = '<i class="fas fa-robot me-1"></i>Générer avec IA';
                    btn.style.background = 'linear-gradient(135deg, #b8860b, #d4a017)';
                    btn.disabled = false;
                }, 3000);
            } else {
                btn.innerHTML = '<i class="fas fa-robot me-1"></i>Générer avec IA';
                btn.disabled = false;
                btn.style.opacity = '1';
                alert('Erreur: ' + (data.message || 'Échec de la génération'));
            }
        })
        .catch(function(err) {
            btn.innerHTML = '<i class="fas fa-robot me-1"></i>Générer avec IA';
            btn.disabled = false;
            btn.style.opacity = '1';
            alert('Erreur réseau');
        });
    });
    </script>
{% endblock %}
