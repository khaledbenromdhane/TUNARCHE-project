    {# ═══════════════════════════════════════════════════════════
       ADD / EDIT EVENT MODAL
       – Blurred backdrop (backdrop-filter: blur)
       – All required input fields
       – Paiement as toggle switch
    ═══════════════════════════════════════════════════════════ #}
    <div class="modal fade" id="eventModal" tabindex="-1" aria-labelledby="eventModalLabel" aria-hidden="true" data-bs-backdrop="static">
        <div class="modal-dialog modal-dialog-centered modal-lg">
            <div class="modal-content evt-modal-content">

                {# ── Modal Header ── #}
                <div class="modal-header evt-modal-header">
                    <div class="modal-header-icon evt-header-icon">
                        <i class="fas fa-calendar-plus" id="evtModalIcon"></i>
                    </div>
                    <div>
                        <h5 class="modal-title" id="eventModalLabel">Add Événement</h5>
                        <p class="modal-subtitle mb-0" id="evtModalSubtitle">Fill in the details to create a new event</p>
                    </div>
                    <button type="button" class="btn-close-modal" data-bs-dismiss="modal" aria-label="Close">
                        <i class="fas fa-times"></i>
                    </button>
                </div>

                {# ── Modal Body ── #}
                <div class="modal-body evt-modal-body">
                    <form id="eventForm" novalidate>
                        <input type="hidden" id="formEventId" value="">

                        <div class="row g-3">
                            {# ── ID Événement ── #}
                            <div class="col-md-4">
                                <div class="form-floating-custom">
                                    <label for="inputEvtId"><i class="fas fa-hashtag me-1 text-accent"></i> ID Événement</label>
                                    <input type="text" class="form-control modal-input" id="inputEvtId" placeholder="Auto-generated" readonly>
                                    <small class="form-hint">Auto-generated by system</small>
                                </div>
                            </div>

                            {# ── Nom ── #}
                            <div class="col-md-8">
                                <div class="form-floating-custom">
                                    <label for="inputEvtNom"><i class="fas fa-bookmark me-1 text-accent"></i> Nom <span class="required">*</span></label>
                                    <input type="text" class="form-control modal-input" id="inputEvtNom" placeholder="Event name" required>
                                    <div class="invalid-feedback">Please enter the event name.</div>
                                </div>
                            </div>

                            {# ── Type Événement ── #}
                            <div class="col-md-6">
                                <div class="form-floating-custom">
                                    <label for="inputEvtType"><i class="fas fa-tags me-1 text-accent"></i> Type Événement <span class="required">*</span></label>
                                    <select class="form-select modal-input" id="inputEvtType" required>
                                        <option value="" disabled selected>Select event type…</option>
                                        <option value="exposition">Exposition</option>
                                        <option value="concert">Concert</option>
                                        <option value="gala">Gala</option>
                                        <option value="atelier">Atelier</option>
                                        <option value="conference">Conférence</option>
                                        <option value="festival">Festival</option>
                                    </select>
                                    <div class="invalid-feedback">Please select an event type.</div>
                                </div>
                            </div>

                            {# ── Nbr Participants ── #}
                            <div class="col-md-6">
                                <div class="form-floating-custom">
                                    <label for="inputEvtParticipants"><i class="fas fa-users me-1 text-accent"></i> Nbr Participants <span class="required">*</span></label>
                                    <input type="number" class="form-control modal-input" id="inputEvtParticipants" placeholder="0" min="1" required>
                                    <div class="invalid-feedback">Enter number of participants.</div>
                                </div>
                            </div>

                            {# ── Date ── #}
                            <div class="col-md-6">
                                <div class="form-floating-custom">
                                    <label for="inputEvtDate"><i class="fas fa-calendar-day me-1 text-accent"></i> Date <span class="required">*</span></label>
                                    <input type="date" class="form-control modal-input" id="inputEvtDate" required>
                                    <div class="invalid-feedback">Please select a date.</div>
                                </div>
                            </div>

                            {# ── Heure ── #}
                            <div class="col-md-6">
                                <div class="form-floating-custom">
                                    <label for="inputEvtHeure"><i class="fas fa-clock me-1 text-accent"></i> Heure <span class="required">*</span></label>
                                    <input type="time" class="form-control modal-input" id="inputEvtHeure" required>
                                    <div class="invalid-feedback">Please select a time.</div>
                                </div>
                            </div>

                            {# ── Lieu ── #}
                            <div class="col-md-12">
                                <div class="form-floating-custom">
                                    <label for="inputEvtLieu"><i class="fas fa-map-marker-alt me-1 text-accent"></i> Lieu <span class="required">*</span></label>
                                    <input type="text" class="form-control modal-input" id="inputEvtLieu" placeholder="Event venue" required>
                                    <div class="invalid-feedback">Please enter the location.</div>
                                </div>
                            </div>

                            {# ── Description ── #}
                            <div class="col-md-12">
                                <div class="form-floating-custom">
                                    <label for="inputEvtDesc"><i class="fas fa-align-left me-1 text-accent"></i> Description</label>
                                    <textarea class="form-control modal-input evt-textarea" id="inputEvtDesc" rows="3" placeholder="Write a short description of the event…"></textarea>
                                </div>
                            </div>

                            {# ── Paiement Toggle ── #}
                            <div class="col-md-12">
                                <div class="paiement-toggle-wrap">
                                    <div class="paiement-toggle-label">
                                        <i class="fas fa-credit-card me-2 text-accent"></i>
                                        <div>
                                            <span class="ptl-title">Paiement Required</span>
                                            <span class="ptl-desc">Toggle on if this is a paid event</span>
                                        </div>
                                    </div>
                                    <label class="toggle-switch">
                                        <input type="checkbox" id="inputEvtPaiement">
                                        <span class="toggle-slider"></span>
                                        <span class="toggle-label-text" id="paiementStatusText">Free</span>
                                    </label>
                                </div>
                            </div>
                        </div>

                    </form>
                </div>

                {# ── Modal Footer ── #}
                <div class="modal-footer evt-modal-footer">
                    <button type="button" class="btn btn-modal-cancel" data-bs-dismiss="modal">
                        <i class="fas fa-times me-1"></i> Cancel
                    </button>
                    <button type="button" class="btn btn-modal-save" id="saveEventBtn">
                        <i class="fas fa-check me-1"></i> <span id="saveEventBtnText">Save Event</span>
                    </button>
                </div>

            </div>
        </div>
    </div>


    {# ═══════════════════════════════════════════════════════════
       CUSTOM DELETE CONFIRMATION ALERT
    ═══════════════════════════════════════════════════════════ #}
    <div class="custom-alert-overlay" id="deleteEvtAlertOverlay">
        <div class="custom-alert-box" id="deleteEvtAlertBox">
            <div class="alert-icon-wrap danger-evt">
                <i class="fas fa-calendar-xmark"></i>
            </div>
            <h4 class="alert-title">Delete Event?</h4>
            <p class="alert-message">Are you sure you want to delete <strong id="deleteEvtName"></strong>? This action cannot be undone.</p>
            <div class="alert-actions">
                <button class="btn btn-alert-cancel" id="cancelEvtDeleteBtn">
                    <i class="fas fa-times me-1"></i> Cancel
                </button>
                <button class="btn btn-alert-confirm" id="confirmEvtDeleteBtn">
                    <i class="fas fa-trash-can me-1"></i> Delete
                </button>
            </div>
        </div>
    </div>


    {# ═══════════════════════════════════════════════════════════
       TOAST NOTIFICATIONS
    ═══════════════════════════════════════════════════════════ #}
    <div class="toast-container position-fixed top-0 end-0 p-3" id="evtToastContainer" style="z-index: 1090;">

        <div class="toast admin-toast toast-success" id="evtToastSuccess" role="alert" aria-live="assertive" aria-atomic="true" data-bs-autohide="true" data-bs-delay="4000">
            <div class="toast-body-custom">
                <div class="toast-icon"><i class="fas fa-check-circle"></i></div>
                <div class="toast-content">
                    <strong class="toast-title">Success</strong>
                    <p class="toast-message mb-0" id="evtToastSuccessMsg">Operation completed successfully.</p>
                </div>
                <button type="button" class="btn-close-toast" data-bs-dismiss="toast" aria-label="Close"><i class="fas fa-times"></i></button>
            </div>
            <div class="toast-progress"><div class="toast-progress-bar success"></div></div>
        </div>

        <div class="toast admin-toast toast-error" id="evtToastError" role="alert" aria-live="assertive" aria-atomic="true" data-bs-autohide="true" data-bs-delay="5000">
            <div class="toast-body-custom">
                <div class="toast-icon"><i class="fas fa-times-circle"></i></div>
                <div class="toast-content">
                    <strong class="toast-title">Error</strong>
                    <p class="toast-message mb-0" id="evtToastErrorMsg">Something went wrong.</p>
                </div>
                <button type="button" class="btn-close-toast" data-bs-dismiss="toast" aria-label="Close"><i class="fas fa-times"></i></button>
            </div>
            <div class="toast-progress"><div class="toast-progress-bar error"></div></div>
        </div>

        <div class="toast admin-toast toast-warning" id="evtToastWarning" role="alert" aria-live="assertive" aria-atomic="true" data-bs-autohide="true" data-bs-delay="4000">
            <div class="toast-body-custom">
                <div class="toast-icon"><i class="fas fa-exclamation-circle"></i></div>
                <div class="toast-content">
                    <strong class="toast-title">Warning</strong>
                    <p class="toast-message mb-0" id="evtToastWarningMsg">Please check your input.</p>
                </div>
                <button type="button" class="btn-close-toast" data-bs-dismiss="toast" aria-label="Close"><i class="fas fa-times"></i></button>
            </div>
            <div class="toast-progress"><div class="toast-progress-bar warning"></div></div>
        </div>

    </div>

{% endblock %}

{% block javascripts %}
    <script src="{{ asset('assets/js/admin-events.js') }}"></script>
{% endblock %}
