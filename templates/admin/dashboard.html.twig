{# ═══════════════════════════════════════════════════════════════
   Admin Dashboard – Main overview page
   Extends: admin/base.html.twig
   Contains: Stat cards, recent data table, quick actions
═══════════════════════════════════════════════════════════════ #}
{% extends 'admin/base.html.twig' %}

{% block title %}Dashboard{% endblock %}

{% block page_title %}Dashboard{% endblock %}

{% block breadcrumb %}
    <li class="breadcrumb-item active" aria-current="page">Overview</li>
{% endblock %}

{% block page_actions %}
    <div class="d-flex gap-2">
        <button class="btn btn-admin-outline">
            <i class="fas fa-download me-1"></i> Export
        </button>
        <button class="btn btn-admin-primary">
            <i class="fas fa-plus me-1"></i> Create Event
        </button>
    </div>
{% endblock %}

{% block body %}

    {# ═══════════════════════════════════════════════════════════
       STATISTICS CARDS ROW
       – Total Users, Events, Blogs, Revenue
    ═══════════════════════════════════════════════════════════ #}
    <div class="row g-4 mb-4">

        {# ── Total Users ── #}
        <div class="col-xl-3 col-lg-6 col-md-6 col-sm-6">
            <div class="stat-card animate-in">
                <div class="stat-card-shimmer"></div>
                <div class="stat-card-header">
                    <div class="stat-card-icon gold">
                        <i class="fas fa-users"></i>
                    </div>
                    <span class="stat-card-trend up">
                        <i class="fas fa-arrow-up me-1"></i>12.5%
                    </span>
                </div>
                <div class="stat-card-value" data-counter="2486">0</div>
                <div class="stat-card-label">Total Users</div>
            </div>
        </div>

        {# ── Total Events ── #}
        <div class="col-xl-3 col-lg-6 col-md-6 col-sm-6">
            <div class="stat-card animate-in">
                <div class="stat-card-shimmer"></div>
                <div class="stat-card-header">
                    <div class="stat-card-icon purple">
                        <i class="fas fa-calendar-alt"></i>
                    </div>
                    <span class="stat-card-trend up">
                        <i class="fas fa-arrow-up me-1"></i>8.3%
                    </span>
                </div>
                <div class="stat-card-value" data-counter="184">0</div>
                <div class="stat-card-label">Total Events</div>
            </div>
        </div>

        {# ── Total Blogs ── #}
        <div class="col-xl-3 col-lg-6 col-md-6 col-sm-6">
            <div class="stat-card animate-in">
                <div class="stat-card-shimmer"></div>
                <div class="stat-card-header">
                    <div class="stat-card-icon teal">
                        <i class="fas fa-feather-alt"></i>
                    </div>
                    <span class="stat-card-trend up">
                        <i class="fas fa-arrow-up me-1"></i>23.1%
                    </span>
                </div>
                <div class="stat-card-value" data-counter="539">0</div>
                <div class="stat-card-label">Blog Articles</div>
            </div>
        </div>

        {# ── Revenue ── #}
        <div class="col-xl-3 col-lg-6 col-md-6 col-sm-6">
            <div class="stat-card animate-in">
                <div class="stat-card-shimmer"></div>
                <div class="stat-card-header">
                    <div class="stat-card-icon gold">
                        <i class="fas fa-coins"></i>
                    </div>
                    <span class="stat-card-trend down">
                        <i class="fas fa-arrow-down me-1"></i>3.2%
                    </span>
                </div>
                <div class="stat-card-value">$<span data-counter="48250">0</span></div>
                <div class="stat-card-label">Total Revenue</div>
            </div>
        </div>

    </div>


