{% extends 'admin/base.html.twig' %}

{% block title %}Galeries{% endblock %}
{% block page_title %}Galeries{% endblock %}

{% block breadcrumb %}
    <li class="breadcrumb-item"><a href="{{ path('app_admin_dashboard') }}">Dashboard</a></li>
    <li class="breadcrumb-item active" aria-current="page">Galeries</li>
{% endblock %}

{% block page_actions %}
    <a href="{{ path('app_admin_galerie_new') }}" class="btn btn-admin-primary">
        <i class="fas fa-plus me-1"></i> Ajouter une galerie
    </a>
{% endblock %}

{% block body %}
    <div class="admin-table-card animate-in" id="galerie-list-card">
        <div class="admin-table-header d-flex flex-wrap align-items-center justify-content-between gap-3">
            <h3 class="admin-table-title mb-0"><i class="fas fa-building-columns me-2 text-accent"></i>Liste des galeries</h3>
            <div class="d-flex flex-wrap align-items-center gap-2">
                <div class="input-group input-group-sm" style="max-width: 220px;">
                    <span class="input-group-text"><i class="fas fa-search"></i></span>
                    <input type="text" class="form-control form-control-sm" id="galerie-search" placeholder="Rechercher (nom, catégorie)..." autocomplete="off">
                </div>
                <select class="form-select form-select-sm" id="galerie-sort" style="width: auto;">
                    <option value="">Tri par défaut</option>
                    <option value="nom">Nom</option>
                    <option value="categorie">Catégorie</option>
                    <option value="nbOeuvresDispo">Nb œuvres</option>
                    <option value="nbEmployes">Nb employés</option>
                    <option value="id">ID</option>
                </select>
                <select class="form-select form-select-sm" id="galerie-order" style="width: auto;">
                    <option value="ASC">Croissant</option>
                    <option value="DESC">Décroissant</option>
                </select>
                <select class="form-select form-select-sm" id="galerie-categorie" style="width: auto;">
                    <option value="">Toutes les catégories</option>
                    {% for cat in categories %}
                        <option value="{{ cat|e('html_attr') }}">{{ cat }}</option>
                    {% endfor %}
                </select>
            </div>
        </div>
        <div class="table-responsive position-relative">
            <div class="admin-list-loader position-absolute top-0 start-0 end-0 bottom-0 bg-dark bg-opacity-25 d-none d-flex align-items-center justify-content-center" style="min-height: 120px; z-index: 5;">
                <div class="spinner-border text-light" role="status"><span class="visually-hidden">Chargement...</span></div>
            </div>
            <table class="admin-table">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Catégorie</th>
                        <th>Nom</th>
                        <th>Nb œuvres dispo</th>
                        <th>Artistes</th>
                        <th>Nb employés</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody id="galerie-list-body">
                    {% include 'admin/categorie/_list_rows.html.twig' %}
                </tbody>
            </table>
        </div>
    </div>

    {% for message in app.flashes('success') %}
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            {{ message }}
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    {% endfor %}

    <script>
    (function() {
        var url = "{{ path('app_admin_galerie_index')|e('js') }}";
        var card = document.getElementById('galerie-list-card');
        var tbody = document.getElementById('galerie-list-body');
        var searchEl = document.getElementById('galerie-search');
        var sortEl = document.getElementById('galerie-sort');
        var orderEl = document.getElementById('galerie-order');
        var categorieEl = document.getElementById('galerie-categorie');
        var loader = card ? card.querySelector('.admin-list-loader') : null;
        var timeout = null;

        function buildUrl() {
            var params = new URLSearchParams();
            var q = (searchEl && searchEl.value) ? searchEl.value.trim() : '';
            params.set('q', q);
            if (sortEl && sortEl.value) params.set('sort', sortEl.value);
            if (orderEl && orderEl.value) params.set('order', orderEl.value);
            if (categorieEl && categorieEl.value) params.set('categorie', categorieEl.value);
            return url + (url.indexOf('?') >= 0 ? '&' : '?') + params.toString();
        }

        function load() {
            if (!tbody) return;
            if (loader) loader.classList.remove('d-none');
            fetch(buildUrl(), {
                method: 'GET',
                headers: { 'X-Requested-With': 'XMLHttpRequest', 'Accept': 'application/json' }
            }).then(function(r) {
                if (!r.ok) throw new Error(r.status);
                return r.json();
            }).then(function(data) {
                if (data.html !== undefined) tbody.innerHTML = data.html;
            }).catch(function() {
                tbody.innerHTML = '<tr><td colspan="7" class="text-center text-danger py-3">Erreur de chargement.</td></tr>';
            }).finally(function() {
                if (loader) loader.classList.add('d-none');
            });
        }

        function schedule() {
            clearTimeout(timeout);
            timeout = setTimeout(load, 300);
        }

        if (searchEl) { searchEl.addEventListener('input', schedule); searchEl.addEventListener('keyup', schedule); }
        if (sortEl) sortEl.addEventListener('change', load);
        if (orderEl) orderEl.addEventListener('change', load);
        if (categorieEl) categorieEl.addEventListener('change', load);
    })();
    </script>
{% endblock %}
