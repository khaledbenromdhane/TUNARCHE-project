<div id="oeuvre-form-frame" class="admin-table-card animate-in">
    <div class="admin-table-header">
        <h3 class="admin-table-title">{{ is_edit ? 'Modifier l\'œuvre' : 'Créer une œuvre' }}</h3>
    </div>
    <div class="p-4">
        {{ form_start(form, { attr: { novalidate: 'novalidate', 'data-ajax-form': 'oeuvre' } }) }}

        {# Identification principale #}
        <div class="mb-4">
            <h6 class="text-muted text-uppercase small mb-3"><i class="fas fa-palette me-1"></i> Identification</h6>
            <div class="row g-3">
                <div class="col-12">{{ form_row(form.titre) }}</div>
                <div class="col-md-6">{{ form_row(form.artiste) }}</div>
                <div class="col-md-6">{{ form_row(form.galerie) }}</div>
            </div>
        </div>

        {# Caractéristiques #}
        <div class="mb-4">
            <h6 class="text-muted text-uppercase small mb-3"><i class="fas fa-info-circle me-1"></i> Caractéristiques</h6>
            <div class="row g-3">
                <div class="col-md-4">{{ form_row(form.anneeRealisation) }}</div>
                <div class="col-md-4">{{ form_row(form.etat) }}</div>
                <div class="col-md-4">{{ form_row(form.prix) }}</div>
                <div class="col-12">{{ form_row(form.statut) }}</div>
            </div>
        </div>

        {# Visuel et description #}
        <div class="mb-4">
            <h6 class="text-muted text-uppercase small mb-3"><i class="fas fa-image me-1"></i> Visuel & description</h6>
            <div class="row g-3">
                <div class="col-md-12 col-lg-5">{{ form_row(form.imageFile) }}</div>
                <div class="col-md-12 col-lg-7">{{ form_row(form.description) }}</div>
            </div>
        </div>

        <div class="mt-4 pt-3 border-top">
            <button type="submit" class="btn btn-admin-primary">
                <i class="fas fa-check me-1"></i> {{ is_edit ? 'Enregistrer' : 'Créer' }}
            </button>
            <a href="{{ path('app_admin_oeuvre_index') }}" class="btn btn-admin-outline ms-2">Annuler</a>
        </div>
        {{ form_end(form) }}
    </div>
</div>
