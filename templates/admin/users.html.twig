{# ═══════════════════════════════════════════════════════════════
   Admin Users Management Page
   Route: /admin/user
   Features:
     – Styled user listing table with all required columns
     – Add/Edit user modal with blurred backdrop
     – Bootstrap Toasts for success/error notifications
     – Custom animated alert confirmations (delete)
     – Fully responsive design matching the luxury theme
═══════════════════════════════════════════════════════════════ #}
{% extends 'admin/base.html.twig' %}

{% block title %}Users Management{% endblock %}

{% block page_title %}Users Management{% endblock %}

{% block breadcrumb %}
    <li class="breadcrumb-item"><a href="{{ path('app_admin_dashboard') }}">Dashboard</a></li>
    <li class="breadcrumb-item active" aria-current="page">Users</li>
{% endblock %}

{% block page_actions %}
    <div class="d-flex gap-2 flex-wrap">
        <button class="btn btn-admin-outline btn-sm" id="exportUsersBtn">
            <i class="fas fa-file-export me-1"></i> Export
        </button>
        <button class="btn btn-admin-primary" data-bs-toggle="modal" data-bs-target="#userModal" id="addUserBtn">
            <i class="fas fa-user-plus me-1"></i> Add User
        </button>
    </div>
{% endblock %}

{% block stylesheets %}
    <link href="{{ asset('assets/css/admin-users.css') }}" rel="stylesheet">
{% endblock %}

