{% extends 'admin/base.html.twig' %}

{% block title %}Publications Management{% endblock %}

{% block page_title %}Publications{% endblock %}

{% block breadcrumb %}
    <li class="breadcrumb-item"><a href="{{ path('app_admin_dashboard') }}">Dashboard</a></li>
    <li class="breadcrumb-item active" aria-current="page">Publications</li>
{% endblock %}

{% block page_actions %}
    <button class="btn btn-admin-primary" id="addPublicationBtn">
        <i class="fas fa-plus-circle me-2"></i>Add Publication
    </button>
{% endblock %}

{% block stylesheets %}
    <link href="{{ asset('assets/css/admin-publications.css') }}" rel="stylesheet">
{% endblock %}

{% block body %}

    {# ═══════════════════════════════════════════════════════════
       PUBLICATION STAT SUMMARY CARDS
    ═══════════════════════════════════════════════════════════ #}
    <div class="row g-3 mb-4">
        <div class="col-xl-3 col-lg-6 col-md-6 col-sm-6">
            <div class="pub-stat-card animate-in">
                <div class="pub-stat-icon gold">
                    <i class="fas fa-file-alt"></i>
                </div>
                <div class="pub-stat-info">
                    <span class="pub-stat-value">{{ totalCount }}</span>
                    <span class="pub-stat-label">Total Publications</span>
                </div>
            </div>
        </div>
        <div class="col-xl-3 col-lg-6 col-md-6 col-sm-6">
            <div class="pub-stat-card animate-in">
                <div class="pub-stat-icon teal">
                    <i class="fas fa-calendar-check"></i>
                </div>
                <div class="pub-stat-info">
                    <span class="pub-stat-value">{{ thisMonthCount }}</span>
                    <span class="pub-stat-label">This Month</span>
                </div>
            </div>
        </div>
        <div class="col-xl-3 col-lg-6 col-md-6 col-sm-6">
            <div class="pub-stat-card animate-in">
                <div class="pub-stat-icon purple">
                    <i class="fas fa-images"></i>
                </div>
                <div class="pub-stat-info">
                    <span class="pub-stat-value">{{ withImagesCount }}</span>
                    <span class="pub-stat-label">With Images</span>
                </div>
            </div>
        </div>
        <div class="col-xl-3 col-lg-6 col-md-6 col-sm-6">
            <div class="pub-stat-card animate-in">
                <div class="pub-stat-icon pink">
                    <i class="fas fa-thumbs-up"></i>
                </div>
                <div class="pub-stat-info">
                    {% set totalLikes = 0 %}
                    {% for pub in publications %}
                        {% set totalLikes = totalLikes + (pub.nbLikes ?? 0) %}
                    {% endfor %}
                    <span class="pub-stat-value">{{ totalLikes }}</span>
                    <span class="pub-stat-label">Total Likes</span>
                </div>
            </div>
        </div>
    </div>

    {# ═══════════════════════════════════════════════════════════
       PUBLICATIONS TABLE CARD
    ═══════════════════════════════════════════════════════════ #}
    <div class="admin-table-card pub-table-card animate-in">

        {# ── Table Header with Filters ── #}
        <div class="admin-table-header">
            <div class="d-flex align-items-center gap-2">
                <h3 class="admin-table-title mb-0">
                    <i class="fas fa-newspaper me-2 text-accent"></i>All Publications
                </h3>
                <span class="pub-count-badge">{{ totalCount }}</span>
            </div>
            <div class="admin-table-controls d-flex flex-wrap gap-2 align-items-center mt-3 mt-md-0">
                <div class="pub-search-wrap">
                    <i class="fas fa-search"></i>
                    <input type="text" class="form-control admin-form-control" id="searchPublication" placeholder="Search publications...">
                </div>
            </div>
        </div>

        {# ── Responsive Table ── #}
        <div class="table-responsive">
            <table class="admin-table pub-table">
                <thead>
                    <tr>
                        <th class="th-check"><input type="checkbox" class="form-check-input" id="selectAllPublications"></th>
                        <th class="sortable" data-column="id">ID <i class="fas fa-sort"></i></th>
                        <th>Image</th>
                        <th class="sortable" data-column="titre">Title <i class="fas fa-sort"></i></th>
                        <th>Description</th>
                        <th class="sortable" data-column="date">Date <i class="fas fa-sort"></i></th>
                        <th class="th-actions">Actions</th>
                    </tr>
                </thead>
                <tbody id="publicationsTableBody">
                    {% if publications is empty %}
                        <tr>
                            <td colspan="7" class="text-center py-5">
                                <i class="fas fa-inbox fa-3x text-muted mb-3 d-block"></i>
                                <p class="text-muted">No publications found. Click "Add Publication" to create one.</p>
                            </td>
                        </tr>
                    {% else %}
                        {% for pub in publications %}
                        <tr data-id="{{ pub.idPublication }}" data-description="{{ pub.description }}">
                            <td><input type="checkbox" class="form-check-input pub-checkbox" value="{{ pub.idPublication }}"></td>
                            <td><span class="pub-id">{{ pub.idPublication }}</span></td>
                            <td>
                                <div class="pub-image-container">
                                    {% if pub.image and pub.image != 'default.jpg' %}
                                        <img src="/uploads/{{ pub.image }}" alt="{{ pub.titre }}" class="pub-thumbnail">
                                    {% else %}
                                        <div class="pub-thumbnail-placeholder"><i class="fas fa-image"></i></div>
                                    {% endif %}
                                </div>
                            </td>
                            <td>
                                <div class="pub-title-cell">
                                    <i class="fas fa-newspaper text-accent me-2"></i>
                                    <span class="pub-title">{{ pub.titre }}</span>
                                </div>
                            </td>
                            <td><span class="pub-description">{{ pub.description|length > 80 ? pub.description|slice(0, 80) ~ '...' : pub.description }}</span></td>
                            <td>
                                <div class="pub-date">
                                    <i class="fas fa-calendar me-1"></i>
                                    <span>{{ pub.dateAct ? pub.dateAct|date('Y-m-d') : 'N/A' }}</span>
                                </div>
                            </td>
                            <td>
                                <button class="table-action-btn btn-edit-publication" title="Edit"
                                        data-id="{{ pub.idPublication }}"
                                        data-titre="{{ pub.titre }}"
                                        data-description="{{ pub.description }}"
                                        data-date="{{ pub.dateAct ? pub.dateAct|date('Y-m-d') : '' }}"
                                        data-image="{{ pub.image }}"
                                        data-image-url="{{ pub.image and pub.image != 'default.jpg' ? '/uploads/' ~ pub.image : '' }}">
                                    <i class="fas fa-edit"></i>
                                </button>
                                <button class="table-action-btn delete btn-delete-publication" title="Delete" data-id="{{ pub.idPublication }}" data-titre="{{ pub.titre }}">
                                    <i class="fas fa-trash-alt"></i>
                                </button>
                            </td>
                        </tr>
                        {% endfor %}
                    {% endif %}
                </tbody>
            </table>
        </div>

        {# ── Table Footer ── #}
        <div class="admin-table-footer">
            <div class="table-footer-info">Showing <strong>{{ publications|length }}</strong> of <strong>{{ totalCount }}</strong> publications</div>
        </div>
    </div>

    {# ═══════════════════════════════════════════════════════════════
       ADD/EDIT PUBLICATION MODAL
    ═══════════════════════════════════════════════════════════════ #}
    <div class="modal fade" id="publicationModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered modal-xl">
            <div class="modal-content pub-modal-content">
                <div class="modal-header pub-modal-header">
                    <div class="pub-header-icon">
                        <i class="fas fa-file-alt"></i>
                    </div>
                    <div>
                        <h5 class="modal-title">Add Publication</h5>
                        <p class="modal-subtitle">Create a new publication</p>
                    </div>
                    <button type="button" class="btn-close-modal" data-bs-dismiss="modal" aria-label="Close">
                        <i class="fas fa-xmark"></i>
                    </button>
                </div>
                <div class="modal-body pub-modal-body">
                    <form id="publicationForm" enctype="multipart/form-data">
                        <input type="hidden" id="publicationIdHidden" value="">
                        
                        <div class="row g-3">
                            <!-- ID Publication (readonly) -->
                            <div class="col-md-3">
                                <label for="publicationId" class="form-label-custom">
                                    <i class="fas fa-hashtag me-1"></i>ID Publication
                                </label>
                                <input type="text" class="form-control admin-form-control" id="publicationId" readonly>
                            </div>

                            <!-- Date -->
                            <div class="col-md-3">
                                <label for="publicationDate" class="form-label-custom">
                                    <i class="fas fa-calendar me-1"></i>Date <span class="text-danger">*</span>
                                </label>
                                <input type="date" class="form-control admin-form-control" id="publicationDate" required>
                            </div>

                            <!-- Titre -->
                            <div class="col-md-6">
                                <label for="publicationTitre" class="form-label-custom">
                                    <i class="fas fa-heading me-1"></i>Title <span class="text-danger">*</span>
                                </label>
                                <input type="text" class="form-control admin-form-control" id="publicationTitre" placeholder="Enter publication title" required>
                            </div>

                            <!-- Description -->
                            <div class="col-12">
                                <label for="publicationDescription" class="form-label-custom">
                                    <i class="fas fa-align-left me-1"></i>Description <span class="text-danger">*</span>
                                </label>
                                <textarea class="form-control admin-form-control" id="publicationDescription" rows="4" placeholder="Enter publication description..." required></textarea>
                            </div>

                            <!-- Image Upload -->
                            <div class="col-12">
                                <label for="publicationImage" class="form-label-custom">
                                    <i class="fas fa-image me-1"></i>Image
                                </label>
                                <div class="pub-image-upload-area">
                                    <input type="file" class="form-control admin-form-control" id="publicationImage" accept="image/*">
                                    <div class="pub-image-preview-container" id="imagePreviewContainer" style="display: none;">
                                        <img id="imagePreview" src="" alt="Preview" class="pub-image-preview">
                                        <button type="button" class="btn-remove-image" id="removeImageBtn">
                                            <i class="fas fa-times"></i>
                                        </button>
                                    </div>
                                    <div class="pub-upload-placeholder" id="uploadPlaceholder">
                                        <i class="fas fa-cloud-upload-alt"></i>
                                        <p>Click to upload or drag and drop</p>
                                        <small>PNG, JPG, GIF up to 10MB</small>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </form>
                </div>
                <div class="modal-footer pub-modal-footer">
                    <button type="button" class="btn btn-admin-outline" data-bs-dismiss="modal">
                        <i class="fas fa-xmark me-2"></i>Cancel
                    </button>
                    <button type="button" class="btn btn-admin-primary" id="savePublicationBtn">
                        <i class="fas fa-check me-2"></i>Save Publication
                    </button>
                </div>
            </div>
        </div>
    </div>

    {# ═══════════════════════════════════════════════════════════════
       DELETE CONFIRMATION ALERT
    ═══════════════════════════════════════════════════════════════ #}
    <div class="delete-alert-overlay" id="deleteAlertOverlay">
        <div class="delete-alert-card">
            <div class="delete-alert-icon">
                <i class="fas fa-triangle-exclamation"></i>
            </div>
            <h3 class="delete-alert-title">Delete Publication?</h3>
            <p class="delete-alert-message" id="deleteAlertMessage">
                Are you sure you want to delete this publication? This action cannot be undone.
            </p>
            <div class="delete-alert-actions">
                <button class="btn btn-admin-outline" id="cancelDeleteBtn">
                    <i class="fas fa-xmark me-2"></i>Cancel
                </button>
                <button class="btn btn-delete" id="confirmDeleteBtn">
                    <i class="fas fa-trash-can me-2"></i>Delete
                </button>
            </div>
        </div>
    </div>

    {# ═══════════════════════════════════════════════════════════════
       TOAST NOTIFICATIONS
    ═══════════════════════════════════════════════════════════════ #}
    <div class="toast-container position-fixed top-0 end-0 p-3">
        <!-- Success Toast -->
        <div id="successToast" class="toast custom-toast toast-success" role="alert" aria-live="assertive" aria-atomic="true">
            <div class="toast-header">
                <i class="fas fa-circle-check toast-icon me-2"></i>
                <strong class="me-auto toast-title">Success</strong>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="toast" aria-label="Close"></button>
            </div>
            <div class="toast-body">Publication created successfully!</div>
            <div class="toast-progress-bar"></div>
        </div>

        <!-- Error Toast -->
        <div id="errorToast" class="toast custom-toast toast-error" role="alert" aria-live="assertive" aria-atomic="true">
            <div class="toast-header">
                <i class="fas fa-circle-xmark toast-icon me-2"></i>
                <strong class="me-auto toast-title">Error</strong>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="toast" aria-label="Close"></button>
            </div>
            <div class="toast-body">Something went wrong!</div>
            <div class="toast-progress-bar"></div>
        </div>

        <!-- Warning Toast -->
        <div id="warningToast" class="toast custom-toast toast-warning" role="alert" aria-live="assertive" aria-atomic="true">
            <div class="toast-header">
                <i class="fas fa-triangle-exclamation toast-icon me-2"></i>
                <strong class="me-auto toast-title">Warning</strong>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="toast" aria-label="Close"></button>
            </div>
            <div class="toast-body">Please check your input!</div>
            <div class="toast-progress-bar"></div>
        </div>
    </div>

{% endblock %}

{% block javascripts %}
    <script>
        const PUBLICATION_URLS = {
            create: '{{ path("app_admin_publication_create") }}',
            update: '{{ path("app_admin_publication_update", {id: "__ID__"}) }}',
            delete: '{{ path("app_admin_publication_delete", {id: "__ID__"}) }}',
            search: '{{ path("app_admin_publication_search") }}',
            get: '{{ path("app_admin_publication_get", {id: "__ID__"}) }}',
        };
    </script>
    <script src="{{ asset('assets/js/admin-publications.js') }}"></script>
{% endblock %}
