                        <td>
                            <div class="pub-image-container">
                                <img src="https://images.unsplash.com/photo-1561149077-4d3f48d8d4a0?w=100&h=100&fit=crop" alt="Publication 4" class="pub-thumbnail">
                            </div>
                        </td>
                        <td>
                            <div class="pub-title-cell">
                                <i class="fas fa-laptop-code text-primary me-2"></i>
