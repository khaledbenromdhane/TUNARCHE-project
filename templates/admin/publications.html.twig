                        <td>
                            <div class="pub-image-container">
                                <img src="https://images.unsplash.com/photo-1536924940846-227afb31e2a5?w=100&h=100&fit=crop" alt="Publication 6" class="pub-thumbnail">
                            </div>
                        </td>
                        <td>
                            <div class="pub-title-cell">
                                <i class="fas fa-ticket-alt text-danger me-2"></i>
                                <span class="pub-title">Upcoming Exhibitions Preview</span>
                            </div>
                        </td>
                        <td><span class="pub-description">Join us for an exclusive behind-the-scenes look at major art exhibitions...</span></td>
