    </div>

    {# ═══════════════════════════════════════════════════════════════
       ADD/EDIT PUBLICATION MODAL
    ═══════════════════════════════════════════════════════════════ #}
    <div class="modal fade" id="publicationModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered modal-xl">
            <div class="modal-content pub-modal-content">
                <div class="modal-header pub-modal-header">
                    <div class="pub-header-icon">
                        <i class="fas fa-file-alt"></i>
                    </div>
                    <div>
                        <h5 class="modal-title">Add Publication</h5>
                        <p class="modal-subtitle">Create a new publication</p>
                    </div>
                    <button type="button" class="btn-close-modal" data-bs-dismiss="modal" aria-label="Close">
                        <i class="fas fa-xmark"></i>
                    </button>
                </div>
                <div class="modal-body pub-modal-body">
                    <form id="publicationForm">
                        <input type="hidden" id="publicationIdHidden">
                        
                        <div class="row g-3">
                            <!-- ID Publication (readonly) -->
                            <div class="col-md-3">
                                <label for="publicationId" class="form-label-custom">
                                    <i class="fas fa-hashtag me-1"></i>ID Publication
                                </label>
                                <input type="text" class="form-control admin-form-control" id="publicationId" readonly>
                            </div>

                            <!-- Date -->
                            <div class="col-md-3">
                                <label for="publicationDate" class="form-label-custom">
                                    <i class="fas fa-calendar me-1"></i>Date <span class="text-danger">*</span>
                                </label>
                                <input type="date" class="form-control admin-form-control" id="publicationDate" required>
                            </div>

                            <!-- Titre -->
                            <div class="col-md-6">
                                <label for="publicationTitre" class="form-label-custom">
                                    <i class="fas fa-heading me-1"></i>Title <span class="text-danger">*</span>
                                </label>
                                <input type="text" class="form-control admin-form-control" id="publicationTitre" placeholder="Enter publication title" required>
                            </div>

                            <!-- Description -->
                            <div class="col-12">
                                <label for="publicationDescription" class="form-label-custom">
                                    <i class="fas fa-align-left me-1"></i>Description <span class="text-danger">*</span>
                                </label>
                                <textarea class="form-control admin-form-control" id="publicationDescription" rows="4" placeholder="Enter publication description..." required></textarea>
                            </div>

                            <!-- Image Upload -->
                            <div class="col-12">
                                <label for="publicationImage" class="form-label-custom">
                                    <i class="fas fa-image me-1"></i>Image
                                </label>
                                <div class="pub-image-upload-area">
                                    <input type="file" class="form-control admin-form-control" id="publicationImage" accept="image/*">
                                    <div class="pub-image-preview-container" id="imagePreviewContainer" style="display: none;">
                                        <img id="imagePreview" src="" alt="Preview" class="pub-image-preview">
                                        <button type="button" class="btn-remove-image" id="removeImageBtn">
                                            <i class="fas fa-times"></i>
                                        </button>
                                    </div>
                                    <div class="pub-upload-placeholder" id="uploadPlaceholder">
                                        <i class="fas fa-cloud-upload-alt"></i>
                                        <p>Click to upload or drag and drop</p>
                                        <small>PNG, JPG, GIF up to 10MB</small>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </form>
                </div>
                <div class="modal-footer pub-modal-footer">
                    <button type="button" class="btn btn-admin-outline" data-bs-dismiss="modal">
                        <i class="fas fa-xmark me-2"></i>Cancel
                    </button>
                    <button type="button" class="btn btn-admin-primary" id="savePublicationBtn">
                        <i class="fas fa-check me-2"></i>Save Publication
                    </button>
                </div>
            </div>
        </div>
    </div>

    {# ═══════════════════════════════════════════════════════════════
       DELETE CONFIRMATION ALERT
    ═══════════════════════════════════════════════════════════════ #}
    <div class="delete-alert-overlay" id="deleteAlertOverlay">
        <div class="delete-alert-card">
            <div class="delete-alert-icon">
                <i class="fas fa-triangle-exclamation"></i>
            </div>
            <h3 class="delete-alert-title">Delete Publication?</h3>
            <p class="delete-alert-message" id="deleteAlertMessage">
                Are you sure you want to delete this publication? This action cannot be undone.
            </p>
            <div class="delete-alert-actions">
                <button class="btn btn-admin-outline" id="cancelDeleteBtn">
                    <i class="fas fa-xmark me-2"></i>Cancel
                </button>
                <button class="btn btn-delete" id="confirmDeleteBtn">
                    <i class="fas fa-trash-can me-2"></i>Delete
                </button>
            </div>
        </div>
    </div>

    {# ═══════════════════════════════════════════════════════════════
       TOAST NOTIFICATIONS
    ═══════════════════════════════════════════════════════════════ #}
    <div class="toast-container position-fixed top-0 end-0 p-3">
        <!-- Success Toast -->
        <div id="successToast" class="toast custom-toast toast-success" role="alert" aria-live="assertive" aria-atomic="true">
            <div class="toast-header">
                <i class="fas fa-circle-check toast-icon me-2"></i>
                <strong class="me-auto toast-title">Success</strong>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="toast" aria-label="Close"></button>
            </div>
            <div class="toast-body">Publication created successfully!</div>
            <div class="toast-progress-bar"></div>
        </div>

        <!-- Error Toast -->
        <div id="errorToast" class="toast custom-toast toast-error" role="alert" aria-live="assertive" aria-atomic="true">
            <div class="toast-header">
                <i class="fas fa-circle-xmark toast-icon me-2"></i>
                <strong class="me-auto toast-title">Error</strong>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="toast" aria-label="Close"></button>
            </div>
            <div class="toast-body">Something went wrong!</div>
            <div class="toast-progress-bar"></div>
        </div>

        <!-- Warning Toast -->
        <div id="warningToast" class="toast custom-toast toast-warning" role="alert" aria-live="assertive" aria-atomic="true">
            <div class="toast-header">
                <i class="fas fa-triangle-exclamation toast-icon me-2"></i>
                <strong class="me-auto toast-title">Warning</strong>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="toast" aria-label="Close"></button>
            </div>
            <div class="toast-body">Please check your input!</div>
            <div class="toast-progress-bar"></div>
        </div>
    </div>

{% endblock %}

{% block javascripts %}
    <script src="{{ asset('assets/js/admin-publications.js') }}"></script>
