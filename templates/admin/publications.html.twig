                </tbody>
            </table>
        </div>

        {# ── Table Footer ── #}
        <div class="admin-table-footer">
            <div class="table-footer-info">Showing <strong>1–6</strong> of <strong>6</strong> publications</div>
            <nav aria-label="Publications pagination">
                <ul class="pagination admin-pagination mb-0">
                    <li class="page-item disabled">
                        <a class="page-link" href="#" aria-label="Previous"><i class="fas fa-chevron-left"></i></a>
                    </li>
                    <li class="page-item active"><a class="page-link" href="#">1</a></li>
                    <li class="page-item"><a class="page-link" href="#">2</a></li>
                    <li class="page-item"><a class="page-link" href="#">3</a></li>
                    <li class="page-item">
                        <a class="page-link" href="#" aria-label="Next"><i class="fas fa-chevron-right"></i></a>
                    </li>
