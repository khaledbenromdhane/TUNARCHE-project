{% extends 'admin/base.html.twig' %}

{% block title %}Publications Management{% endblock %}

{% block page_title %}Publications{% endblock %}

{% block breadcrumb %}
    <li class="breadcrumb-item"><a href="{{ path('app_admin_dashboard') }}">Dashboard</a></li>
    <li class="breadcrumb-item active" aria-current="page">Publications</li>
{% endblock %}

{% block page_actions %}
    <button class="btn btn-admin-primary" id="addPublicationBtn">
        <i class="fas fa-plus-circle me-2"></i>Add Publication
    </button>
{% endblock %}

{% block stylesheets %}
    <link href="{{ asset('assets/css/admin-publications.css') }}" rel="stylesheet">
{% endblock %}

{% block body %}

