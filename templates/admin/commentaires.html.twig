    {# ═══════════════════════════════════════════════════════════════
       ADD/EDIT COMMENTAIRE MODAL
    ═══════════════════════════════════════════════════════════════ #}
    <div class="modal fade" id="commentaireModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered modal-lg">
            <div class="modal-content com-modal-content">
                <div class="modal-header com-modal-header">
                    <div class="com-header-icon">
                        <i class="fas fa-comment-dots"></i>
                    </div>
                    <div>
                        <h5 class="modal-title">Add Commentaire</h5>
                        <p class="modal-subtitle">Create a new comment</p>
                    </div>
                    <button type="button" class="btn-close-modal" data-bs-dismiss="modal" aria-label="Close">
                        <i class="fas fa-xmark"></i>
                    </button>
                </div>
                <div class="modal-body com-modal-body">
                    <form id="commentaireForm">
                        <input type="hidden" id="commentaireIdHidden">
                        
                        <div class="row g-3">
                            <!-- ID Commentaire (readonly) -->
                            <div class="col-md-4">
                                <label for="commentaireId" class="form-label-custom">
                                    <i class="fas fa-hashtag me-1"></i>ID Commentaire
                                </label>
                                <input type="text" class="form-control admin-form-control" id="commentaireId" readonly>
                            </div>

                            <!-- ID User (Select) -->
                            <div class="col-md-4">
                                <label for="commentaireUserId" class="form-label-custom">
                                    <i class="fas fa-user me-1"></i>User <span class="text-danger">*</span>
                                </label>
                                <select class="form-select admin-select" id="commentaireUserId" required>
                                    <option value="">Select user...</option>
                                    <option value="15">Marie Dubois (#15)</option>
                                    <option value="23">Jean Martin (#23)</option>
                                    <option value="8">Sophie Laurent (#8)</option>
                                    <option value="31">Pierre Leroy (#31)</option>
                                    <option value="47">Camille Bernard (#47)</option>
                                    <option value="62">Lucas Petit (#62)</option>
                                    <option value="99">Anonymous User (#99)</option>
                                    <option value="120">Other User (#120)</option>
                                </select>
                            </div>

                            <!-- ID Publication (Select) -->
                            <div class="col-md-4">
                                <label for="commentairePublicationId" class="form-label-custom">
                                    <i class="fas fa-image me-1"></i>Publication <span class="text-danger">*</span>
                                </label>
                                <select class="form-select admin-select" id="commentairePublicationId" required>
                                    <option value="">Select publication...</option>
                                    <option value="42">Modern Art Exhibition (#42)</option>
                                    <option value="38">Art Workshop 2026 (#38)</option>
                                    <option value="29">Abstract Collection (#29)</option>
                                    <option value="15">Classic Paintings (#15)</option>
                                    <option value="51">Portrait Gallery (#51)</option>
                                    <option value="33">Sculpture Exhibition (#33)</option>
                                    <option value="67">Digital Art Showcase (#67)</option>
                                </select>
                            </div>

                            <!-- Comment Text -->
                            <div class="col-12">
                                <label for="commentaireText" class="form-label-custom">
                                    <i class="fas fa-comment-dots me-1"></i>Comment Text <span class="text-danger">*</span>
                                </label>
                                <textarea class="form-control admin-form-control" id="commentaireText" rows="3" placeholder="Enter comment text..." required></textarea>
                            </div>

                            <!-- Status -->
                            <div class="col-md-4">
                                <label for="commentaireStatus" class="form-label-custom">
                                    <i class="fas fa-eye me-1"></i>Status <span class="text-danger">*</span>
                                </label>
                                <select class="form-select admin-select" id="commentaireStatus" required>
                                    <option value="visible">Visible</option>
                                    <option value="hidden">Hidden</option>
                                </select>
                            </div>

                            <!-- Number of Likes -->
                            <div class="col-md-4">
                                <label for="commentaireLikes" class="form-label-custom">
                                    <i class="fas fa-heart me-1"></i>Likes <span class="text-danger">*</span>
                                </label>
                                <input type="number" class="form-control admin-form-control" id="commentaireLikes" placeholder="0" min="0" value="0" required>
                            </div>

                            <!-- Parent ID (Optional) -->
                            <div class="col-md-4">
                                <label for="commentaireParentId" class="form-label-custom">
                                    <i class="fas fa-reply me-1"></i>Parent ID (Reply)
                                </label>
                                <input type="number" class="form-control admin-form-control" id="commentaireParentId" placeholder="Optional" min="1">
                                <small class="form-text text-muted">Leave empty for main comment</small>
                            </div>

                            <!-- Est Signalé Toggle -->
                            <div class="col-12">
                                <div class="form-check form-switch com-toggle">
                                    <input class="form-check-input" type="checkbox" id="commentaireEstSignale">
                                    <label class="form-check-label" for="commentaireEstSignale">
                                        <i class="fas fa-flag me-2"></i>Comment is reported
                                    </label>
                                </div>
                            </div>

                            <!-- Raison Signalement (Conditional) -->
                            <div class="col-12" id="raisonSignalementGroup" style="display: none;">
                                <label for="commentaireRaisonSignalement" class="form-label-custom">
                                    <i class="fas fa-exclamation-triangle me-1"></i>Report Reason <span class="text-danger">*</span>
                                </label>
                                <textarea class="form-control admin-form-control" id="commentaireRaisonSignalement" rows="3" placeholder="Describe the reason for reporting this comment..."></textarea>
                            </div>
                        </div>
                    </form>
                </div>
                <div class="modal-footer com-modal-footer">
                    <button type="button" class="btn btn-admin-outline" data-bs-dismiss="modal">
                        <i class="fas fa-xmark me-2"></i>Cancel
                    </button>
                    <button type="button" class="btn btn-admin-primary" id="saveCommentaireBtn">
                        <i class="fas fa-check me-2"></i>Save Comment
                    </button>
                </div>
            </div>
        </div>
    </div>

    {# ═══════════════════════════════════════════════════════════════
       DELETE CONFIRMATION ALERT
    ═══════════════════════════════════════════════════════════════ #}
    <div class="delete-alert-overlay" id="deleteAlertOverlay">
        <div class="delete-alert-card">
            <div class="delete-alert-icon">
                <i class="fas fa-triangle-exclamation"></i>
            </div>
            <h3 class="delete-alert-title">Delete Commentaire?</h3>
            <p class="delete-alert-message" id="deleteAlertMessage">
                Are you sure you want to delete this comment? This action cannot be undone.
            </p>
            <div class="delete-alert-actions">
                <button class="btn btn-admin-outline" id="cancelDeleteBtn">
                    <i class="fas fa-xmark me-2"></i>Cancel
                </button>
                <button class="btn btn-delete" id="confirmDeleteBtn">
                    <i class="fas fa-trash-can me-2"></i>Delete
                </button>
            </div>
        </div>
    </div>

    {# ═══════════════════════════════════════════════════════════════
       TOAST NOTIFICATIONS
    ═══════════════════════════════════════════════════════════════ #}
    <div class="toast-container position-fixed top-0 end-0 p-3">
        <!-- Success Toast -->
        <div id="successToast" class="toast custom-toast toast-success" role="alert" aria-live="assertive" aria-atomic="true">
            <div class="toast-header">
                <i class="fas fa-circle-check toast-icon me-2"></i>
                <strong class="me-auto toast-title">Success</strong>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="toast" aria-label="Close"></button>
            </div>
            <div class="toast-body">Commentaire created successfully!</div>
            <div class="toast-progress-bar"></div>
        </div>

        <!-- Error Toast -->
        <div id="errorToast" class="toast custom-toast toast-error" role="alert" aria-live="assertive" aria-atomic="true">
            <div class="toast-header">
                <i class="fas fa-circle-xmark toast-icon me-2"></i>
                <strong class="me-auto toast-title">Error</strong>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="toast" aria-label="Close"></button>
            </div>
            <div class="toast-body">Something went wrong!</div>
            <div class="toast-progress-bar"></div>
        </div>

        <!-- Warning Toast -->
        <div id="warningToast" class="toast custom-toast toast-warning" role="alert" aria-live="assertive" aria-atomic="true">
            <div class="toast-header">
                <i class="fas fa-triangle-exclamation toast-icon me-2"></i>
                <strong class="me-auto toast-title">Warning</strong>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="toast" aria-label="Close"></button>
            </div>
            <div class="toast-body">Please check your input!</div>
            <div class="toast-progress-bar"></div>
        </div>
    </div>

{% endblock %}

{% block javascripts %}
    <script src="{{ asset('assets/js/admin-commentaires.js') }}"></script>
{% endblock %}
