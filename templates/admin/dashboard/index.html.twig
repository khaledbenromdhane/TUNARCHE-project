{% extends 'back/base.html.twig' %}

{% block title %}Dashboard{% endblock %}
{% block page_title %}Tableau de Bord{% endblock %}

{% block breadcrumb %}
    <li class="breadcrumb-item active" aria-current="page">Dashboard</li>
{% endblock %}

{% block body %}
<div class="container-fluid">

    {# ═══ CARTES STATISTIQUES DYNAMIQUES ═══ #}
    <div class="row g-3 mb-4">
        <div class="col-sm-6 col-xl-3">
            <div class="admin-stat-card stat-primary">
                <div class="stat-icon"><i class="fas fa-users"></i></div>
                <div class="stat-content">
                    <h3>{{ stats.total }}</h3>
                    <p>Total Utilisateurs</p>
                </div>
            </div>
        </div>
        <div class="col-sm-6 col-xl-3">
            <div class="admin-stat-card stat-danger" style="--stat-color: #dc3545;">
                <div class="stat-icon"><i class="fas fa-shield-alt"></i></div>
                <div class="stat-content">
                    <h3>{{ stats.admins }}</h3>
                    <p>Administrateurs</p>
                </div>
            </div>
        </div>
        <div class="col-sm-6 col-xl-3">
            <div class="admin-stat-card stat-warning">
                <div class="stat-icon"><i class="fas fa-palette"></i></div>
                <div class="stat-content">
                    <h3>{{ stats.artists }}</h3>
                    <p>Artistes</p>
                </div>
            </div>
        </div>
        <div class="col-sm-6 col-xl-3">
            <div class="admin-stat-card stat-success">
                <div class="stat-icon"><i class="fas fa-user"></i></div>
                <div class="stat-content">
                    <h3>{{ stats.users }}</h3>
                    <p>Utilisateurs</p>
                </div>
            </div>
        </div>
    </div>

    {# ═══ GRAPHIQUES + INFO ADMIN ═══ #}
    <div class="row g-3 mb-4">

        {# Graphique répartition rôles #}
        <div class="col-lg-5">
            <div class="card admin-card h-100">
                <div class="card-header">
                    <h5 class="mb-0"><i class="fas fa-chart-pie me-2"></i>Répartition des Rôles</h5>
                </div>
                <div class="card-body d-flex justify-content-center align-items-center">
                    <div style="position:relative; width:260px; height:260px;">
                        <canvas id="rolesChart"></canvas>
                        <div style="position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);text-align:center;pointer-events:none;">
                            <div style="font-size:2rem;font-weight:700;color:#c9a84c;">{{ stats.total }}</div>
                            <div style="font-size:0.75rem;color:#aaa;">Total</div>
                        </div>
                    </div>
                </div>
                <div class="card-footer d-flex justify-content-around text-center small">
                    <div><span class="badge" style="background:#dc3545;">●</span> Admins : <strong>{{ stats.admins }}</strong></div>
                    <div><span class="badge" style="background:#ffc107;">●</span> Artistes : <strong>{{ stats.artists }}</strong></div>
                    <div><span class="badge" style="background:#198754;">●</span> Users : <strong>{{ stats.users }}</strong></div>
                </div>
            </div>
        </div>

        {# Graphique barres #}
        <div class="col-lg-7">
            <div class="card admin-card h-100">
                <div class="card-header">
                    <h5 class="mb-0"><i class="fas fa-chart-bar me-2"></i>Statistiques Utilisateurs</h5>
                </div>
                <div class="card-body">
                    <canvas id="statsBarChart" height="220"></canvas>
                </div>
            </div>
        </div>
    </div>

    {# ═══ INFO ADMIN CONNECTÉ ═══ #}
    <div class="row">
        <div class="col-12">
            <div class="card admin-card">
                <div class="card-header">
                    <h5 class="mb-0"><i class="fas fa-user-shield me-2"></i>Administrateur Connecté</h5>
                </div>
                <div class="card-body">
                    <div class="d-flex align-items-center gap-4 flex-wrap">
                        {% if app.user.avatarFilename is defined and app.user.avatarFilename %}
                            <img src="{{ asset('uploads/avatars/' ~ app.user.avatarFilename) }}"
                                 class="rounded-circle" width="80" height="80"
                                 style="object-fit:cover;border:3px solid #c9a84c;" alt="Avatar">
                        {% else %}
                            <img src="https://ui-avatars.com/api/?name={{ app.user.prenom }}+{{ app.user.nom }}&background=c9a84c&color=0a0a12&bold=true&size=80"
                                 class="rounded-circle" width="80" height="80"
                                 style="border:3px solid #c9a84c;" alt="Avatar">
                        {% endif %}
                        <div>
                            <h4 class="mb-1">{{ app.user.prenom }} {{ app.user.nom }}</h4>
                            <p class="mb-1 text-muted"><i class="fas fa-envelope me-2"></i>{{ app.user.email }}</p>
                            <div>
                                {% for role in app.user.roles %}
                                    {% if role == 'ROLE_ADMIN' %}
                                        <span class="badge bg-danger me-1"><i class="fas fa-shield-alt me-1"></i>Administrateur</span>
                                    {% elseif role == 'ROLE_ARTIST' %}
                                        <span class="badge bg-warning text-dark me-1"><i class="fas fa-palette me-1"></i>Artiste</span>
                                    {% elseif role == 'ROLE_USER' %}
                                        <span class="badge bg-primary me-1"><i class="fas fa-user me-1"></i>Utilisateur</span>
                                    {% endif %}
                                {% endfor %}
                            </div>
                        </div>
                        <div class="ms-auto d-flex gap-2">
                            <a href="{{ path('app_profile') }}" class="btn btn-outline-secondary">
                                <i class="fas fa-eye me-1"></i>Voir le profil
                            </a>
                            <a href="{{ path('app_profile_edit') }}" class="btn btn-gold">
                                <i class="fas fa-edit me-1"></i>Modifier
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

</div>
{% endblock %}

{% block javascripts %}
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
<script>
// Données depuis Twig
const statsData = {
    admins:  {{ stats.admins }},
    artists: {{ stats.artists }},
    users:   {{ stats.users }},
    total:   {{ stats.total }},
};

// ── Graphique Donut Rôles ──
const ctxPie = document.getElementById('rolesChart').getContext('2d');
new Chart(ctxPie, {
    type: 'doughnut',
    data: {
        labels: ['Admins', 'Artistes', 'Utilisateurs'],
        datasets: [{
            data: [statsData.admins, statsData.artists, statsData.users],
            backgroundColor: ['#dc3545', '#ffc107', '#198754'],
            borderColor: ['#1a1a2e', '#1a1a2e', '#1a1a2e'],
            borderWidth: 3,
        }]
    },
    options: {
        responsive: false,
        cutout: '65%',
        plugins: {
            legend: { display: false },
            tooltip: {
                callbacks: {
                    label: ctx => ` ${ctx.label}: ${ctx.parsed} (${((ctx.parsed/statsData.total)*100).toFixed(1)}%)`
                }
            }
        }
    }
});

// ── Graphique Barres ──
const ctxBar = document.getElementById('statsBarChart').getContext('2d');
new Chart(ctxBar, {
    type: 'bar',
    data: {
        labels: ['Total', 'Admins', 'Artistes', 'Utilisateurs'],
        datasets: [{
            label: 'Nombre',
            data: [statsData.total, statsData.admins, statsData.artists, statsData.users],
            backgroundColor: ['#c9a84c', '#dc3545', '#ffc107', '#198754'],
            borderRadius: 8,
            borderSkipped: false,
        }]
    },
    options: {
        responsive: true,
        maintainAspectRatio: false,
        plugins: { legend: { display: false } },
        scales: {
            y: {
                beginAtZero: true,
                ticks: { stepSize: 1, color: '#aaa' },
                grid: { color: 'rgba(255,255,255,0.05)' }
            },
            x: {
                ticks: { color: '#aaa' },
                grid: { display: false }
            }
        }
    }
});
</script>
{% endblock %}
