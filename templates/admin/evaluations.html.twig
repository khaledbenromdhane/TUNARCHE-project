    {# ═══════════════════════════════════════════════════════════════
       ADD/EDIT EVALUATION MODAL
    ═══════════════════════════════════════════════════════════════ #}
    <div class="modal fade" id="evaluationModal" tabindex="-1" aria-labelledby="evaluationModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered modal-lg">
            <div class="modal-content eval-modal-content">
                <div class="modal-header eval-modal-header">
                    <div class="eval-header-icon">
                        <i class="fas fa-star" id="evaluationModalIcon"></i>
                    </div>
                    <div>
                        <h5 class="modal-title" id="evaluationModalLabel">Add Évaluation</h5>
                        <p class="modal-subtitle" id="evaluationModalSubtitle">Fill in the details to create a new evaluation</p>
                    </div>
                    <button type="button" class="btn-close-modal" data-bs-dismiss="modal" aria-label="Close">
                        <i class="fas fa-times"></i>
                    </button>
                </div>

                <div class="modal-body eval-modal-body">
                    <form id="evaluationForm" novalidate>
                        <input type="hidden" id="formEvaluationId" value="">

                        <div class="row g-3">
                            {# ID Évaluation #}
                            <div class="col-md-6">
                                <label for="inputEvaluationId" class="form-label-custom"><i class="fas fa-hashtag me-1"></i> ID Évaluation</label>
                                <input type="text" class="form-control admin-form-control" id="inputEvaluationId" placeholder="Auto-generated" readonly>
                                <small class="form-text-muted">Auto-generated by system</small>
                            </div>

                            {# Date #}
                            <div class="col-md-6">
                                <label for="inputDate" class="form-label-custom"><i class="fas fa-calendar-days me-1"></i> Date <span class="text-danger">*</span></label>
                                <input type="date" class="form-control admin-form-control" id="inputDate" required>
                                <div class="invalid-feedback">Please select a date.</div>
                            </div>

                            {# Titre #}
                            <div class="col-md-12">
                                <label for="inputTitre" class="form-label-custom"><i class="fas fa-heading me-1"></i> Title <span class="text-danger">*</span></label>
                                <input type="text" class="form-control admin-form-control" id="inputTitre" placeholder="e.g., Excellent Formation Experience" required>
                                <div class="invalid-feedback">Please enter a title.</div>
                            </div>

                            {# Rating (Star Rating) #}
                            <div class="col-md-12">
                                <label class="form-label-custom"><i class="fas fa-star me-1"></i> Rating <span class="text-danger">*</span></label>
                                <div class="star-rating-input">
                                    <input type="radio" name="rating" id="star5" value="5" required>
                                    <label for="star5" class="star-label"><i class="fas fa-star"></i></label>
                                    
                                    <input type="radio" name="rating" id="star4" value="4">
                                    <label for="star4" class="star-label"><i class="fas fa-star"></i></label>
                                    
                                    <input type="radio" name="rating" id="star3" value="3">
                                    <label for="star3" class="star-label"><i class="fas fa-star"></i></label>
                                    
                                    <input type="radio" name="rating" id="star2" value="2">
                                    <label for="star2" class="star-label"><i class="fas fa-star"></i></label>
                                    
                                    <input type="radio" name="rating" id="star1" value="1">
                                    <label for="star1" class="star-label"><i class="fas fa-star"></i></label>
                                    
                                    <span class="rating-value-display">0/5</span>
                                </div>
                                <div class="invalid-feedback d-block" id="ratingError" style="display: none !important;">Please select a rating.</div>
                            </div>

                            {# Commentaire #}
                            <div class="col-md-12">
                                <label for="inputCommentaire" class="form-label-custom"><i class="fas fa-comment me-1"></i> Comment <span class="text-danger">*</span></label>
                                <textarea class="form-control admin-form-control" id="inputCommentaire" rows="5" placeholder="Enter your evaluation comment..." required></textarea>
                                <div class="invalid-feedback">Please enter a comment.</div>
                            </div>
                        </div>
                    </form>
                </div>

                <div class="modal-footer eval-modal-footer">
                    <button type="button" class="btn btn-admin-outline" data-bs-dismiss="modal">
                        <i class="fas fa-times me-1"></i> Cancel
                    </button>
                    <button type="button" class="btn btn-admin-primary" id="saveEvaluationBtn">
                        <i class="fas fa-check me-1"></i> <span id="saveEvaluationBtnText">Add Évaluation</span>
                    </button>
                </div>
            </div>
        </div>
    </div>

    {# ═══════════════════════════════════════════════════════════════
       DELETE CONFIRMATION ALERT
    ═══════════════════════════════════════════════════════════════ #}
    <div class="delete-alert-overlay" id="deleteEvaluationAlert">
        <div class="delete-alert-card">
            <div class="delete-alert-icon">
                <i class="fas fa-exclamation-triangle"></i>
            </div>
            <h4 class="delete-alert-title">Delete Évaluation?</h4>
            <p class="delete-alert-message">
                Are you sure you want to delete <strong id="deleteEvaluationName">this evaluation</strong>?<br>
                This action cannot be undone.
            </p>
            <div class="delete-alert-actions">
                <button class="btn btn-admin-outline" id="cancelDeleteEvaluationBtn">
                    <i class="fas fa-times me-1"></i> Cancel
                </button>
                <button class="btn btn-danger" id="confirmDeleteEvaluationBtn">
                    <i class="fas fa-trash-can me-1"></i> Delete
                </button>
            </div>
        </div>
    </div>

    {# ═══════════════════════════════════════════════════════════════
       TOAST NOTIFICATIONS
    ═══════════════════════════════════════════════════════════════ #}
    <div class="toast-container position-fixed top-0 end-0 p-3" style="z-index: 9999;">
        {# Success Toast #}
        <div id="evaluationToastSuccess" class="toast custom-toast toast-success" role="alert" aria-live="assertive" aria-atomic="true">
            <div class="toast-header">
                <i class="fas fa-check-circle toast-icon me-2"></i>
                <strong class="me-auto">Success</strong>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="toast" aria-label="Close"></button>
            </div>
            <div class="toast-body" id="evaluationToastSuccessMsg">Évaluation added successfully!</div>
            <div class="toast-progress-bar"></div>
        </div>

        {# Error Toast #}
        <div id="evaluationToastError" class="toast custom-toast toast-error" role="alert" aria-live="assertive" aria-atomic="true">
            <div class="toast-header">
                <i class="fas fa-times-circle toast-icon me-2"></i>
                <strong class="me-auto">Error</strong>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="toast" aria-label="Close"></button>
            </div>
            <div class="toast-body" id="evaluationToastErrorMsg">An error occurred!</div>
            <div class="toast-progress-bar"></div>
        </div>

        {# Warning Toast #}
        <div id="evaluationToastWarning" class="toast custom-toast toast-warning" role="alert" aria-live="assertive" aria-atomic="true">
            <div class="toast-header">
                <i class="fas fa-triangle-exclamation toast-icon me-2"></i>
                <strong class="me-auto">Warning</strong>
