                    <i class="fas fa-clipboard-check"></i>
                </div>
                <div class="eval-stat-info">
                    <span class="eval-stat-value" data-counter="328">0</span>
                    <span class="eval-stat-label">Total Évaluations</span>
                </div>
                <div class="eval-stat-trend up"><i class="fas fa-arrow-up"></i> 14%</div>
            </div>
        </div>
