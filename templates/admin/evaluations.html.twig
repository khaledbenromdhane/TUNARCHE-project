{% extends 'admin/base.html.twig' %}

{% block title %}Évaluations Management{% endblock %}

{% block page_title %}Évaluations{% endblock %}

{% block breadcrumb %}
    <li class="breadcrumb-item"><a href="{{ path('app_admin_dashboard') }}">Dashboard</a></li>
    <li class="breadcrumb-item active" aria-current="page">Évaluations</li>
{% endblock %}

{% block page_actions %}
    <div class="d-flex gap-2 flex-wrap">
        <button class="btn btn-admin-outline btn-sm" id="exportEvaluationsBtn">
            <i class="fas fa-file-export me-1"></i> Export
        </button>
        <button class="btn btn-admin-primary" data-bs-toggle="modal" data-bs-target="#evaluationModal" id="addEvaluationBtn">
            <i class="fas fa-star me-1"></i> Add Évaluation
        </button>
    </div>
{% endblock %}

{% block stylesheets %}
    <link href="{{ asset('assets/css/admin-evaluations.css') }}" rel="stylesheet">
{% endblock %}

{% block body %}

