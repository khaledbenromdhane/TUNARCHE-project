{% extends 'admin/base.html.twig' %}

{% block title %}Galeries Management{% endblock %}

{% block page_title %}Galeries{% endblock %}

{% block breadcrumb %}
    <li class="breadcrumb-item"><a href="{{ path('app_admin_dashboard') }}">Dashboard</a></li>
    <li class="breadcrumb-item active" aria-current="page">Galeries</li>
{% endblock %}

{% block page_actions %}
    <div class="d-flex gap-2 flex-wrap">
        <button class="btn btn-admin-outline btn-sm" id="exportGaleriesBtn">
            <i class="fas fa-file-export me-1"></i> Export
        </button>
        <button class="btn btn-admin-primary" data-bs-toggle="modal" data-bs-target="#galerieModal" id="addGalerieBtn">
            <i class="fas fa-palette me-1"></i> Add Galerie
        </button>
    </div>
{% endblock %}

{% block stylesheets %}
    <link href="{{ asset('assets/css/admin-galeries.css') }}" rel="stylesheet">
{% endblock %}

{% block body %}

