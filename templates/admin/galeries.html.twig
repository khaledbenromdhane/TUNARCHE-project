    {# ═══════════════════════════════════════════════════════════════
       ADD/EDIT GALERIE MODAL
    ═══════════════════════════════════════════════════════════════ #}
    <div class="modal fade" id="galerieModal" tabindex="-1" aria-labelledby="galerieModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content gal-modal-content">
            <div class="modal-header gal-modal-header">
                <div class="gal-header-icon">
                    <i class="fas fa-palette" id="galerieModalIcon"></i>
                </div>
                <div>
                    <h5 class="modal-title" id="galerieModalLabel">Add Galerie</h5>
                    <p class="modal-subtitle" id="galerieModalSubtitle">Fill in the details to create a new gallery</p>
                </div>
                <button type="button" class="btn-close-modal" data-bs-dismiss="modal" aria-label="Close">
                    <i class="fas fa-xmark"></i>
                </button>
            </div>
            <div class="modal-body gal-modal-body">
                <form id="galerieForm">
                    <input type="hidden" id="formGalerieId">
                    
                    <div class="row g-3">
                        <!-- Galerie ID (readonly) -->
                        <div class="col-md-6">
                            <label for="inputGalerieId" class="form-label-custom">
                                <i class="fas fa-hashtag me-1"></i>Galerie ID
                            </label>
                            <input type="text" class="form-control admin-form-control" id="inputGalerieId" placeholder="#GAL-XXX" readonly>
                        </div>

                        <!-- Category -->
                        <div class="col-md-6">
                            <label for="inputGalerieCategory" class="form-label-custom">
                                <i class="fas fa-tag me-1"></i>Category <span class="text-danger">*</span>
                            </label>
                            <select class="form-select admin-select" id="inputGalerieCategory" required>
                                <option value="">Select category...</option>
                                <option value="contemporary">Contemporary</option>
                                <option value="classical">Classical</option>
                                <option value="modern">Modern</option>
                                <option value="sculpture">Sculpture</option>
                                <option value="photography">Photography</option>
                                <option value="abstract">Abstract</option>
                            </select>
                        </div>

                        <!-- Galerie Name -->
                        <div class="col-12">
                            <label for="inputGalerieName" class="form-label-custom">
                                <i class="fas fa-building-columns me-1"></i>Galerie Name <span class="text-danger">*</span>
                            </label>
                            <input type="text" class="form-control admin-form-control" id="inputGalerieName" placeholder="Enter gallery name" required>
                        </div>

                        <!-- Number of Artworks -->
                        <div class="col-md-6">
                            <label for="inputGalerieArtworks" class="form-label-custom">
                                <i class="fas fa-palette me-1"></i>Available Artworks <span class="text-danger">*</span>
                            </label>
                            <input type="number" class="form-control admin-form-control" id="inputGalerieArtworks" placeholder="0" min="0" required>
                        </div>

                        <!-- Number of Staff -->
                        <div class="col-md-6">
                            <label for="inputGalerieStaff" class="form-label-custom">
                                <i class="fas fa-user-tie me-1"></i>Staff Members <span class="text-danger">*</span>
                            </label>
                            <input type="number" class="form-control admin-form-control" id="inputGalerieStaff" placeholder="0" min="0" required>
                        </div>

                        <!-- Artists (comma-separated) -->
                        <div class="col-12">
                            <label for="inputGalerieArtists" class="form-label-custom">
                                <i class="fas fa-users-line me-1"></i>Featured Artists <span class="text-danger">*</span>
                            </label>
                            <input type="text" class="form-control admin-form-control" id="inputGalerieArtists" placeholder="Enter artist names (comma-separated)" required>
                            <small class="form-text text-muted">Separate multiple artists with commas (e.g., Picasso, Monet, Van Gogh)</small>
                        </div>
                    </div>
                </form>
            </div>
            <div class="modal-footer gal-modal-footer">
                <button type="button" class="btn btn-admin-outline" data-bs-dismiss="modal">
                    <i class="fas fa-xmark me-2"></i>Cancel
                </button>
                <button type="button" class="btn btn-admin-primary" id="saveGalerieBtn">
                    <i class="fas fa-check me-2"></i><span id="saveGalerieBtnText">Save Galerie</span>
                </button>
            </div>
        </div>
    </div>
</div>

{# ═══════════════════════════════════════════════════════════════
   DELETE CONFIRMATION ALERT
═══════════════════════════════════════════════════════════════ #}
<div class="delete-alert-overlay" id="deleteGalerieAlertOverlay">
    <div class="delete-alert-box">
        <div class="delete-alert-icon">
            <i class="fas fa-triangle-exclamation"></i>
        </div>
        <h3 class="delete-alert-title">Delete Galerie?</h3>
        <p class="delete-alert-message">
            Are you sure you want to delete <strong id="deleteGalerieName"></strong>? This action cannot be undone.
        </p>
        <div class="delete-alert-actions">
            <button class="btn btn-admin-outline" id="cancelGalerieDeleteBtn">
                <i class="fas fa-xmark me-2"></i>Cancel
            </button>
            <button class="btn btn-delete" id="confirmGalerieDeleteBtn">
                <i class="fas fa-trash-can me-2"></i>Delete
            </button>
        </div>
    </div>
</div>

{# ═══════════════════════════════════════════════════════════════
   TOAST NOTIFICATIONS
═══════════════════════════════════════════════════════════════ #}
<div class="toast-container position-fixed top-0 end-0 p-3">
    <!-- Success Toast -->
    <div id="galerieToastSuccess" class="toast custom-toast toast-success" role="alert" aria-live="assertive" aria-atomic="true">
        <div class="toast-header">
            <i class="fas fa-circle-check toast-icon me-2"></i>
            <strong class="me-auto">Success</strong>
            <button type="button" class="btn-close btn-close-white" data-bs-dismiss="toast" aria-label="Close"></button>
        </div>
        <div class="toast-body" id="galerieToastSuccessMsg">Galerie created successfully!</div>
        <div class="toast-progress-bar"></div>
    </div>

    <!-- Error Toast -->
    <div id="galerieToastError" class="toast custom-toast toast-error" role="alert" aria-live="assertive" aria-atomic="true">
        <div class="toast-header">
            <i class="fas fa-circle-xmark toast-icon me-2"></i>
            <strong class="me-auto">Error</strong>
            <button type="button" class="btn-close btn-close-white" data-bs-dismiss="toast" aria-label="Close"></button>
        </div>
        <div class="toast-body" id="galerieToastErrorMsg">Something went wrong!</div>
        <div class="toast-progress-bar"></div>
    </div>

    <!-- Warning Toast -->
    <div id="galerieToastWarning" class="toast custom-toast toast-warning" role="alert" aria-live="assertive" aria-atomic="true">
        <div class="toast-header">
            <i class="fas fa-triangle-exclamation toast-icon me-2"></i>
            <strong class="me-auto">Warning</strong>
            <button type="button" class="btn-close btn-close-white" data-bs-dismiss="toast" aria-label="Close"></button>
        </div>
        <div class="toast-body" id="galerieToastWarningMsg">Please check your input!</div>
        <div class="toast-progress-bar"></div>
    </div>
</div>

{% endblock %}

