{% extends 'admin/base.html.twig' %}

{% block title %}Œuvres Management{% endblock %}

{% block page_title %}Œuvres{% endblock %}

{% block breadcrumb %}
    <li class="breadcrumb-item"><a href="{{ path('app_admin_dashboard') }}">Dashboard</a></li>
    <li class="breadcrumb-item active" aria-current="page">Œuvres</li>
{% endblock %}

{% block page_actions %}
    <div class="d-flex gap-2 flex-wrap">
        <button class="btn btn-admin-outline btn-sm" id="exportOeuvresBtn">
            <i class="fas fa-file-export me-1"></i> Export
        </button>
        <button class="btn btn-admin-primary" data-bs-toggle="modal" data-bs-target="#oeuvreModal" id="addOeuvreBtn">
            <i class="fas fa-palette me-1"></i> Add Œuvre
        </button>
    </div>
{% endblock %}

{% block stylesheets %}
    <link href="{{ asset('assets/css/admin-oeuvres.css') }}" rel="stylesheet">
{% endblock %}

{% block body %}

