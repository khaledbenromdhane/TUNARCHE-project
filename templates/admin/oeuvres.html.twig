    {# ═══════════════════════════════════════════════════════════════
       ADD/EDIT ŒUVRE MODAL
    ═══════════════════════════════════════════════════════════════ #}
    <div class="modal fade" id="oeuvreModal" tabindex="-1" aria-labelledby="oeuvreModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered modal-lg">
            <div class="modal-content oeuv-modal-content">
                <div class="modal-header oeuv-modal-header">
                    <div class="oeuv-header-icon">
                        <i class="fas fa-palette" id="oeuvreModalIcon"></i>
                    </div>
                    <div>
                        <h5 class="modal-title" id="oeuvreModalLabel">Add Œuvre</h5>
                        <p class="modal-subtitle" id="oeuvreModalSubtitle">Fill in the details to create a new artwork</p>
                    </div>
                    <button type="button" class="btn-close-modal" data-bs-dismiss="modal" aria-label="Close">
                        <i class="fas fa-times"></i>
                    </button>
                </div>

                <div class="modal-body oeuv-modal-body">
                    <form id="oeuvreForm" novalidate>
                        <input type="hidden" id="formOeuvreId" value="">

                        <div class="row g-3">
                            {# ID Œuvre #}
                            <div class="col-md-6">
                                <label for="inputOeuvreId" class="form-label-custom"><i class="fas fa-hashtag me-1"></i> ID Œuvre</label>
                                <input type="text" class="form-control admin-form-control" id="inputOeuvreId" placeholder="Auto-generated" readonly>
                                <small class="form-text-muted">Auto-generated by system</small>
                            </div>

                            {# Year Created #}
                            <div class="col-md-6">
                                <label for="inputAnnee" class="form-label-custom"><i class="fas fa-calendar-alt me-1"></i> Year Created <span class="text-danger">*</span></label>
                                <input type="number" class="form-control admin-form-control" id="inputAnnee" min="1800" max="2026" placeholder="e.g., 2024" required>
                                <div class="invalid-feedback">Please enter a valid year.</div>
                            </div>

                            {# Titre #}
                            <div class="col-md-6">
                                <label for="inputTitre" class="form-label-custom"><i class="fas fa-heading me-1"></i> Title <span class="text-danger">*</span></label>
                                <input type="text" class="form-control admin-form-control" id="inputTitre" placeholder="e.g., La Nuit Étoilée" required>
                                <div class="invalid-feedback">Please enter a title.</div>
                            </div>

                            {# Nom Tableau #}
                            <div class="col-md-6">
                                <label for="inputNomTableau" class="form-label-custom"><i class="fas fa-signature me-1"></i> Artwork Name <span class="text-danger">*</span></label>
                                <input type="text" class="form-control admin-form-control" id="inputNomTableau" placeholder="e.g., Starry Night Reimagined" required>
                                <div class="invalid-feedback">Please enter artwork name.</div>
                            </div>

                            {# Gallery #}
                            <div class="col-md-6">
                                <label for="inputGalerie" class="form-label-custom"><i class="fas fa-building-columns me-1"></i> Gallery <span class="text-danger">*</span></label>
                                <select class="form-select admin-select" id="inputGalerie" required>
                                    <option value="" disabled selected>Select gallery…</option>
                                    <option value="1">Galerie Moderne</option>
                                    <option value="2">Galerie Classique</option>
                                    <option value="3">Galerie Urbaine</option>
                                    <option value="4">Galerie Sculpture</option>
                                    <option value="5">Galerie Photo</option>
                                    <option value="6">Galerie Abstract</option>
                                </select>
                                <div class="invalid-feedback">Please select a gallery.</div>
                            </div>

                            {# Artist #}
                            <div class="col-md-6">
                                <label for="inputArtiste" class="form-label-custom"><i class="fas fa-user-circle me-1"></i> Artist <span class="text-danger">*</span></label>
                                <select class="form-select admin-select" id="inputArtiste" required>
                                    <option value="" disabled selected>Select artist…</option>
                                    <option value="1">Sophie Martin</option>
                                    <option value="2">Ahmed Ben Ali</option>
                                    <option value="3">Clara Dubois</option>
                                    <option value="4">Marc Lefevre</option>
                                    <option value="5">Lina Haddad</option>
                                    <option value="6">Thomas Blanc</option>
                                </select>
                                <div class="invalid-feedback">Please select an artist.</div>
                            </div>

                            {# Prix #}
                            <div class="col-md-6">
                                <label for="inputPrix" class="form-label-custom"><i class="fas fa-euro-sign me-1"></i> Price (€) <span class="text-danger">*</span></label>
                                <input type="number" class="form-control admin-form-control" id="inputPrix" min="0" step="0.01" placeholder="e.g., 45000" required>
                                <div class="invalid-feedback">Please enter a valid price.</div>
                            </div>

                            {# Condition #}
                            <div class="col-md-6">
                                <label for="inputEtat" class="form-label-custom"><i class="fas fa-star me-1"></i> Condition <span class="text-danger">*</span></label>
                                <select class="form-select admin-select" id="inputEtat" required>
                                    <option value="" disabled selected>Select condition…</option>
                                    <option value="neuf">Neuf</option>
                                    <option value="bon">Bon</option>
                                    <option value="endommagé">Endommagé</option>
                                </select>
                                <div class="invalid-feedback">Please select a condition.</div>
                            </div>
                        </div>
                    </form>
                </div>

                <div class="modal-footer oeuv-modal-footer">
                    <button type="button" class="btn btn-admin-outline" data-bs-dismiss="modal">
                        <i class="fas fa-times me-1"></i> Cancel
                    </button>
                    <button type="button" class="btn btn-admin-primary" id="saveOeuvreBtn">
                        <i class="fas fa-check me-1"></i> <span id="saveOeuvreBtnText">Add Œuvre</span>
                    </button>
                </div>
            </div>
        </div>
    </div>

    {# ═══════════════════════════════════════════════════════════════
       DELETE CONFIRMATION ALERT
    ═══════════════════════════════════════════════════════════════ #}
    <div class="delete-alert-overlay" id="deleteOeuvreAlert">
        <div class="delete-alert-card">
            <div class="delete-alert-icon">
                <i class="fas fa-exclamation-triangle"></i>
            </div>
            <h4 class="delete-alert-title">Delete Artwork?</h4>
            <p class="delete-alert-message">
                Are you sure you want to delete <strong id="deleteOeuvreName">this artwork</strong>?<br>
                This action cannot be undone.
            </p>
            <div class="delete-alert-actions">
                <button class="btn btn-admin-outline" id="cancelDeleteOeuvreBtn">
                    <i class="fas fa-times me-1"></i> Cancel
                </button>
                <button class="btn btn-danger" id="confirmDeleteOeuvreBtn">
                    <i class="fas fa-trash-can me-1"></i> Delete
