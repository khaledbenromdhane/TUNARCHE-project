{% extends 'base.html.twig' %}

{% block body %}
<div class="container mt-5 text-center">
    <div class="card shadow p-5">
        <h1>Résultat du Quiz : {{ quiz.title }}</h1>
        <hr>
        <h2 class="display-4">Score : {{ score }} / {{ total }}</h2>

        {% if isPassed %}
            <div class="alert alert-success mt-4">
                <h3>✅ Félicitations ! Vous avez réussi.</h3>
                <p class="mb-0">
                    Badge obtenu : 
                    {% if badge == 'Gold' %}
                        <span class="badge bg-warning text-dark fs-6">🥇 Gold</span>
                    {% elseif badge == 'Silver' %}
                        <span class="badge bg-secondary fs-6">🥈 Silver</span>
                    {% else %}
                        <span class="badge bg-danger fs-6">🥉 Bronze</span>
                    {% endif %}
                </p>
            </div>

            {# ✅ GENERATE CERTIFICATE BUTTON #}
            <div class="mt-3">
                <a href="{{ path('quiz_certificat', {'id': quiz.id}) }}"
                   class="btn btn-success btn-lg"
                   target="_blank">
                    <i class="fas fa-file-pdf me-2"></i> Générer mon Certificat PDF
                </a>
            </div>

        {% else %}
            <div class="alert alert-danger mt-4">
                <h3>❌ Dommage ! Vous n'avez pas atteint le score requis.</h3>
                <p class="mb-0">Score minimum requis : 50%</p>
            </div>
        {% endif %}

        <div class="mt-4">
            <a href="{{ path('quiz_pass', {'id': quiz.id}) }}" class="btn btn-primary">
                <i class="fas fa-redo me-1"></i> Réessayer
            </a>
            <a href="{{ path('app_formation_front') }}" class="btn btn-secondary">
                <i class="fas fa-arrow-left me-1"></i> Retour aux formations
            </a>
        </div>
    </div>
</div>
{% endblock %}