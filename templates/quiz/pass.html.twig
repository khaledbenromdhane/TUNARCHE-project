{% extends 'base.html.twig' %}

{% block body %}
<div class="container mt-5">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>{{ quiz.title }}</h2>
        <div>
            <button onclick="readAllQuestions()" class="btn btn-primary me-2">
                <i class="fas fa-volume-up me-1"></i> Lire tout
            </button>
            <button onclick="stopReading()" class="btn btn-outline-danger">
                <i class="fas fa-stop me-1"></i> Stop
            </button>
        </div>
    </div>

    <form method="post">

        {% for question in quiz.questions %}
            <div class="card p-3 mb-4" id="card-{{ loop.index }}">

                <div class="d-flex justify-content-between align-items-start mb-2">
                    <h5 class="question-text mb-0">
                        {{ loop.index }}. {{ question.questionText }}
                    </h5>
                    <button type="button"
                            onclick="readQuestion({{ loop.index }}, '{{ question.questionText|e('js') }}', '{{ question.choiceA|e('js') }}', '{{ question.choiceB|e('js') }}', '{{ question.choiceC|e('js') }}')"
                            class="btn btn-sm btn-outline-primary ms-2"
                            title="Lire cette question">
                        <i class="fas fa-volume-up"></i>
                    </button>
                </div>

                <div class="form-check">
                    <input class="form-check-input"
                           type="radio"
                           name="question_{{ question.id }}"
                           value="A"
                           id="q{{ question.id }}A"
                           required>
                    <label class="form-check-label" for="q{{ question.id }}A">
                        A — {{ question.choiceA }}
                    </label>
                </div>

                <div class="form-check">
                    <input class="form-check-input"
                           type="radio"
                           name="question_{{ question.id }}"
                           value="B"
                           id="q{{ question.id }}B">
                    <label class="form-check-label" for="q{{ question.id }}B">
                        B — {{ question.choiceB }}
                    </label>
                </div>

                <div class="form-check">
                    <input class="form-check-input"
                           type="radio"
                           name="question_{{ question.id }}"
                           value="C"
                           id="q{{ question.id }}C">
                    <label class="form-check-label" for="q{{ question.id }}C">
                        C — {{ question.choiceC }}
                    </label>
                </div>

            </div>
        {% endfor %}

        <button type="submit" class="btn btn-success">
            Valider Quiz
        </button>

    </form>

</div>

<script>
// ✅ Collect all questions data
const questions = [
    {% for question in quiz.questions %}
    {
        index: {{ loop.index }},
        text: "{{ question.questionText|e('js') }}",
        choiceA: "{{ question.choiceA|e('js') }}",
        choiceB: "{{ question.choiceB|e('js') }}",
        choiceC: "{{ question.choiceC|e('js') }}",
        cardId: "card-{{ loop.index }}"
    }{% if not loop.last %},{% endif %}
    {% endfor %}
];

let currentCard = null;

// ✅ Highlight active card
function highlightCard(cardId) {
    if (currentCard) {
        document.getElementById(currentCard).style.border = '';
        document.getElementById(currentCard).style.boxShadow = '';
    }
    currentCard = cardId;
    const card = document.getElementById(cardId);
    card.style.border = '2px solid #0d6efd';
    card.style.boxShadow = '0 0 10px rgba(13,110,253,0.3)';
    card.scrollIntoView({ behavior: 'smooth', block: 'center' });
}

// ✅ Read single question
function readQuestion(index, text, choiceA, choiceB, choiceC) {
    stopReading();
    highlightCard('card-' + index);

    const fullText = `Question ${index}. ${text}. Option A : ${choiceA}. Option B : ${choiceB}. Option C : ${choiceC}.`;

    const utterance = new SpeechSynthesisUtterance(fullText);
    utterance.lang = 'fr-FR';
    utterance.rate = 0.85;
    utterance.pitch = 1;

    // Pick best French voice
    const voices = speechSynthesis.getVoices();
    const frVoice = voices.find(v => v.lang === 'fr-FR' && v.name.includes('Google'))
                 || voices.find(v => v.lang === 'fr-FR')
                 || voices.find(v => v.lang.startsWith('fr'));
    if (frVoice) utterance.voice = frVoice;

    speechSynthesis.speak(utterance);
}

// ✅ Read all questions one by one
function readAllQuestions() {
    stopReading();
    let delay = 0;

    questions.forEach((q, i) => {
        setTimeout(() => {
            readQuestion(q.index, q.text, q.choiceA, q.choiceB, q.choiceC);
        }, delay);
        // estimate ~6 seconds per question
        delay += (q.text.length + q.choiceA.length + q.choiceB.length + q.choiceC.length) * 60;
    });
}

// ✅ Stop reading
function stopReading() {
    speechSynthesis.cancel();
    if (currentCard) {
        document.getElementById(currentCard).style.border = '';
        document.getElementById(currentCard).style.boxShadow = '';
        currentCard = null;
    }
}

// Load voices
window.speechSynthesis.onvoiceschanged = () => { speechSynthesis.getVoices(); };
</script>

{% endblock %}