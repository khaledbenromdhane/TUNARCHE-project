{% extends 'back/base_admin.html.twig' %}

{% block title %}Modifier Quiz{% endblock %}
{% block page_title %}Gestion des Quiz{% endblock %}

{% block body %}
<div class="row justify-content-center">
    <div class="col-md-10">
        <div class="card card-outline card-warning shadow-sm">
            <div class="card-header">
                <h3 class="card-title">
                    <i class="fas fa-question-circle me-2"></i> 
                    Modifier le Quiz : <strong>{{ quiz.title }}</strong>
                </h3>
            </div>
            
            <div class="card-body">
                {# Inclusion du formulaire avec le style Bootstrap 5 #}
                {{ include('admin_quiz/_form.html.twig', {'button_label': 'Mettre à jour le quiz'}) }}
            </div>

            <div class="card-footer bg-light d-flex justify-content-between">
                <a href="{{ path('app_admin_quiz_index') }}" class="btn btn-secondary">
                    <i class="fas fa-arrow-left me-1"></i> Retour à la liste
                </a>
                
                {# Bouton de suppression stylisé #}
                <form method="post" action="{{ path('app_admin_quiz_delete', {'id': quiz.id}) }}" onsubmit="return confirm('Êtes-vous sûr de vouloir supprimer ce quiz ?');">
                    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ quiz.id) }}">
                    <button class="btn btn-danger">
                        <i class="fas fa-trash me-1"></i> Supprimer
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>
{% endblock %}