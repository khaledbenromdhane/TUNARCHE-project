{{ form_start(form) }}
    <div class="mb-3">
        {{ form_label(form.title, 'Titre du Quiz', {'label_attr': {'class': 'form-label'}}) }}
        {{ form_widget(form.title, {'attr': {'class': 'form-control', 'placeholder': 'Entrez le titre...'}}) }}
        {{ form_errors(form.title) }}
    </div>

    <div class="mb-3">
        {{ form_label(form.formation, 'Formation associée', {'label_attr': {'class': 'form-label'}}) }}
        {{ form_widget(form.formation, {'attr': {'class': 'form-select'}}) }}
        {{ form_errors(form.formation) }}
    </div>

    <button class="btn btn-primary w-100">
        <i class="fas fa-save me-1"></i> {{ button_label|default('Enregistrer') }}
    </button>
{{ form_end(form) }}