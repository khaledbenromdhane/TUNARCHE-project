{% extends 'base.html.twig' %}

{% block body %}
<div class="container mt-4">
    <h2>Liste des Quiz</h2>

    <a href="{{ path('app_admin_quiz_new') }}" class="btn btn-success mb-3">
        ➕ Nouveau Quiz
    </a>

    <table class="table table-bordered">
        <thead>
            <tr>
                <th>ID</th>
                <th>Titre</th>
                <th>Formation</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
        {% for quiz in quizzes %}
            <tr>
                <td>{{ quiz.id }}</td>
                <td>{{ quiz.title }}</td>
                <td>{{ quiz.formation.title }}</td>
                <td>
                    <a href="{{ path('app_admin_quiz_show', {'id': quiz.id}) }}" class="btn btn-info btn-sm">Voir</a>
                    <a href="{{ path('app_admin_quiz_edit', {'id': quiz.id}) }}" class="btn btn-warning btn-sm">Modifier</a>
                    {{ include('quiz/_delete_form.html.twig') }}
                </td>
            </tr>
        {% else %}
            <tr>
                <td colspan="4">Aucun quiz trouvé</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>
</div>
{% endblock %}