<!doctype html>
<html class="no-js" lang="fr">

<head>
    <meta charset="utf-8">
    <meta http-equiv="x-ua-compatible" content="ie=edge">
    <title>{% block title %}Artvista{% endblock %}</title>
    <meta name="description" content="Artvista - Museum & Art Gallery">
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">

    <!-- Favicons -->
    <link rel="icon" type="image/png" sizes="32x32" href="{{ asset('assets/img/favicons/favicon.png') }}">
    <meta name="theme-color" content="#ffffff">

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Jost:ital,wght@0,100..900;1,100..900&family=Roboto:ital,wght@0,100;0,300;0,400;0,500;0,700;0,900;1,100;1,300;1,400;1,500;1,700;1,900&display=swap" rel="stylesheet">

    <!-- CSS -->
    <link rel="stylesheet" href="{{ asset('assets/css/bootstrap.min.css') }}">
    <link rel="stylesheet" href="{{ asset('assets/css/all.min.css') }}">
    <link rel="stylesheet" href="{{ asset('assets/css/magnific-popup.min.css') }}">
    <link rel="stylesheet" href="{{ asset('assets/css/slick.min.css') }}">
    <link rel="stylesheet" href="{{ asset('assets/css/odometer.css') }}">
    <link rel="stylesheet" href="{{ asset('assets/css/style.css') }}">

    {% block stylesheets %}{% endblock %}

    <style>
        /* ── Avatar Profile Menu ── */
        .user-avatar-btn {
            display: flex; align-items: center; gap: 8px;
            background: none; border: none; cursor: pointer;
            color: inherit; text-decoration: none;
        }
        .user-avatar-btn img {
            width: 36px; height: 36px;
            border-radius: 50%;
            object-fit: cover;
            border: 2px solid #d4a574;
        }
        .user-avatar-btn .user-name {
            font-size: 14px; font-weight: 500;
        }
        .profile-dropdown {
            min-width: 220px;
            border: none;
            box-shadow: 0 8px 30px rgba(0,0,0,0.15);
            border-radius: 12px;
            overflow: hidden;
        }
        .profile-dropdown .dropdown-header {
            background: linear-gradient(135deg, #d4a574, #c4924e);
            color: white; padding: 16px;
        }
        .profile-dropdown .dropdown-header img {
            width: 55px; height: 55px;
            border-radius: 50%; object-fit: cover;
            border: 3px solid rgba(255,255,255,0.5);
            margin-bottom: 8px;
        }
        .profile-dropdown .dropdown-item {
            padding: 10px 16px; font-size: 14px;
            display: flex; align-items: center; gap: 10px;
        }
        .profile-dropdown .dropdown-item:hover {
            background-color: #f8f4ef; color: #d4a574;
        }
        .profile-dropdown .dropdown-item i { width: 16px; color: #d4a574; }
        .profile-dropdown .dropdown-item.text-danger i { color: #dc3545; }
    </style>
</head>

<body>

    <!-- Cursor -->
    <div class="cursor"></div>
    <div class="cursor-follower"></div>

    <!--==============================
     Preloader
    ==============================-->
    <div class="preloader">
        <div class="preloader-inner">
            <img src="{{ asset('assets/img/logo-white.svg') }}" alt="Artvista">
            <span class="loader"></span>
        </div>
    </div>

    <!--==============================
    Sidemenu
    ==============================-->
    <div class="sidemenu-wrapper">
        <div class="sidemenu-content">
            <button class="closeButton sideMenuCls"><i class="fas fa-times"></i></button>

            {# ── Auth dans sidemenu ── #}
            <div class="widget footer-widget mb-4">
                <h4 class="widget_title text-white mb-3">Mon Compte</h4>
                {% if app.user %}
                    <div class="d-flex align-items-center gap-2 mb-3">
                        <img src="{{ app.user.avatarUrl }}"
                             alt="Avatar"
                             style="width:45px;height:45px;border-radius:50%;object-fit:cover;border:2px solid #d4a574;">
                        <div>
                            <div class="text-white fw-bold">{{ app.user.prenom }} {{ app.user.nom }}</div>
                            <small class="text-muted">{{ app.user.email }}</small>
                        </div>
                    </div>
                    <a href="{{ path('app_profile') }}" class="btn w-100 mb-2">
                        <i class="fas fa-user me-2"></i>Mon Profil
                    </a>
                    <a href="{{ path('app_logout') }}" class="btn style2 w-100">
                        <i class="fas fa-sign-out-alt me-2"></i>Déconnexion
                    </a>
                {% else %}
                    <a href="{{ path('app_login') }}" class="btn w-100 mb-2">
                        <i class="fas fa-sign-in-alt me-2"></i>Connexion
                    </a>
                    <a href="{{ path('app_register') }}" class="btn style2 w-100">
                        <i class="fas fa-user-plus me-2"></i>Inscription
                    </a>
                {% endif %}
            </div>

            <div class="widget footer-widget">
                <div class="widget widget-about footer-widget">
                    <div class="footer-logo">
                        <a href="{{ path('app_home') }}"><img src="{{ asset('assets/img/logo-white.svg') }}" alt="logo"></a>
                    </div>
                    <p class="about-text mb-4 text-white">Bienvenue chez Artvista, où l'histoire prend vie et l'art parle.</p>
                    <p class="footer-text text-white">
                        <a href="tel:+216 72 379 121"><i class="fas fa-phone-alt me-2"></i>+216 72 379 121</a>
                    </p>
                    <p class="contact-text text-white"><i class="fa fa-map-marker-alt me-2"></i> Tunis, Rue de la Liberté 24</p>
                    <p class="footer-text text-white"><a href="mailto:support@artvista.com"><i class="fas fa-envelope me-2"></i>support@artvista.com</a></p>
                    <div class="social-btn style2 mt-30">
                        <a href="https://facebook.com/"><i class="fab fa-facebook-f"></i></a>
                        <a href="https://www.twitter.com/"><i class="fab fa-twitter"></i></a>
                        <a href="https://linkedin.com/"><i class="fab fa-linkedin-in"></i></a>
                        <a href="https://instagram.com/"><i class="fab fa-instagram"></i></a>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!--==============================
    PopUp Search
    ==============================-->
    <div class="popup-search-box">
        <button class="searchClose"><i class="fas fa-times"></i></button>
        <form action="#">
            <input type="text" placeholder="Rechercher..">
            <button type="submit"><i class="fas fa-search"></i></button>
        </form>
    </div>

    <!--==============================
    Mobile Menu
    ==============================-->
    <div class="mobile-menu-wrapper">
        <div class="mobile-menu-area text-center">
            <button class="menu-toggle"><i class="fas fa-times"></i></button>
            <div class="mobile-logo">
                <a href="{{ path('app_home') }}"><img src="{{ asset('assets/img/logo-white.svg') }}" alt="Artvista"></a>
            </div>
            <div class="mobile-menu">
                <ul>
                    {% if app.user %}
                        <li>
                            <a href="{{ path('app_profile') }}">
                                <i class="fas fa-user-circle me-2"></i>Mon Profil
                            </a>
                        </li>
                        {% if is_granted('ROLE_ADMIN') %}
                            <li><a href="{{ path('app_admin_dashboard') }}"><i class="fas fa-tachometer-alt me-2"></i>Administration</a></li>
                        {% endif %}
                        <li><a href="{{ path('app_logout') }}"><i class="fas fa-sign-out-alt me-2"></i>Déconnexion</a></li>
                    {% else %}
                        <li><a href="{{ path('app_login') }}"><i class="fas fa-sign-in-alt me-2"></i>Connexion</a></li>
                        <li><a href="{{ path('app_register') }}"><i class="fas fa-user-plus me-2"></i>Inscription</a></li>
                    {% endif %}
                    <li><a href="{{ path('app_front_index') }}">Accueil</a></li>
                    <li><a href="{{ path('app_front_oeuvre') }}">Œuvres</a></li>
                    <li><a href="{{ path('app_evenement_index') }}">Événements</a></li>
                    <li><a href="{{ path('blog_publication_index') }}">Blog</a></li>
                    <li><a href="{{ path('app_formation_front') }}">Formation</a></li>
                </ul>
            </div>
        </div>
    </div>

    <!--==============================
    Header
    ==============================-->
    <header class="nav-header header-layout1">
        <div class="header-top d-md-block d-none">
            <div class="container">
                <div class="row justify-content-center justify-content-lg-between align-items-center gy-2">
                    <div class="col-auto">
                        <div class="header-links">
                            <ul>
                                <li>
                                    <svg width="17" height="17" viewBox="0 0 17 17" fill="none" xmlns="http://www.w3.org/2000/svg">
                                        <path d="M15 11.0312L11.9375 9.71875C11.25 9.40625 10.4688 9.625 10 10.1875L9.15625 11.2188C7.75 10.4062 6.59375 9.25 5.78125 7.875L6.84375 7.03125C7.375 6.5625 7.59375 5.78125 7.3125 5.125L5.96875 2C5.65625 1.28125 4.875 0.875 4.09375 1.0625L1.25 1.71875C0.5 1.875 0 2.53125 0 3.3125C0 10.875 6.125 17 13.6875 17C14.4688 17 15.125 16.5 15.25 15.75L15.9062 12.9062C16.125 12.125 15.7188 11.3438 15 11.0312ZM14.4688 12.5625L13.8125 15.4062C13.8125 15.4375 13.75 15.5 13.6875 15.5C6.96875 15.5 1.46875 10.0312 1.46875 3.3125C1.46875 3.25 1.53125 3.1875 1.59375 3.1875L4.4375 2.53125L4.46875 2.5C4.53125 2.5 4.5625 2.5625 4.59375 2.59375L5.90625 5.65625C5.9375 5.71875 5.9375 5.78125 5.875 5.8125L4.34375 7.0625C4.09375 7.28125 4 7.65625 4.15625 7.96875C5.1875 10.0625 6.90625 11.7812 9 12.8125C9.3125 12.9688 9.71875 12.9062 9.9375 12.625L11.1875 11.0938C11.2188 11.0625 11.2812 11.0312 11.3438 11.0625L14.4062 12.375C14.4688 12.4375 14.5 12.5 14.4688 12.5625Z" fill="inherit"/>
                                    </svg>
                                    <a href="tel:012041654">Des questions ?</a>
                                </li>
                                <li><i class="far fa-envelope"></i><a href="mailto:info@artvista.com">info@artvista.com</a></li>
                                <li><i class="far fa-clock"></i>Lun - Ven: 8:00 - 18:00</li>
                            </ul>
                        </div>
                    </div>
                    <div class="col-auto d-none d-lg-block">
                        <div class="header-links header-links-right">
                            <ul>
                                {# ── Bloc AUTH ── #}
                                <li>
                                    {% if app.user %}
                                        <div class="dropdown">
                                            <a class="user-avatar-btn dropdown-toggle"
                                               href="#"
                                               role="button"
                                               data-bs-toggle="dropdown"
                                               aria-expanded="false">
                                                <img src="{{ app.user.avatarUrl }}"
                                                     alt="{{ app.user.prenom }}"
                                                     onerror="this.src='https://ui-avatars.com/api/?name={{ app.user.prenom|url_encode }}+{{ app.user.nom|url_encode }}&background=d4a574&color=fff'">
                                                <span class="user-name">{{ app.user.prenom }}</span>
                                                <i class="fas fa-chevron-down ms-1" style="font-size:10px;"></i>
                                            </a>
                                            <ul class="dropdown-menu dropdown-menu-end profile-dropdown">
                                                <li>
                                                    <div class="dropdown-header text-center">
                                                        <img src="{{ app.user.avatarUrl }}"
                                                             alt="{{ app.user.prenom }}"
                                                             onerror="this.src='https://ui-avatars.com/api/?name={{ app.user.prenom|url_encode }}+{{ app.user.nom|url_encode }}&background=d4a574&color=fff'">
                                                        <div class="fw-bold">{{ app.user.prenom }} {{ app.user.nom }}</div>
                                                        <small style="opacity:.8;">{{ app.user.email }}</small>
                                                        <div class="mt-1">
                                                            {% for role in app.user.roles %}
                                                                {% if role != 'ROLE_USER' %}
                                                                    <span class="badge" style="background:rgba(255,255,255,0.3);font-size:10px;">
                                                                        {{ role|replace({'ROLE_': ''}) }}
                                                                    </span>
                                                                {% endif %}
                                                            {% endfor %}
                                                        </div>
                                                    </div>
                                                </li>
                                                <li><hr class="dropdown-divider m-0"></li>
                                                <li>
                                                    <a class="dropdown-item" href="{{ path('app_profile') }}">
                                                        <i class="fas fa-user"></i> Mon Profil
                                                    </a>
                                                </li>
                                                <li>
                                                    <a class="dropdown-item" href="{{ path('app_profile_edit') }}">
                                                        <i class="fas fa-edit"></i> Modifier le profil
                                                    </a>
                                                </li>
                                                {% if is_granted('ROLE_ADMIN') %}
                                                    <li><hr class="dropdown-divider"></li>
                                                    <li>
                                                        <a class="dropdown-item" href="{{ path('app_admin_dashboard') }}">
                                                            <i class="fas fa-tachometer-alt"></i> Administration
                                                        </a>
                                                    </li>
                                                    <li>
                                                        <a class="dropdown-item" href="{{ path('app_admin_users_index') }}">
                                                            <i class="fas fa-users-cog"></i> Gestion utilisateurs
                                                        </a>
                                                    </li>
                                                {% endif %}
                                                <li><hr class="dropdown-divider"></li>
                                                <li>
                                                    <a class="dropdown-item text-danger" href="{{ path('app_logout') }}">
                                                        <i class="fas fa-sign-out-alt"></i> Déconnexion
                                                    </a>
                                                </li>
                                            </ul>
                                        </div>
                                    {% else %}
                                        <i class="fas fa-user"></i>
                                        <a href="{{ path('app_login') }}">Connexion</a>
                                        <span style="margin:0 5px;">|</span>
                                        <a href="{{ path('app_register') }}">Inscription</a>
                                    {% endif %}
                                </li>
                                <li>
                                    <button type="button" class="sidebar-btn sideMenuToggler">
                                        <span class="line"></span>
                                    </button>
                                </li>
                            </ul>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="sticky-wrapper">
            <div class="menu-area">
                <div class="container">
                    <div class="row align-items-center justify-content-between">
                        <div class="col-auto">
                            <div class="header-logo">
                                <a href="{{ path('app_home') }}"><img src="{{ asset('assets/img/logo.svg') }}" alt="logo"></a>
                            </div>
                        </div>
                        <div class="col-auto">
                            <nav class="main-menu d-none d-lg-inline-block">
                                <ul>
                                    <li><a href="{{ path('app_front_index') }}">Accueil</a></li>
                                    <li><a href="{{ path('app_front_oeuvre') }}">Œuvres</a></li>
                                    <li><a href="{{ path('app_evenement_index') }}">Événements</a></li>
                                    <li><a href="{{ path('blog_publication_index') }}">Blog</a></li>
                                    <li><a href="{{ path('app_formation_front') }}">Formation</a></li>
                                </ul>
                            </nav>
                            <div class="navbar-right d-inline-flex d-lg-none">
                                <button type="button" class="menu-toggle icon-btn"><i class="fas fa-bars"></i></button>
                            </div>
                        </div>
                        <div class="col-auto d-none d-xl-block">
                            <div class="header-button">
                                <a href="{{ path('app_evenement_index') }}" class="btn d-none d-xl-block">
                                    ÉVÉNEMENTS & TICKETS
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </header>

    <div id="smooth-wrapper">
        <div id="smooth-content">

            <!--==============================
            Breadcrumb
            ==============================-->
            {% block breadcrumb %}{% endblock %}

            <!--==============================
            Main Content
            ==============================-->
            {% block body %}{% endblock %}

            <!--==============================
            Footer
            ==============================-->
            <footer class="footer-wrapper footer-layout2 space-top overflow-hidden">
                <div class="container">
                    <div class="footer-top text-center">
                        <p class="subtitle">À travers les visites et les expositions</p>
                        <h2 class="title text-white">RESTEZ EN CONTACT</h2>
                        <a class="btn" href="#">Contactez-nous !</a>
                    </div>
                    <div class="widget-area">
                        <div class="row justify-content-xl-between">
                            <div class="col-md-6 col-xl-3 col-lg-4">
                                <div class="widget footer-widget">
                                    <div class="widget-about">
                                        <div class="footer-logo">
                                            <img src="{{ asset('assets/img/logo-white.svg') }}" alt="logo">
                                        </div>
                                        <p class="footer-text">Bienvenue chez Artvista, où l'histoire prend vie et l'art parle.</p>
                                        <div class="payment-card-wrap">
                                            <a href="#"><img src="{{ asset('assets/img/icon/payment-card1.png') }}" alt="img"></a>
                                            <a href="#"><img src="{{ asset('assets/img/icon/payment-card2.png') }}" alt="img"></a>
                                            <a href="#"><img src="{{ asset('assets/img/icon/payment-card3.png') }}" alt="img"></a>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <div class="col-md-6 col-xl-auto col-lg-4">
                                <div class="widget widget_nav_menu footer-widget">
                                    <h3 class="widget_title">Liens Rapides</h3>
                                    <div class="menu-all-pages-container">
                                        <ul class="menu">
                                            <li><a href="{{ path('app_home') }}">Accueil</a></li>
                                            <li><a href="{{ path('app_evenement_index') }}">Événements</a></li>
                                            <li><a href="#">À propos</a></li>
                                        </ul>
                                    </div>
                                </div>
                            </div>
                            <div class="col-md-6 col-xl-auto col-lg-4">
                                <div class="widget widget_nav_menu footer-widget">
                                    <h3 class="widget_title">Info Visiteurs</h3>
                                    <div class="menu-all-pages-container">
                                        <ul class="menu">
                                            <li><a href="#">Comment nous trouver</a></li>
                                            <li><a href="{{ path('app_evenement_index') }}">Obtenir un Ticket</a></li>
                                            <li><a href="{{ path('app_evenement_index') }}">Rejoindre un Événement</a></li>
                                            <li><a href="#">Visites</a></li>
                                        </ul>
                                    </div>
                                </div>
                            </div>
                            <div class="col-md-6 col-xl-auto col-lg-4">
                                <div class="widget widget_nav_menu footer-widget">
                                    <h3 class="widget_title">Réseaux Sociaux</h3>
                                    <div class="menu-all-pages-container">
                                        <ul class="menu">
                                            <li><a href="https://www.facebook.com/">Facebook</a></li>
                                            <li><a href="https://www.twitter.com/">Twitter</a></li>
                                            <li><a href="https://www.linkedin.com/">LinkedIn</a></li>
                                            <li><a href="https://www.instagram.com/">Instagram</a></li>
                                        </ul>
                                    </div>
                                </div>
                            </div>
                            <div class="col-md-6 col-xl-auto col-lg-4">
                                <div class="widget footer-widget">
                                    <div class="widget-contact">
                                        <h3 class="widget_title">Contact</h3>
                                        <ul class="contact-info-list">
                                            <li>Ouvert tous les jours, 10h - 22h</li>
                                            <li class="text-light">Lundi Fermé</li>
                                            <li>Tunis, Rue de la Liberté 24</li>
                                            <li>artvista@gmail.com</li>
                                        </ul>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="copyright-wrap text-center">
                    <div class="container">
                        <div class="row gy-3 justify-content-lg-between justify-content-center">
                            <div class="col-lg-auto align-self-center">
                                <p class="copyright-text text-white">&copy; {{ "now"|date("Y") }} Artvista. Tous droits réservés.</p>
                            </div>
                            <div class="col-lg-auto align-self-center">
                                <div class="footer-links">
                                    <ul>
                                        <li><a href="#">Sécurité</a></li>
                                        <li><a href="#">Politique de confidentialité</a></li>
                                        <li><a href="#">Conditions d'utilisation</a></li>
                                    </ul>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </footer>

        </div>
    </div>

    <!-- Scroll To Top -->
    <div class="scroll-top">
        <svg class="progress-circle svg-content" width="100%" height="100%" viewBox="-1 -1 102 102">
            <path d="M50,1 a49,49 0 0,1 0,98 a49,49 0 0,1 0,-98" style="transition: stroke-dashoffset 10ms linear 0s; stroke-dasharray: 307.919, 307.919; stroke-dashoffset: 307.919;"></path>
        </svg>
    </div>

    <!--==============================
    JS Files
    ==============================-->
    <script src="{{ asset('assets/js/vendor/jquery-3.7.1.min.js') }}"></script>
    <script src="{{ asset('assets/js/slick.min.js') }}"></script>
    <script src="{{ asset('assets/js/bootstrap.min.js') }}"></script>
    <script src="{{ asset('assets/js/jquery.magnific-popup.min.js') }}"></script>
    <script src="{{ asset('assets/js/jquery.counterup.min.js') }}"></script>
    <script src="{{ asset('assets/js/jquery-ui.min.js') }}"></script>
    <script src="{{ asset('assets/js/jquery.marquee.min.js') }}"></script>
    <script src="{{ asset('assets/js/imagesloaded.pkgd.min.js') }}"></script>
    <script src="{{ asset('assets/js/isotope.pkgd.min.js') }}"></script>
    <script src="{{ asset('assets/js/ScrollTrigger.min.js') }}"></script>
    <script src="{{ asset('assets/js/ScrollSmoother.min.js') }}"></script>
    <script src="{{ asset('assets/js/ScrollToPlugin.min.js') }}"></script>
    <script src="{{ asset('assets/js/SplitText.min.js') }}"></script>
    <script src="{{ asset('assets/js/gsap.min.js') }}"></script>
    <script src="{{ asset('assets/js/waypoints.js') }}"></script>
    <script src="{{ asset('assets/js/wow.js') }}"></script>
    <script src="{{ asset('assets/js/main.js') }}"></script>

    {% block javascripts %}{% endblock %}
</body>

</html>
