    <meta name="keywords" content="Artvista - Museum & Art Gallery HTML Template">
    <meta name="robots" content="INDEX,FOLLOW">

    <!-- Mobile Specific Metas -->
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">

    <!-- Favicons - Place favicon.ico in the root directory -->
    <link rel="icon" type="image/png" sizes="32x32" href="{{ fa }}/img/favicons/favicon.png">
    <meta name="msapplication-TileColor" content="#ffffff">
    <meta name="msapplication-TileImage" content="{{ fa }}/img/favicons/ms-icon-144x144.png">
    <meta name="theme-color" content="#ffffff">

    <!--==============================
	  Google Fonts
	============================== -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Jost:ital,wght@0,100..900;1,100..900&family=Roboto:ital,wght@0,100;0,300;0,400;0,500;0,700;0,900;1,100;1,300;1,400;1,500;1,700;1,900&display=swap" rel="stylesheet">


    <!--==============================
	    All CSS File
	============================== -->
    <!-- Bootstrap -->
    <link rel="stylesheet" href="{{ fa }}/css/bootstrap.min.css">
    <!-- Fontawesome Icon -->
    <link rel="stylesheet" href="{{ fa }}/css/all.min.css">
    <!-- Magnific Popup -->
    <link rel="stylesheet" href="{{ fa }}/css/magnific-popup.min.css">
    <!-- Slick Slider -->
    <link rel="stylesheet" href="{{ fa }}/css/slick.min.css">
    <!-- Odometer -->
    <link rel="stylesheet" href="{{ fa }}/css/odometer.css">
    <!-- Theme Custom CSS -->
    <link rel="stylesheet" href="{{ fa }}/css/style.css">

    <style>
        .user-avatar-btn {
            display: flex; align-items: center; gap: 8px;
            background: none; border: none; cursor: pointer;
            color: inherit; text-decoration: none;
        }
        .user-avatar-btn img {
            width: 36px; height: 36px;
            border-radius: 50%; object-fit: cover;
            border: 2px solid #d4a574;
        }
        .user-avatar-btn .user-name { font-size: 14px; font-weight: 500; }
        .profile-dropdown {
            min-width: 220px; border: none;
            box-shadow: 0 8px 30px rgba(0,0,0,0.15);
            border-radius: 12px; overflow: hidden;
        }
        .profile-dropdown .dropdown-header {
            background: linear-gradient(135deg, #d4a574, #c4924e);
            color: white; padding: 16px;
        }
        .profile-dropdown .dropdown-header img {
            width: 55px; height: 55px;
            border-radius: 50%; object-fit: cover;
            border: 3px solid rgba(255,255,255,0.5); margin-bottom: 8px;
        }
        .profile-dropdown .dropdown-item {
            padding: 10px 16px; font-size: 14px;
            display: flex; align-items: center; gap: 10px;
        }
        .profile-dropdown .dropdown-item:hover { background-color: #f8f4ef; color: #d4a574; }
        .profile-dropdown .dropdown-item i { width: 16px; color: #d4a574; }
        .profile-dropdown .dropdown-item.text-danger i { color: #dc3545; }
    </style>
</head>

