    <div id="smooth-wrapper">
        <div id="smooth-content">
        {% block breadcrumb %}
        <div class="breadcumb-wrapper text-center" data-bg-src="https://images.unsplash.com/photo-1594608661623-aa0bd3a69d98?w=1920&h=600&fit=crop">
            <div class="container">
                <div class="breadcumb-content">
                    <h1 class="breadcumb-title">Œuvres</h1>
                </div>
                <ul class="breadcumb-menu">
