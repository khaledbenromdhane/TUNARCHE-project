                    <li class="active">ŒUVRES</li>
                </ul>                
            </div>
        </div>
        {% endblock %}

        {% block content %}
        <!--==============================
        Grille des œuvres (style catalogue)
        ==============================-->
        <div class="product-area-1 space overflow-hidden">
            <div class="container">
                <div class="title-area text-center mb-40">
                    <span class="sub-title text-theme">CATALOGUE</span>
                    <h2 class="sec-title">Nos Œuvres</h2>
                </div>
                <div class="d-flex justify-content-center mb-4">
                    <form method="get" action="{{ path('app_front_oeuvre') }}" class="d-inline-flex align-items-center gap-2">
                        <label for="filtre" class="mb-0 fw-semibold">Statut :</label>
                        <select name="filtre" id="filtre" class="form-select form-select-sm" style="width: auto;">
                            <option value="" {{ filtre is null ? 'selected' : '' }}>Toutes</option>
                            <option value="disponible" {{ filtre == 'disponible' ? 'selected' : '' }}>Disponibles</option>
                            <option value="vendue" {{ filtre == 'vendue' ? 'selected' : '' }}>Vendues</option>
                        </select>
                        <button type="submit" class="btn btn-theme btn-sm">Filtrer</button>
                    </form>
                </div>
                {% if oeuvres|length > 0 %}
                <div class="row gy-4">
                    {% for oeuvre in oeuvres %}
                    <div class="col-lg-3 col-md-6">
                        <div class="product-card">
                            <a href="{{ path('app_front_oeuvre_detail', { id: oeuvre.id }) }}" class="text-decoration-none text-inherit">
                                <div class="product-img">
                                    <span class="tag">{{ oeuvre.etat == 'neuve' ? 'Neuve' : 'Défectueuse' }}</span>
                                    <span class="tag tag-statut" style="left: auto; right: 20px; {% if oeuvre.statut == 'vendue' %}background-color: #6c757d;{% else %}background-color: #198754;{% endif %}">{{ oeuvre.statut == 'vendue' ? 'Vendue' : 'Disponible' }}</span>
                                    {% if oeuvre.image %}
                                        <img src="{{ asset('uploads/oeuvres/' ~ oeuvre.image) }}" alt="{{ oeuvre.titre }}">
                                    {% else %}
                                        {% set oeuvre_fallbacks = [
                                            'https://images.unsplash.com/photo-1579783902614-a3fb3927b6a5?w=400&h=400&fit=crop',
                                            'https://images.unsplash.com/photo-1561214115-f2f134cc4912?w=400&h=400&fit=crop',
                                            'https://images.unsplash.com/photo-1578301978693-85fa9c0320b9?w=400&h=400&fit=crop',
                                            'https://images.unsplash.com/photo-1549887534-1541e9326642?w=400&h=400&fit=crop',
                                            'https://images.unsplash.com/photo-1582201942988-13e60e4556ee?w=400&h=400&fit=crop',
                                            'https://images.unsplash.com/photo-1544967082-d9d25d867d66?w=400&h=400&fit=crop'
                                        ] %}
                                        <img src="{{ oeuvre_fallbacks[loop.index0 % 6] }}" alt="{{ oeuvre.titre }}">
                                    {% endif %}
                                </div>
                                <div class="product-content">
                                    <span class="price">{{ oeuvre.prix|number_format(2, ',', ' ') }} DT</span>
                                    <h3 class="product-title">{{ oeuvre.titre }}</h3>
                                    <p class="oeuvre-meta mb-0">
                                        <i class="far fa-user me-1 text-theme"></i> {{ oeuvre.artiste ? oeuvre.artiste.fullName : '-' }}<br>
                                        <i class="far fa-calendar me-1 text-theme"></i> {{ oeuvre.anneeRealisation }}
                                    </p>
                                </div>
                            </a>
                            <div class="p-3 pt-0">
                                {% if oeuvre.statut == 'vendue' %}
                                    <span class="btn btn-secondary w-100 btn-sm disabled"><i class="fas fa-check me-2"></i>Vendue</span>
                                {% elseif oeuvre.statut == 'disponible' %}
                                    <a href="{{ path('app_stripe_acheter', { id: oeuvre.id }) }}" class="btn btn-theme w-100 btn-sm"><i class="fas fa-shopping-cart me-2"></i>Acheter</a>
                                {% endif %}
                            </div>
                        </div>
                    </div>
                    {% endfor %}
                </div>
                {% else %}
                <div class="text-center py-5">
                    <i class="fas fa-palette fa-4x text-muted mb-3"></i>
                    <p class="sec-title mb-0">Aucune œuvre à afficher</p>
                    <p class="text-muted">Notre catalogue sera bientôt disponible.</p>
                </div>
                {% endif %}
            </div>
        </div>
        {% endblock %}

        <!--==============================
            Footer Area
        ==============================-->
        <footer class="footer-wrapper footer-layout2 space-top overflow-hidden"> 
            <div class="container">
                <div class="footer-top text-center">
                    <p class="subtitle">Through Museum Tours and Talks</p>
                    <h2 class="title text-white">GET IN TOUCH</h2>
