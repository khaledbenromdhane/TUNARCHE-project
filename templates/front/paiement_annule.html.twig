{% set fa = asset('frontoffice/assets') %}
{% extends 'front/oeuvre.html.twig' %}

{% block page_title %}Paiement annulé - Tun'Arche{% endblock %}

{% block breadcrumb %}
<div class="breadcumb-wrapper text-center" data-bg-src="{{ fa }}/img/bg/breadcrumb-bg.png">
    <div class="container">
        <div class="breadcumb-content">
            <h1 class="breadcumb-title">Paiement annulé</h1>
        </div>
        <ul class="breadcumb-menu">
            <li><a href="{{ path('app_front_index') }}">ACCUEIL</a></li>
            <li class="active">PAIEMENT</li>
        </ul>
    </div>
</div>
{% endblock %}

{% block content %}
<section class="product-details space">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-8 text-center">
                <div class="mb-4">
                    <i class="fas fa-times-circle text-warning" style="font-size: 4rem;"></i>
                </div>
                <h2 class="sec-title mb-3">Paiement annulé</h2>
                <p class="mb-4">Vous avez annulé le paiement. Aucun prélèvement n'a été effectué.</p>
                {% if oeuvre %}
                    <a href="{{ path('app_front_oeuvre_detail', { id: oeuvre.id }) }}" class="btn btn-outline me-2"><i class="fas fa-arrow-left me-2"></i>Retour à l'œuvre</a>
                {% endif %}
                <a href="{{ path('app_front_oeuvre') }}" class="btn"><i class="fas fa-th-large me-2"></i>Voir les œuvres</a>
            </div>
        </div>
    </div>
</section>
{% endblock %}
