                </div>
            </form>
        </div>
    </div>
</div>
{% endblock %}

{% block javascripts %}
<script>
document.addEventListener('DOMContentLoaded', function () {

    /* ══════════════════════════════════════════════════════
       MOVE MODALS OUT OF #smooth-content
       GSAP ScrollSmoother applies transform to #smooth-content,
       which creates a stacking context that traps position:fixed
       elements. Moving modals to <body> root fixes centering
       and pointer-events.
    ══════════════════════════════════════════════════════ */
    var pmEl = document.getElementById('participateModal');
    var emEl = document.getElementById('editParticipationModal');
    if (pmEl) document.body.appendChild(pmEl);
    if (emEl) document.body.appendChild(emEl);

    /* Pause ScrollSmoother while any modal is open */
    var smoother = (typeof ScrollSmoother !== 'undefined') ? ScrollSmoother.get() : null;
    document.querySelectorAll('.modal').forEach(function (m) {
        m.addEventListener('shown.bs.modal', function () {
            if (smoother) smoother.paused(true);
        });
        m.addEventListener('hidden.bs.modal', function () {
            if (smoother) smoother.paused(false);
        });
    });

    var pmModal = new bootstrap.Modal(pmEl);
    var emModal = new bootstrap.Modal(emEl);
    var today   = new Date().toISOString().split('T')[0];

    /* ── CREATE modal ── */
    document.querySelectorAll('.btn-open-participate').forEach(function (btn) {
        btn.addEventListener('click', function () {
            var d = this.dataset;
            document.getElementById('pm-event-id').value         = d.eventId;
            document.getElementById('pm-event-name').textContent = d.eventNom;

            var dateInput  = document.getElementById('pm-date');
            dateInput.min  = today;
            dateInput.max  = d.eventDate;
            dateInput.value = '';

            document.getElementById('pm-nbr').value   = 1;
            document.getElementById('pm-statut').value = 'En attente';
            document.getElementById('pm-mode').value   = '';

            var pg   = document.getElementById('pm-paiement-group');
            var paid = d.eventPaiement === '1';
            pg.style.display = paid ? 'block' : 'none';
            document.getElementById('pm-mode').required = paid;

            pmModal.show();
        });
    });

    /* ── EDIT modal ── */
    document.querySelectorAll('.btn-open-edit').forEach(function (btn) {
        btn.addEventListener('click', function () {
            var d    = this.dataset;
            var form = document.getElementById('editParticipationForm');
            form.action = '/evenement/participation/' + d.participationId + '/modifier';

            document.getElementById('em-event-id').value         = d.eventId;
            document.getElementById('em-event-name').textContent = d.eventNom;

            var dateInput   = document.getElementById('em-date');
            dateInput.min   = today;
            dateInput.max   = d.eventDate;
            dateInput.value = d.date || '';

            document.getElementById('em-nbr').value   = d.nbr || 1;
            document.getElementById('em-statut').value = d.statut || '';
            document.getElementById('em-mode').value   = d.mode || '';

            var pg   = document.getElementById('em-paiement-group');
            var paid = d.eventPaiement === '1';
            pg.style.display = paid ? 'block' : 'none';
            document.getElementById('em-mode').required = paid;

            emModal.show();
        });
    });

    /* ── Auto-dismiss flash messages ── */
    document.querySelectorAll('.flash-msg').forEach(function (el) {
        setTimeout(function () {
            el.style.transition = 'opacity .4s, transform .4s';
            el.style.opacity = '0';
            el.style.transform = 'translateY(-8px)';
            setTimeout(function () { el.remove(); }, 400);
        }, 4000);
    });
});
</script>
{% endblock %}
