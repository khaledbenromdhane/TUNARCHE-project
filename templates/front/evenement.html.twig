                    <div class="mb-3">
                        <label for="em-nbr" class="form-label">Nombre de places <span style="color:#f87171">*</span></label>
                        <input type="number" class="form-control" id="em-nbr" name="nbr_participation" min="1" required>
                    </div>
                    <div class="mb-3">
                        <label for="em-statut" class="form-label">Statut <span style="color:#f87171">*</span></label>
                        <select class="form-select" id="em-statut" name="statut" required>
                            <option value="">— Choisir —</option>
