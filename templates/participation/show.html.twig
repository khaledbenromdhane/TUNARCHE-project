{# ═══════════════════════════════════════════════════════════════
   Participation – Show (Detail View)
   Route: GET /participation/{id}
═══════════════════════════════════════════════════════════════ #}
{% extends 'base.html.twig' %}

{% block title %}Participation #{{ participation.id }}{% endblock %}

{% block stylesheets %}
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <style>
        :root {
            --gold: #d4af37; --gold-dark: #b8860b;
            --purple: #a855f7; --bg-dark: #0a0a0f;
            --bg-card: rgba(20,20,30,0.95); --border: rgba(212,175,55,0.15);
        }
        body { font-family: 'Poppins', sans-serif; background: var(--bg-dark); color: #e0e0e0; min-height: 100vh; }
        .page-header {
            background: linear-gradient(135deg, rgba(212,175,55,0.08), rgba(138,43,226,0.08));
            border-bottom: 1px solid var(--border); padding: 2rem 0; margin-bottom: 2rem;
        }
        .page-header h1 { color: #fff; font-weight: 700; }
        .detail-card {
            background: var(--bg-card); border: 1px solid var(--border);
            border-radius: 16px; padding: 2.5rem; max-width: 800px; margin: 0 auto;
        }
        .detail-row {
            display: flex; padding: 1rem 0;
            border-bottom: 1px solid rgba(255,255,255,0.04);
        }
        .detail-row:last-child { border-bottom: none; }
        .detail-label {
            width: 220px; flex-shrink: 0; color: rgba(255,255,255,0.5);
            font-weight: 600; font-size: 0.875rem; display: flex;
            align-items: center; gap: 0.5rem;
        }
        .detail-label i { color: var(--gold); width: 18px; text-align: center; }
        .detail-value { color: #fff; font-size: 0.9375rem; flex: 1; }
        .badge-status {
            padding: 0.375rem 0.75rem; border-radius: 6px;
            font-size: 0.8125rem; font-weight: 600;
        }
        .badge-confirmed { background: rgba(34,197,94,0.15); color: #22c55e; border: 1px solid rgba(34,197,94,0.3); }
        .badge-pending { background: rgba(234,179,8,0.15); color: #eab308; border: 1px solid rgba(234,179,8,0.3); }
        .badge-cancelled { background: rgba(239,68,68,0.15); color: #ef4444; border: 1px solid rgba(239,68,68,0.3); }
        .badge-carte { background: rgba(99,102,241,0.15); color: #6366f1; border: 1px solid rgba(99,102,241,0.3); }
        .badge-cash { background: rgba(168,85,247,0.15); color: #a855f7; border: 1px solid rgba(168,85,247,0.3); }
        .badge-type {
            padding: 0.375rem 0.75rem; border-radius: 6px;
            font-size: 0.8125rem; font-weight: 600;
            background: rgba(168,85,247,0.15); color: #a855f7;
            border: 1px solid rgba(168,85,247,0.3);
        }
        .btn-gold {
            background: linear-gradient(135deg, var(--gold), var(--gold-dark));
            color: #0a0a0f; border: none; font-weight: 600;
            padding: 0.625rem 1.5rem; border-radius: 8px; transition: all 0.3s;
        }
        .btn-gold:hover { transform: translateY(-2px); box-shadow: 0 6px 20px rgba(212,175,55,0.4); color: #0a0a0f; }
        .btn-outline-light { border-color: rgba(255,255,255,0.2); color: rgba(255,255,255,0.7); padding: 0.625rem 1.5rem; border-radius: 8px; }
        .btn-outline-light:hover { background: rgba(255,255,255,0.05); color: #fff; }
        .btn-danger-outline {
            border: 1px solid rgba(239,68,68,0.3); color: #ef4444;
            padding: 0.625rem 1.5rem; border-radius: 8px; background: transparent;
            transition: all 0.3s;
        }
        .btn-danger-outline:hover { background: rgba(239,68,68,0.1); color: #ef4444; }
        .id-badge {
            background: rgba(212,175,55,0.1); border: 1px solid rgba(212,175,55,0.3);
            color: var(--gold); padding: 0.375rem 0.75rem; border-radius: 6px;
            font-weight: 600; font-size: 0.875rem;
        }
    </style>
{% endblock %}

{% block body %}
    <div class="page-header">
        <div class="container">
            <div class="d-flex justify-content-between align-items-center flex-wrap gap-3">
                <div>
                    <h1 class="mb-1"><i class="fas fa-eye me-2" style="color: var(--gold);"></i>Détails de la Participation</h1>
                    <nav aria-label="breadcrumb">
                        <ol class="breadcrumb mb-0" style="font-size: 0.875rem;">
                            <li class="breadcrumb-item"><a href="{{ path('app_participation_index') }}" style="color: var(--gold); text-decoration: none;">Participations</a></li>
                            <li class="breadcrumb-item active text-muted">Participation #{{ participation.id }}</li>
                        </ol>
                    </nav>
                </div>
                <a href="{{ path('app_participation_index') }}" class="btn btn-outline-light btn-sm">
                    <i class="fas fa-arrow-left me-1"></i> Retour à la liste
                </a>
            </div>
        </div>
    </div>

    <div class="container pb-5">
        <div class="detail-card">
            <div class="d-flex align-items-center gap-2 mb-4">
                <span class="id-badge"><i class="fas fa-hashtag me-1"></i>ID: {{ participation.id }}</span>
            </div>

            <div class="detail-row">
                <div class="detail-label"><i class="fas fa-calendar-alt"></i> Événement</div>
                <div class="detail-value">
                    {% if participation.evenement %}
                        <span class="badge-type">{{ participation.evenement.nom }}</span>
                    {% else %}
                        <span style="color: rgba(255,255,255,0.3);">N/A</span>
                    {% endif %}
                </div>
            </div>

            <div class="detail-row">
                <div class="detail-label"><i class="fas fa-calendar-day"></i> Date de participation</div>
                <div class="detail-value">{{ participation.dateParticipation|date('d/m/Y') }}</div>
            </div>

            <div class="detail-row">
                <div class="detail-label"><i class="fas fa-users"></i> Nombre de places</div>
                <div class="detail-value">{{ participation.nbrParticipation }}</div>
            </div>

            <div class="detail-row">
                <div class="detail-label"><i class="fas fa-info-circle"></i> Statut</div>
                <div class="detail-value">
                    {% if participation.statut == 'Confirmée' %}
                        <span class="badge-status badge-confirmed"><i class="fas fa-check-circle me-1"></i>{{ participation.statut }}</span>
                    {% elseif participation.statut == 'En attente' %}
                        <span class="badge-status badge-pending"><i class="fas fa-clock me-1"></i>{{ participation.statut }}</span>
                    {% else %}
                        <span class="badge-status badge-cancelled"><i class="fas fa-times-circle me-1"></i>{{ participation.statut }}</span>
                    {% endif %}
                </div>
            </div>

            <div class="detail-row">
                <div class="detail-label"><i class="fas fa-credit-card"></i> Mode de paiement</div>
                <div class="detail-value">
                    {% if participation.modePaiement %}
                        <span class="badge-status {{ participation.modePaiement == 'Carte' ? 'badge-carte' : 'badge-cash' }}">
                            <i class="fas {{ participation.modePaiement == 'Carte' ? 'fa-credit-card' : 'fa-money-bill-wave' }} me-1"></i>{{ participation.modePaiement }}
                        </span>
                    {% else %}
                        <span style="color: rgba(255,255,255,0.3);">— Non applicable (événement gratuit)</span>
                    {% endif %}
                </div>
            </div>

            {% if participation.evenement %}
                <div class="detail-row">
                    <div class="detail-label"><i class="fas fa-map-marker-alt"></i> Lieu de l'événement</div>
                    <div class="detail-value">{{ participation.evenement.lieu }}</div>
                </div>
                <div class="detail-row">
                    <div class="detail-label"><i class="fas fa-calendar"></i> Date de l'événement</div>
                    <div class="detail-value">{{ participation.evenement.date|date('d/m/Y') }} à {{ participation.evenement.heure|date('H:i') }}</div>
                </div>
            {% endif %}

            <hr style="border-color: rgba(255,255,255,0.06); margin: 1.5rem 0;">

            <div class="d-flex justify-content-between flex-wrap gap-2">
                <form action="{{ path('app_participation_delete', {id: participation.id}) }}" method="post"
                      onsubmit="return confirm('Êtes-vous sûr de vouloir supprimer cette participation ?');">
                    <input type="hidden" name="_token" value="{{ csrf_token('delete_participation_' ~ participation.id) }}">
                    <button type="submit" class="btn btn-danger-outline">
                        <i class="fas fa-trash-alt me-1"></i> Supprimer
                    </button>
                </form>
                <a href="{{ path('app_participation_edit', {id: participation.id}) }}" class="btn btn-gold">
                    <i class="fas fa-edit me-1"></i> Modifier
                </a>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
{% endblock %}
