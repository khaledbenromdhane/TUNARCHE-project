{# ═══════════════════════════════════════════════════════════════
   Participation – Modifier (Edit)
   Route: GET|POST /participation/{id}/modifier
   PHP validation errors displayed per field
═══════════════════════════════════════════════════════════════ #}
{% extends 'base.html.twig' %}

{% block title %}Modifier – Participation #{{ participation.id }}{% endblock %}

{% block stylesheets %}
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <style>
        :root {
            --gold: #d4af37; --gold-dark: #b8860b;
            --purple: #a855f7; --bg-dark: #0a0a0f;
            --bg-card: rgba(20,20,30,0.95); --border: rgba(212,175,55,0.15);
        }
        body { font-family: 'Poppins', sans-serif; background: var(--bg-dark); color: #e0e0e0; min-height: 100vh; }
        .page-header {
            background: linear-gradient(135deg, rgba(212,175,55,0.08), rgba(138,43,226,0.08));
            border-bottom: 1px solid var(--border); padding: 2rem 0; margin-bottom: 2rem;
        }
        .page-header h1 { color: #fff; font-weight: 700; }
        .form-card {
            background: var(--bg-card); border: 1px solid var(--border);
            border-radius: 16px; padding: 2.5rem; max-width: 800px; margin: 0 auto;
        }
        .form-card .form-label {
            color: rgba(255,255,255,0.8); font-weight: 600; font-size: 0.875rem;
            margin-bottom: 0.5rem;
        }
        .form-card .form-label .required { color: #ef4444; }
        .form-card .form-label i { color: var(--gold); margin-right: 0.375rem; }
        .form-card .form-control,
        .form-card .form-select {
            background: rgba(255,255,255,0.04);
            border: 1px solid rgba(255,255,255,0.1);
            color: #e0e0e0; border-radius: 8px;
            padding: 0.75rem 1rem; font-size: 0.9375rem;
            transition: all 0.3s;
        }
        .form-card .form-control:focus,
        .form-card .form-select:focus {
            background: rgba(255,255,255,0.06);
            border-color: var(--gold);
            box-shadow: 0 0 0 3px rgba(212,175,55,0.15);
            color: #fff;
        }
        .form-card .form-control.is-invalid,
        .form-card .form-select.is-invalid {
            border-color: #ef4444;
            box-shadow: 0 0 0 3px rgba(239,68,68,0.15);
        }
        .form-card .invalid-feedback {
            color: #ef4444; font-size: 0.8125rem; margin-top: 0.375rem;
            display: flex; align-items: center; gap: 0.375rem;
        }
        .form-card .form-select option { background: #1a1a2e; color: #e0e0e0; }
        .btn-gold {
            background: linear-gradient(135deg, var(--gold), var(--gold-dark));
            color: #0a0a0f; border: none; font-weight: 600;
            padding: 0.75rem 2rem; border-radius: 8px; font-size: 1rem;
            transition: all 0.3s;
        }
        .btn-gold:hover { transform: translateY(-2px); box-shadow: 0 6px 20px rgba(212,175,55,0.4); color: #0a0a0f; }
        .btn-outline-light { border-color: rgba(255,255,255,0.2); color: rgba(255,255,255,0.7); padding: 0.75rem 2rem; border-radius: 8px; }
        .btn-outline-light:hover { background: rgba(255,255,255,0.05); color: #fff; }
        .section-divider {
            height: 1px; background: linear-gradient(90deg, transparent, var(--border), transparent);
            margin: 1.5rem 0;
        }
        .id-badge {
            background: rgba(212,175,55,0.1); border: 1px solid rgba(212,175,55,0.3);
            color: var(--gold); padding: 0.375rem 0.75rem; border-radius: 6px;
            font-weight: 600; font-size: 0.875rem;
        }
        .info-box {
            background: rgba(168,85,247,0.08); border: 1px solid rgba(168,85,247,0.2);
            border-radius: 10px; padding: 1rem 1.25rem; font-size: 0.875rem;
            color: rgba(255,255,255,0.7); display: flex; align-items: center; gap: 0.75rem;
        }
        .info-box i { color: var(--purple); font-size: 1.25rem; }
        #paiementGroup { transition: all 0.3s ease; }
    </style>
{% endblock %}

{% block body %}
    <div class="page-header">
        <div class="container">
            <div class="d-flex justify-content-between align-items-center flex-wrap gap-3">
                <div>
                    <h1 class="mb-1"><i class="fas fa-edit me-2" style="color: var(--gold);"></i>Modifier la Participation</h1>
                    <nav aria-label="breadcrumb">
                        <ol class="breadcrumb mb-0" style="font-size: 0.875rem;">
                            <li class="breadcrumb-item"><a href="{{ path('app_participation_index') }}" style="color: var(--gold); text-decoration: none;">Participations</a></li>
                            <li class="breadcrumb-item active text-muted">Modifier #{{ participation.id }}</li>
                        </ol>
                    </nav>
                </div>
                <a href="{{ path('app_participation_index') }}" class="btn btn-outline-light btn-sm">
                    <i class="fas fa-arrow-left me-1"></i> Retour à la liste
                </a>
            </div>
        </div>
    </div>

    <div class="container pb-5">
        <div class="form-card">
            <div class="d-flex align-items-center gap-2 mb-4">
                <span class="id-badge"><i class="fas fa-hashtag me-1"></i>ID: {{ participation.id }}</span>
            </div>

            <form method="post" action="{{ path('app_participation_edit', {id: participation.id}) }}" novalidate>

                <div class="row g-3">
                    {# ── Événement ── #}
                    <div class="col-12">
                        <label class="form-label" for="id_evenement">
                            <i class="fas fa-calendar-alt"></i> Événement <span class="required">*</span>
                        </label>
                        {% set currentEvtId = errors is not empty ? app.request.request.get('id_evenement') : participation.evenement.id %}
                        <select name="id_evenement" id="id_evenement"
                                class="form-select {{ errors.id_evenement is defined ? 'is-invalid' : '' }}">
                            <option value="" disabled>Sélectionner un événement…</option>
                            {% for evt in evenements %}
                                <option value="{{ evt.id }}"
                                        data-paiement="{{ evt.paiement ? '1' : '0' }}"
                                        data-places="{{ evt.nbrParticipant }}"
                                        data-date="{{ evt.date|date('Y-m-d') }}"
                                        {{ currentEvtId == evt.id ? 'selected' : '' }}>
                                    {{ evt.nom }} ({{ evt.date|date('d/m/Y') }}) — {{ evt.nbrParticipant }} places
                                </option>
                            {% endfor %}
                        </select>
                        {% if errors.id_evenement is defined %}
                            <div class="invalid-feedback d-block">
                                <i class="fas fa-exclamation-triangle"></i> {{ errors.id_evenement }}
                            </div>
                        {% endif %}
                    </div>

                    {# ── Date Participation ── #}
                    <div class="col-md-6">
                        <label class="form-label" for="date_participation">
                            <i class="fas fa-calendar-day"></i> Date de participation <span class="required">*</span>
                        </label>
                        <input type="date" name="date_participation" id="date_participation"
                               class="form-control {{ errors.date_participation is defined ? 'is-invalid' : '' }}"
                               value="{{ errors is not empty ? app.request.request.get('date_participation') : participation.dateParticipation|date('Y-m-d') }}"
                               min="{{ 'now'|date('Y-m-d') }}">
                        {% if errors.date_participation is defined %}
                            <div class="invalid-feedback d-block">
                                <i class="fas fa-exclamation-triangle"></i> {{ errors.date_participation }}
                            </div>
                        {% endif %}
                    </div>

                    {# ── Nombre de places ── #}
                    <div class="col-md-6">
                        <label class="form-label" for="nbr_participation">
                            <i class="fas fa-users"></i> Nombre de places <span class="required">*</span>
                        </label>
                        <input type="number" name="nbr_participation" id="nbr_participation"
                               class="form-control {{ errors.nbr_participation is defined ? 'is-invalid' : '' }}"
                               value="{{ errors is not empty ? app.request.request.get('nbr_participation') : participation.nbrParticipation }}"
                               min="1" placeholder="Ex: 2">
                        {% if errors.nbr_participation is defined %}
                            <div class="invalid-feedback d-block">
                                <i class="fas fa-exclamation-triangle"></i> {{ errors.nbr_participation }}
                            </div>
                        {% endif %}
                    </div>

                    {# ── Statut ── #}
                    <div class="col-md-6">
                        <label class="form-label" for="statut">
                            <i class="fas fa-info-circle"></i> Statut <span class="required">*</span>
                        </label>
                        {% set currentStatut = errors is not empty ? app.request.request.get('statut') : participation.statut %}
                        <select name="statut" id="statut"
                                class="form-select {{ errors.statut is defined ? 'is-invalid' : '' }}">
                            <option value="" disabled>Sélectionner un statut…</option>
                            <option value="En attente" {{ currentStatut == 'En attente' ? 'selected' : '' }}>En attente</option>
                            <option value="Confirmée" {{ currentStatut == 'Confirmée' ? 'selected' : '' }}>Confirmée</option>
                            <option value="Annulée" {{ currentStatut == 'Annulée' ? 'selected' : '' }}>Annulée</option>
                        </select>
                        {% if errors.statut is defined %}
                            <div class="invalid-feedback d-block">
                                <i class="fas fa-exclamation-triangle"></i> {{ errors.statut }}
                            </div>
                        {% endif %}
                    </div>

                    {# ── Mode de paiement (conditional) ── #}
                    <div class="col-md-6" id="paiementGroup" style="display: none;">
                        <label class="form-label" for="mode_paiement">
                            <i class="fas fa-credit-card"></i> Mode de paiement <span class="required">*</span>
                        </label>
                        {% set currentPaiement = errors is not empty ? app.request.request.get('mode_paiement') : participation.modePaiement %}
                        <select name="mode_paiement" id="mode_paiement"
                                class="form-select {{ errors.mode_paiement is defined ? 'is-invalid' : '' }}">
                            <option value="" {{ currentPaiement is empty ? 'selected' : '' }}>Sélectionner…</option>
                            <option value="Carte" {{ currentPaiement == 'Carte' ? 'selected' : '' }}>
                                💳 Carte bancaire
                            </option>
                            <option value="Cash" {{ currentPaiement == 'Cash' ? 'selected' : '' }}>
                                💵 Cash
                            </option>
                        </select>
                        {% if errors.mode_paiement is defined %}
                            <div class="invalid-feedback d-block">
                                <i class="fas fa-exclamation-triangle"></i> {{ errors.mode_paiement }}
                            </div>
                        {% endif %}
                    </div>
                </div>

                <div class="section-divider"></div>

                <div class="info-box mb-4">
                    <i class="fas fa-info-circle"></i>
                    <span>Le nombre de places demandées ne doit pas dépasser la capacité restante de l'événement.</span>
                </div>

                <div class="d-flex justify-content-end gap-2">
                    <a href="{{ path('app_participation_index') }}" class="btn btn-outline-light">Annuler</a>
                    <button type="submit" class="btn btn-gold"><i class="fas fa-save me-1"></i> Enregistrer</button>
                </div>
            </form>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        const evtSelect = document.getElementById('id_evenement');
        const paiementGroup = document.getElementById('paiementGroup');
        const dateInput = document.getElementById('date_participation');

        function togglePaiement() {
            const opt = evtSelect.options[evtSelect.selectedIndex];
            if (opt && opt.dataset.paiement === '1') {
                paiementGroup.style.display = '';
            } else {
                paiementGroup.style.display = 'none';
                document.getElementById('mode_paiement').value = '';
            }
        }

        function updateDateConstraints() {
            const opt = evtSelect.options[evtSelect.selectedIndex];
            if (opt && opt.dataset.date) {
                dateInput.setAttribute('max', opt.dataset.date);
            } else {
                dateInput.removeAttribute('max');
            }
        }

        evtSelect.addEventListener('change', () => {
            togglePaiement();
            updateDateConstraints();
        });
        togglePaiement();
        updateDateConstraints();
    </script>
{% endblock %}
