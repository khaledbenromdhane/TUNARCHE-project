{% extends 'back/base_admin.html.twig' %}

{% block title %}Modifier Formation{% endblock %}
{% block page_title %}Modifier la Formation{% endblock %}

{% block body %}
<div class="row justify-content-center">
    <div class="col-md-10">
        <div class="card card-outline card-warning shadow-sm">
            <div class="card-header">
                <h3 class="card-title">
                    <i class="fas fa-graduation-cap me-2"></i> 
                    Modifier : <strong>{{ formation.nomForm }}</strong>
                </h3>
            </div>
            
            <div class="card-body">
                {# Inclusion du formulaire partagé #}
                {{ include('formation/_form.html.twig', {'button_label': 'Enregistrer les modifications'}) }}
            </div>

            <div class="card-footer bg-light d-flex justify-content-between">
                <a href="{{ path('app_admin_dashboard') }}" class="btn btn-secondary">
                    <i class="fas fa-times me-1"></i> Annuler
                </a>
                
                <form method="post" action="{{ path('app_formation_delete', {'id': formation.id}) }}" onsubmit="return confirm('Voulez-vous vraiment supprimer cette formation ?');">
                    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ formation.id) }}">
                    <button class="btn btn-danger">
                        <i class="fas fa-trash me-1"></i> Supprimer la formation
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>
{% endblock %}