{% extends 'back/base_admin.html.twig' %}

{% block title %}Modifier Formation{% endblock %}
{% block page_title %}Modifier la Formation{% endblock %}

{% block body %}
<div class="row justify-content-center">
    <div class="col-md-10">
        <div class="card card-outline card-warning shadow-sm">
            <div class="card-header">
                <h3 class="card-title">
                    <i class="fas fa-graduation-cap me-2"></i>
                    Modifier : <strong>{{ formation.nomForm }}</strong>
                </h3>
            </div>

            <div class="card-body">
                {# Aperçu image actuelle #}
                {% if formation.imageName %}
                    <div class="mb-3 text-center">
                        <p class="text-muted">Image actuelle :</p>
                        <img src="{{ asset('uploads/formations/' ~ formation.imageName) }}"
                             alt="{{ formation.nomForm }}"
                             style="max-width: 250px; border-radius: 8px; border: 1px solid #ddd; padding: 4px;">
                    </div>
                {% else %}
                    <div class="mb-3 text-center text-muted">
                        <i class="fas fa-image fa-2x"></i>
                        <p>Aucune image pour cette formation</p>
                    </div>
                {% endif %}

                {{ include('formation/_form.html.twig', {'button_label': 'Enregistrer les modifications'}) }}
            </div>

            <div class="card-footer bg-light d-flex justify-content-between">
                <a href="{{ path('app_admin_dashboard') }}" class="btn btn-secondary">
                    <i class="fas fa-times me-1"></i> Annuler
                </a>

                <form method="post" action="{{ path('app_formation_delete', {'id': formation.id}) }}"
                      onsubmit="return confirm('Voulez-vous vraiment supprimer cette formation ?');">
                    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ formation.id) }}">
                    <button class="btn btn-danger">
                        <i class="fas fa-trash me-1"></i> Supprimer la formation
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>
{% endblock %}