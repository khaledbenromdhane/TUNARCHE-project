{% extends 'back/base_admin.html.twig' %}

{% block page_title %}Liste des Formations{% endblock %}

{% block body %}
<div class="card card-outline card-info mb-4 shadow-sm">
    <div class="card-body">
        <form method="get" action="{{ path('app_formation_index') }}" class="row g-3">
            <div class="col-md-4">
                <label class="small fw-bold">Recherche</label>
                <div class="input-group">
                    <span class="input-group-text bg-light"><i class="fas fa-search"></i></span>
                    <input type="text" name="search" class="form-control" placeholder="Nom de la formation..." value="{{ app.request.query.get('search') }}">
                </div>
            </div>
            
            <div class="col-md-3">
                <label class="small fw-bold">Catégorie</label>
                <select name="type" class="form-select">
                    <option value="">Toutes les catégories</option>
                    <option value="Technique" {{ app.request.query.get('type') == 'Technique' ? 'selected' }}>Technique</option>
                    <option value="Management" {{ app.request.query.get('type') == 'Management' ? 'selected' }}>Management</option>
                    <option value="Soft Skills" {{ app.request.query.get('type') == 'Soft Skills' ? 'selected' }}>Soft Skills</option>
                </select>
            </div>

            <div class="col-md-3">
                <label class="small fw-bold">Ordre</label>
                <select name="direction" class="form-select">
                    <option value="ASC" {{ app.request.query.get('direction') == 'ASC' ? 'selected' }}>Ancien → Nouveau</option>
                    <option value="DESC" {{ app.request.query.get('direction') == 'DESC' ? 'selected' }}>Nouveau → Ancien</option>
                </select>
            </div>

            <div class="col-md-2 d-flex align-items-end gap-2">
                <button type="submit" class="btn btn-info w-100 text-white">
                    <i class="fas fa-filter"></i> Filtrer
                </button>
                <a href="{{ path('app_formation_index') }}" class="btn btn-outline-secondary" title="Réinitialiser">
                    <i class="fas fa-sync"></i>
                </a>
            </div>
        </form>
    </div>
</div>

<div class="card card-outline card-primary shadow-sm">
    <div class="card-header">
        <h3 class="card-title">Catalogue des formations ({{ formations|length }})</h3>
        <div class="card-tools">
            <a href="{{ path('app_formation_new') }}" class="btn btn-success btn-sm">
                <i class="fas fa-plus"></i> Ajouter une formation
            </a>
        </div>
    </div>
    <div class="card-body p-0">
        <table class="table table-hover table-striped mb-0">
            <thead>
                <tr>
                    <th>ID</th>
                    {# Tri dynamique sur le nom #}
                    <th>
                        <a href="{{ path('app_formation_index', app.request.query.all|merge({'sort': 'f.nomForm', 'direction': app.request.query.get('direction') == 'ASC' ? 'DESC' : 'ASC'})) }}" class="text-dark">
                            Nom {% if app.request.query.get('sort') == 'f.nomForm' %}<i class="fas fa-sort-{{ app.request.query.get('direction') == 'ASC' ? 'up' : 'down' }}"></i>{% endif %}
                        </a>
                    </th>
                    <th>Date</th>
                    <th>Type</th>
                    <th class="text-center">Actions</th>
                </tr>
            </thead>
            <tbody>
                {% for formation in formations %}
                <tr>
                    <td>{{ formation.id }}</td>
                    <td><strong>{{ formation.nomForm }}</strong></td>
                    <td>{{ formation.dateForm ? formation.dateForm|date('d/m/Y') : '' }}</td>
                    <td>
                        {% set badge_color = 'bg-info' %}
                        {% if formation.type == 'Management' %}{% set badge_color = 'bg-success' %}{% endif %}
                        {% if formation.type == 'Soft Skills' %}{% set badge_color = 'bg-warning' %}{% endif %}
                        <span class="badge {{ badge_color }}">{{ formation.type }}</span>
                    </td>
                    <td class="text-center">
                        <a href="{{ path('app_formation_edit', {'id': formation.id}) }}" class="btn btn-sm btn-warning" title="Modifier">
                            <i class="fas fa-edit"></i>
                        </a>
                        <form method="post" action="{{ path('app_formation_delete', {'id': formation.id}) }}" style="display:inline-block" onsubmit="return confirm('Supprimer ?');">
                            <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ formation.id) }}">
                            <button class="btn btn-sm btn-danger"><i class="fas fa-trash"></i></button>
                        </form>
                    </td>
                </tr>
                {% else %}
                <tr>
                    <td colspan="5" class="text-center py-5">
                        <i class="fas fa-search fa-3x text-muted mb-3 d-block"></i>
                        <p class="text-muted">Aucune formation ne correspond à vos critères.</p>
                        <a href="{{ path('app_formation_index') }}" class="btn btn-sm btn-outline-primary">Afficher tout</a>
                    </td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
</div>
{% endblock %}