{% extends 'back/base_admin.html.twig' %}

{% block title %}Liste des Quizz{% endblock %}
{% block page_title %}Gestion des Quizz{% endblock %}

{% block body %}
<div class="card shadow-sm">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h3 class="card-title">Tous les Quizz</h3>
        <div class="card-tools ms-auto">
            <a href="{{ path('app_admin_quiz_new') }}" class="btn btn-success btn-sm">
                <i class="fas fa-plus"></i> Créer un nouveau
            </a>
        </div>
    </div>
    
    <div class="card-body p-0">
        <table class="table table-hover table-striped mb-0">
            <thead class="table-dark">
                <tr>
                    <th style="width: 80px">Id</th>
                    <th>Titre du Quiz</th>
                    <th>Formation Associée</th>
                    <th class="text-center" style="width: 200px">Actions</th>
                </tr>
            </thead>
            <tbody>
            {% for quiz in quizzes %}
                <tr>
                    <td>{{ quiz.id }}</td>
                    <td><span class="fw-bold">{{ quiz.title }}</span></td>
                    <td>
                        <span class="badge bg-info text-dark">
                            {{ quiz.formation ? quiz.formation.nomForm : 'Aucune' }}
                        </span>
                    </td>
                    <td class="text-center">
                        <div class="btn-group">
                            <a href="{{ path('app_admin_quiz_show', {'id': quiz.id}) }}" class="btn btn-outline-secondary btn-sm" title="Détails">
                                <i class="fas fa-eye"></i>
                            </a>
                            <a href="{{ path('app_admin_quiz_edit', {'id': quiz.id}) }}" class="btn btn-outline-primary btn-sm" title="Modifier">
                                <i class="fas fa-edit"></i>
                            </a>
                        </div>
                    </td>
                </tr>
            {% else %}
                <tr>
                    <td colspan="4" class="text-center py-4">
                        <i class="fas fa-info-circle me-2"></i> Aucun quiz trouvé en base de données.
                    </td>
                </tr>
            {% endfor %}
            </tbody>
        </table>
    </div>
</div>
{% endblock %}